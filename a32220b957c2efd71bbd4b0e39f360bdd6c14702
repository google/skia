      "writtenOn": "2020-09-21T18:39:38Z",
      "side": 1,
      "message": "Is using standard allocation different from today when we use d3d\u0027s \"default allocator\"? Like are we making use of sub alloc\u0027ed heaps yet or do we need the flags to do that?",
      "range": {
        "startLine": 34,
        "startChar": 6,
        "endLine": 34,
        "endChar": 66
      },
      "revId": "a32220b957c2efd71bbd4b0e39f360bdd6c14702",
