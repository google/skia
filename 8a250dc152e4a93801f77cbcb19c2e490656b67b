      "writtenOn": "2018-11-02T17:42:42Z",
      "side": 1,
      "message": "I moved this up (and changed based on the scaled height) to ensure it would be set before we return kIncomplete or kError. (Oops - and I have a bug here - we haven\u0027t actually filled yet. If we keep going in this direction, I\u0027ll need to make sure to fill before setting this.)",
      "range": {
        "startLine": 358,
        "startChar": 0,
        "endLine": 360,
        "endChar": 5
      },
      "revId": "8a250dc152e4a93801f77cbcb19c2e490656b67b",
