    {
      "key": {
        "uuid": "56e622c9_80191203",
        "filename": "src/codec/SkWuffsCodec.cpp",
        "patchSetId": 2
      },
      "lineNbr": 379,
      "author": {
        "id": 8223
      },
      "writtenOn": "2018-11-04T01:23:42Z",
      "side": 1,
      "message": "I\u0027m not sure if it only needs to be done the first time (that onIncrementalDecode is called and we get here). It only needs to be done once Wuffs has completely parsed the palette, but if we hit wuffs_base__suspension__short_read, it\u0027s not guaranteed that the input stream is far along enough that we have completely parsed the palette.\n\nPerhaps Wuffs needs some API to query \"has the palette been completely parsed\", for a decode_frame in progress. Or, I was already considering some way to ask \"what\u0027s the dirty rectangle, in terms of pixels touched so far by decode_frame\", and it could say that the dirty rectangle is empty until the palette is completely decoded. Some thinking required...",
      "parentUuid": "5ec758eb_5a6ef690",
      "range": {
        "startLine": 373,
        "startChar": 0,
        "endLine": 379,
        "endChar": 5
      },
      "revId": "8a250dc152e4a93801f77cbcb19c2e490656b67b",
