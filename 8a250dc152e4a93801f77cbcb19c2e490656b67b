      "lineNbr": 390,
      "author": {
        "id": 8223
      },
      "writtenOn": "2018-11-04T01:23:42Z",
      "side": 1,
      "message": "Out of curiosity, where does \"sampleY \u003e 0\" get enforced? I don\u0027t see any checks in SkSampler.h\u0027s SkSampler::setSampleY.",
      "revId": "8a250dc152e4a93801f77cbcb19c2e490656b67b",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
