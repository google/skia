    {
      "key": {
        "uuid": "dd81a73a_280e3876",
        "filename": "src/codec/SkWuffsCodec.cpp",
        "patchSetId": 2
      },
      "lineNbr": 388,
      "author": {
        "id": 5255
      },
      "writtenOn": "2018-11-05T20:12:59Z",
      "side": 1,
      "message": "Right, assuming we\u0027ve called onGetFrameCount.",
      "parentUuid": "17be3869_38baff45",
      "revId": "8a250dc152e4a93801f77cbcb19c2e490656b67b",
