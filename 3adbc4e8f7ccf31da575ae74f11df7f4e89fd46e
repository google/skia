      "writtenOn": "2017-05-01T13:40:07Z",
      "side": 1,
      "message": "Should there be a base class with virtual methods?",
      "range": {
        "startLine": 16,
        "startChar": 6,
        "endLine": 16,
        "endChar": 35
      },
      "revId": "3adbc4e8f7ccf31da575ae74f11df7f4e89fd46e",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
