import("../../gn/skia.gni")

if (is_ios && skia_use_metal) {
  source_set("minimal_ios_mtl_skia_main") {
    sources = [
      "main.mm",
    ]
    deps = [
      "../..:skia",
    ]
    cflags_objcc = [
      "-std=c++14",
      "-w",
    ]
    libs = [
      "Metal.framework",
      "MetalKit.framework",
      "UIKit.framework",
    ]
  }
}
