# ------------------------------------------------------------------------------

#Method void setMatrix(const SkMatrix& matrix)

Replace Canvas_Matrix with matrix.
Unlike concat(), any prior matrix state is overwritten.

#Param  matrix  Copied into Canvas_Matrix. ##

#Example
void draw(SkCanvas* canvas) {
    SkPaint paint;
    canvas->scale(4, 6);
    canvas->drawText("truth", 5, 2, 10, paint);
    SkMatrix matrix;
    matrix.setScale(2.8f, 6);
    canvas->setMatrix(matrix);
    canvas->drawText("consequences", 12, 2, 20, paint);
}
