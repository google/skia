#Method bool getLocalClipBounds(SkRect* bounds) const 

Return bounds of Canvas_Clip, transformed by inverse of Canvas_Matrix. If Canvas_Clip is empty,
return false, and set bounds to SkRect_MakeEmpty, where all Rect sides equal zero.

bounds is outset by one to account for partial pixel coverage if Canvas_Clip
is anti-aliased.

#Param bounds  Rect of Canvas_Clip in local coordinates. ##

#Return  true if Canvas_Clip bounds is not empty. ##

#Example
    void draw(SkCanvas* canvas) {
        SkCanvas local(256, 256);
        canvas = &local;
        SkRect bounds;
        SkDebugf("local bounds empty = %s\n", canvas->getLocalClipBounds(&bounds)
                 ? "false" : "true");
        SkPath path;
        canvas->clipPath(path);
        SkDebugf("local bounds empty = %s\n", canvas->getLocalClipBounds(&bounds)
                 ? "false" : "true");
    }
    #StdOut
        local bounds empty = false
        local bounds empty = true
