#Method void clipRegion(const SkRegion& deviceRgn, SkClipOp op = SkClipOp::kIntersect)

Replace Canvas_Clip with the intersection or difference of Canvas_Clip and Region deviceRgn.
Resulting Canvas_Clip is aliased; pixels are fully contained by the clip.
deviceRgn is unaffected by Canvas_Matrix.

#Param  deviceRgn    Region to combine with Canvas_Clip. ##
#Param  op  Clip_Op to apply to Canvas_Clip. ##

#Example
#Description
    region is unaffectd by canvas rotation; rect is affected by canvas rotation.
##
void draw(SkCanvas* canvas) {
    canvas->clear(SK_ColorWHITE);
    SkPaint paint;
    SkIRect iRect = {30, 40, 120, 130 };
    SkRegion region(iRect);
    canvas->rotate(10);
    canvas->save();
    canvas->clipRegion(region, SkClipOp::kIntersect);
    canvas->drawCircle(50, 50, 45, paint);
    canvas->restore();
    canvas->translate(100, 100);
    canvas->clipRect(SkRect::Make(iRect), SkClipOp::kIntersect);
    canvas->drawCircle(50, 50, 45, paint);
}
