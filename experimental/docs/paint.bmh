        paint.setUnderlineText(true);
        SkDebugf("paint.isUnderlineText() %c= !!(paint.getFlags() & SkPaint::kUnderlineText_Flag)\n",
                paint.isUnderlineText() == !!(paint.getFlags() & SkPaint::kUnderlineText_Flag) ? '=' : '!');
    
