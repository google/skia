#Method ##

--------------------------------------------------------------------------------

#Method int textToGlyphs(const void* text, size_t byteLength,
                     SkGlyphID glyphs[]) const

textToGlyphs converts text into glyph indices.
Paint Text Encoding specifies how text represents characters or glyphs.
textToGlyphs returns the number of glyph indices represented by text.
glyphs may be nullptr, to compute the glyph count.

textToGlyphs does not check text for valid character encoding or valid
glyph indices.

If byteLength equals zero, textToGlyphs returns zero.
If byteLength includes a partial character, the partial character is ignored.

If Paint Text Encoding is kUTF8_TextEncoding and
text contains an invalid UTF-8 sequence, zero is returned.

    #Example
        void draw(SkCanvas* canvas) {
            SkPaint paint;
            const uint8_t utf8[] = { 0x24, 0xC2, 0xA2, 0xE2, 0x82, 0xAC, 0xF0, 0x90, 0x8D, 0x88 };
            std::vector<SkGlyphID> glyphs;
            int count = paint.textToGlyphs(utf8, sizeof(utf8), nullptr);
            glyphs.resize(count);
            int count2 = paint.textToGlyphs(utf8, sizeof(utf8), &glyphs.front());
            if (count != count2) {
                SkDebugf("expected %d to equal %d\n", count, count2);
                return;
            }
            paint.setTextEncoding(SkPaint::kGlyphID_TextEncoding);
            paint.setTextSize(32);
            canvas->drawText(&glyphs.front(), glyphs.size() * sizeof(SkGlyphID), 10, 40, paint);
        }
    #Example ##

#Method ##

--------------------------------------------------------------------------------

#Method bool containsText(const void* text, size_t byteLength) const #containsText

    containsText returns true if all corresponds to a non-zero glyph ID. 
    containsText returns false if any characters in text are not supported in
    Paint Typeface.

    If Paint Text Encoding is kGlyph_TextEncoding, containsText
    returns true if all glyph indices in text are non-zero; containsText
    does not check to see if text contains valid glyph indices for Paint Typeface.

    containsText returns true if bytelength is zero.

    #Example
        SkPaint paint;
        const uint16_t goodChar = 0x00B0;  // degree symbol
        const uint16_t badChar = 0xD800;   // Unicode surrogate
        paint.setTextEncoding(SkPaint::kUTF16_TextEncoding);
        SkDebugf("0x%04x %c= has char\n", goodChar, 
                paint.containsText(&goodChar, 2) ? '=' : '!');
        SkDebugf("0x%04x %c= has char\n", badChar,
                paint.containsText(&badChar, 2) ? '=' : '!');

        #StdOut
            0x00b0 == has char
            0xd800 != has char
        #StdOut ##
    #Example ##

    #Example
        SkPaint paint;
        const uint16_t goodGlyph = 511;
        const uint16_t zeroGlyph = 0;
        const uint16_t badGlyph = 65535; // larger than glyph count in font
        paint.setTextEncoding(SkPaint::kGlyphID_TextEncoding);
        SkDebugf("0x%04x %c= has glyph\n", goodGlyph, 
                paint.containsText(&goodGlyph, 2) ? '=' : '!');
        SkDebugf("0x%04x %c= has glyph\n", zeroGlyph,
                paint.containsText(&zeroGlyph, 2) ? '=' : '!');
        SkDebugf("0x%04x %c= has glyph\n", badGlyph,
                paint.containsText(&zeroGlyph, 2) ? '=' : '!');

        #StdOut
            0x01ff == has glyph
            0x0000 != has glyph
            0xffff == has glyph
        #StdOut ##
    #Example ##

#SeeAlso setTextEncoding, Typeface

#Method ##

