#Topic ##
--------------------------------------------------------------------------------
#Topic Paint Text Align

Paint Text Align adjusts the text relative to the text position.
Paint Text Align affects glyphs drawn with SkCanvas::drawText, SkCanvas::drawPosText, and
SkCanvas::drawPosTextH, as well as calls that place text glyphs like getTextWidthds and getTextPath.

The text position is set by the font for both horizontal and vertical text.
Typically, For horizontal text, the position is to the left side of the glyph on the base line;
and for vertical text, the position is the horizontal center at the glyph at the caps height.

Paint Text Align adjusts the glyph position to center it or move it to abut the position 
using the metrics returned by the font.

Paint Text Align defaults to kLeft_Align.

#Enum Align

#Code
    enum Align {
        kLeft_Align,
        kCenter_Align,
        kRight_Align,
    };
    enum {
        kAlignCount = 3
    };
#Code ##

kLeft_Align leaves the glyph at the position computed by the font offset by the text position.
kCenter_Align moves the glyph half its width if Paint Flag has kVerticalText_Flag clear, and
half its height if Paint Flag has kVerticalText_Flag set.
kRight_Align moves the glyph by its width if Paint Flag has kVerticalText_Flag clear,
and by its height if Paint Flag has kVerticalText_Flag set.

#Enum ##

#Example
    #Description
    Each position separately moves the glyph in drawPosText.
    #Description ##
    void draw(SkCanvas* canvas) {
        SkPaint paint;
        paint.setTextSize(40);
        SkPoint position[] = {{100, 50}, {150, 40}};
        for (SkPaint::Align a : { SkPaint::kLeft_Align,
                                    SkPaint::kCenter_Align,
                                    SkPaint::kRight_Align}) {
            paint.setTextAlign(a);
            canvas->drawPosText("Aa", 2, position, paint);
            canvas->translate(0, 50);
        }
    }
#Example ##

#Example
    #Description
    Vertical Text treats kLeft_Align as top align, and kRight_Align as bottom align.
    #Description ##
    void draw(SkCanvas* canvas) {
        SkPaint paint;
        paint.setTextSize(40);
        paint.setVerticalText(true);
        for (SkPaint::Align a : { SkPaint::kLeft_Align,
                                    SkPaint::kCenter_Align,
                                    SkPaint::kRight_Align}) {
            paint.setTextAlign(a);
            canvas->drawText("Aa", 2, 50, 100, paint);
            canvas->translate(50, 0);
        }
    }
#Example ##

#Method Align getTextAlign() const

    getTextAlign returns Paint Text Align.
    getTextAlign returns kLeft_Align if Paint Text Align has not been set.

    #Example
        SkPaint paint;
        SkDebugf("kLeft_Align %c= default\n", SkPaint::kLeft_Align == paint.getTextAlign() ? '=' : '!');

        #StdOut
        kLeft_Align == default
        #StdOut ##
    #Example ##
#Method ##

#Method void    setTextAlign(Align align)

    setTextAlign sets Paint Text Align to align.
    setTextAlign has no effect if align is an invalid value.

    #Example
        void draw(SkCanvas* canvas) {
            SkPaint paint;
            paint.setTextSize(40);
            canvas->drawText("Aa", 2, 100, 50, paint);
            paint.setTextAlign(SkPaint::kCenter_Align);
            canvas->drawText("Aa", 2, 100, 100, paint);
            paint.setTextAlign((SkPaint::Align) SkPaint::kAlignCount);
            canvas->drawText("Aa", 2, 100, 150, paint);
        }
    #Example ##

#Method ##

#Topic ##
--------------------------------------------------------------------------------
#Topic Paint Text Size

Paint Text Size adjusts the overall text size.
Paint Text Size can be set to any positive value or zero.
Paint Text Size defaults to 12.
Set SkPaintDefaults_TextSize at compile time to change the default setting.

#Example
    void draw(SkCanvas* canvas) {
        SkPaint paint;
        canvas->drawText("12 point", 8, 10, 20, paint);
        paint.setTextSize(24);
        canvas->drawText("24 point", 8, 10, 60, paint);
        paint.setTextSize(48);
        canvas->drawText("48 point", 8, 10, 120, paint);
    }
#Example ##

#Method SkScalar getTextSize() const

    getTextSize returns Paint Text Size.

    #Example
        SkPaint paint;
        SkDebugf("12 %c= default text size\n", 12 == paint.getTextSize() ? '=' : '!');
    #Example ##

#Method ##

#Method void setTextSize(SkScalar textSize)

    setTextSize sets Paint Text Size.
    setTextSize has no effect if textSize is not greater than or equal to zero.
     
    #Example
        SkPaint paint;
        SkDebugf("12 %c= text size\n", 12 == paint.getTextSize() ? '=' : '!');
        paint.setTextSize(-20);
        SkDebugf("12 %c= text size\n", 12 == paint.getTextSize() ? '=' : '!');
    #Example ##

#Method ##

#Topic ##
--------------------------------------------------------------------------------
#Topic Paint Text Scale X

Paint Text Scale X adjusts the text horizontal scale.
Text scaling approximates condensed and expanded type faces when the actual face
is not available.
Paint Text Scale X can be set to any value.
Paint Text Scale X defaults to 1.

#Example
    void draw(SkCanvas* canvas) {
        SkPaint paint;
        paint.setAntiAlias(true);
        paint.setTextSize(24);
        paint.setTextScaleX(.8f);
        canvas->drawText("narrow", 6, 10, 20, paint);
        paint.setTextScaleX(1);
        canvas->drawText("normal", 6, 10, 60, paint);
        paint.setTextScaleX(1.2f);
        canvas->drawText("wide", 4, 10, 100, paint);
    }
#Example ##

#Method SkScalar getTextScaleX() const

    getTextScaleX returns Paint Text Scale X.

    #Example
        SkPaint paint;
        SkDebugf("1 %c= default text scale x\n", 1 == paint.getTextScaleX() ? '=' : '!');
    #Example ##

#Method ##


#Method void setTextScaleX(SkScalar scaleX)

    setTextScaleX sets Paint Text Scale X.
     
    #Example
        SkPaint paint;
        paint.setTextScaleX(0.f / 0.f);
        SkDebugf("text scale %s-a-number\n", SkScalarIsNaN(paint.getTextScaleX()) ? "not" : "is");
    #Example ##

#Method ##

#Topic ##
--------------------------------------------------------------------------------
#Topic Paint Text Skew X

Paint Text Skew X adjusts the text horizontal skew.
Text skewing approximates italic and oblique type faces when the actual face
is not available.
Paint Text Skew X can be set to any value.
Paint Text Skew X defaults to 0.

#Example
    void draw(SkCanvas* canvas) {
        SkPaint paint;
        paint.setAntiAlias(true);
        paint.setTextSize(24);
        paint.setTextSkewX(-.25f);
        canvas->drawText("right-leaning", 13, 10, 100, paint);
        paint.setTextSkewX(0);
        canvas->drawText("normal", 6, 10, 60, paint);
        paint.setTextSkewX(.25f);
        canvas->drawText("left-leaning", 12, 10, 20, paint);
    }
#Example ##

#Method SkScalar getTextSkewX() const

    getTextSkewX returns Paint Text Skew X.

    #Example
        SkPaint paint;
        SkDebugf("0 %c= default text skew x\n", 0 == paint.getTextSkewX() ? '=' : '!');
    #Example ##

#Method ##

#Method void setTextSkewX(SkScalar skewX)

    setTextSkewX sets Paint Text Skew X.

    #Example
        SkPaint paint;
        paint.setTextScaleX(1.f / 0.f);
        SkDebugf("text scale %s-finite\n", SkScalarIsFinite(paint.getTextScaleX()) ? "is" : "not");
    #Example ##

#Method ##

#Topic ##
--------------------------------------------------------------------------------
#Topic Paint Text Encoding

Paint Text Encoding determines whether text specifies character codes and their encoded size,
or glyph indices. Character codes use the encoding specified by the 
#A Unicode standard # http://unicode.org/standard/standard.html ##. Character codes encoded size
are specified by UTF-8, UTF-16, or UTF-32. All character encoding are able to represent all of
Unicode, differing only in the total storage required.

#A UTF-8 (RFC 3629) # https://tools.ietf.org/html/rfc3629 ## is made up of 8-bit bytes, 
and is a superset of ASCII.
#A UTF-16 (RFC 2781) # https://tools.ietf.org/html/rfc2781 ## is made up of 16-bit words, 
and is a superset of Unicode ranges U+0000 to U+D7FF and U+E000 to U+FFFF.
#A UTF-32 # http://www.unicode.org/versions/Unicode5.0.0/ch03.pdf ## is made up of 32-bit words,
and is a superset of Unicode.

Font Manager uses font data to convert character codes into glyph indices. 
A glyph index is a 16-bit word.

Paint Text Encoding is set to kUTF8_TextEncoding by default.

#Enum TextEncoding
#Code
enum TextEncoding {
    kUTF8_TextEncoding,
    kUTF16_TextEncoding,
    kUTF32_TextEncoding,
    kGlyphID_TextEncoding
};
#Code ##

kUTF8_TextEncoding uses a series of bytes to represent UTF-8 or ASCII.
kUTF16_TextEncoding uses a series of two byte words to represent most of Unicode.
kUTF32_TextEncoding uses a series of four byte words to represent all of Unicode.
kGlyphID_TextEncoding uses a series of two byte words to represent glyph indices.

#Enum ##

#Example
void draw(SkCanvas* canvas) {
    SkPaint paint;
    const char hello8[] = "Hello!";
    const uint16_t hello16[] = { 'H', 'e', 'l', 'l', 'o', '!' };
    const uint32_t hello32[] = { 'H', 'e', 'l', 'l', 'o', '!' };
    paint.setTextSize(24);
    canvas->drawText(hello8, sizeof(hello8) - 1, 10, 30, paint);
    paint.setTextEncoding(SkPaint::kUTF16_TextEncoding);
    canvas->drawText(hello16, sizeof(hello16), 10, 60, paint);
    paint.setTextEncoding(SkPaint::kUTF32_TextEncoding);
    canvas->drawText(hello32, sizeof(hello32), 10, 90, paint);
    uint16_t glyphs[SK_ARRAY_COUNT(hello32)];
    paint.textToGlyphs(hello32, sizeof(hello32), glyphs);
    paint.setTextEncoding(SkPaint::kGlyphID_TextEncoding);
    canvas->drawText(glyphs, sizeof(glyphs), 10, 120, paint);
}
#Example ##

#Method TextEncoding getTextEncoding() const

    getTextEncoding returns Paint Text Encoding.

    #Example
        SkPaint paint;
        SkDebugf("kUTF8_TextEncoding %c= text encoding\n", 
                SkPaint::kUTF8_TextEncoding == paint.getTextEncoding() ? '=' : '!');
        paint.setTextEncoding(SkPaint::kGlyphID_TextEncoding);
        SkDebugf("kGlyphID_TextEncoding %c= text encoding\n", 
                SkPaint::kGlyphID_TextEncoding == paint.getTextEncoding() ? '=' : '!');

        #StdOut
            kUTF8_TextEncoding == text encoding
            kGlyphID_TextEncoding == text encoding
        #StdOut ##
    #Example ##

#Method ##


#Method void setTextEncoding(TextEncoding encoding)

    setTextEncoding sets Paint Text Encoding to encoding.
    Invalid values for encoding are ignored.

    #Example
        SkPaint paint;
        paint.setTextEncoding((SkPaint::TextEncoding) 4);
        SkDebugf("4 %c= text encoding\n", 4 == paint.getTextEncoding() ? '=' : '!');

        #StdOut
            4 != text encoding
        #StdOut ##
    #Example ##

#Method ##

#Topic ##
--------------------------------------------------------------------------------
#Topic Paint Font Metrics

Paint Font Metrics describe dimensions common to the glyphs in Paint Typeface.
The dimensions are computed by Font Manager from font data and do not take 
Paint settings other than Paint Text Size into account.

Font dimensions specify the anchor to the left of the glyph at baseline as the origin.
X-axis values to the left of the glyph are negative, and to the right of the left glyph edge
are positive.
Y-axis values above the baseline are negative, and below the baseline are positive.
 
#Example
#Width 512
void draw(SkCanvas* canvas) {
    SkPaint paint;
    paint.setAntiAlias(true);
    paint.setTextSize(120);
    SkPaint::FontMetrics fm;
    SkScalar lineHeight = paint.getFontMetrics(&fm);
    SkPoint pt = { 70, 180 };
    canvas->clear(SK_ColorWHITE);
    canvas->drawText("M", 1, pt.fX, pt.fY, paint);
    canvas->drawLine(pt.fX, pt.fY, pt.fX, pt.fY + fm.fTop, paint);
    SkScalar ascent = pt.fY + fm.fAscent;
    canvas->drawLine(pt.fX - 25, ascent, pt.fX - 25, ascent + lineHeight, paint);
    canvas->drawLine(pt.fX - 50, pt.fY, pt.fX - 50, pt.fY + fm.fDescent, paint);
    canvas->drawLine(pt.fX + 100, pt.fY, pt.fX + 100, pt.fY + fm.fAscent, paint);
    canvas->drawLine(pt.fX + 125, pt.fY, pt.fX + 125, pt.fY - fm.fXHeight, paint);
    canvas->drawLine(pt.fX + 150, pt.fY, pt.fX + 150, pt.fY - fm.fCapHeight, paint);
    canvas->drawLine(pt.fX + 5, pt.fY, pt.fX + 5, pt.fY + fm.fBottom, paint);
    SkScalar xmin = pt.fX + fm.fXMin;
    canvas->drawLine(xmin, pt.fY + 60, xmin + fm.fMaxCharWidth, pt.fY + 60, paint);
    canvas->drawLine(xmin, pt.fY - 145, pt.fX, pt.fY - 145, paint);
    canvas->drawLine(pt.fX + fm.fXMax, pt.fY - 160, pt.fX, pt.fY - 160, paint);
    SkScalar upos = pt.fY + fm.fUnderlinePosition;
    canvas->drawLine(pt.fX + 25, upos, pt.fX + 130, upos, paint);
    SkScalar urad = fm.fUnderlineThickness / 2;
    canvas->drawLine(pt.fX + 130, upos - urad, pt.fX + 160, upos - urad, paint);
    canvas->drawLine(pt.fX + 130, upos + urad, pt.fX + 160, upos + urad, paint);
    paint.setTextSize(12);
    canvas->drawText("x-min", 5,         pt.fX - 50, pt.fY - 148, paint);
    canvas->drawText("x-max", 5,         pt.fX + 140, pt.fY - 150, paint);
    canvas->drawText("max char width", 14, pt.fX + 120, pt.fY + 57, paint);
    canvas->drawText("underline position", 18, pt.fX + 30, pt.fY + 22, paint);
    canvas->drawText("underline thickness", 19, pt.fX + 162, pt.fY + 13, paint);
    canvas->rotate(-90);
    canvas->drawText("descent", 7,      -pt.fY - 30, pt.fX - 54,  paint);
    canvas->drawText("line height", 11, -pt.fY,      pt.fX - 29,  paint);
    canvas->drawText("top", 3,          -pt.fY + 30, pt.fX - 4,   paint);
    canvas->drawText("ascent", 6,       -pt.fY,      pt.fX + 110, paint);
    canvas->drawText("x-height", 8,     -pt.fY,      pt.fX + 135, paint);
    canvas->drawText("cap-height", 10,  -pt.fY,      pt.fX + 160, paint);
    canvas->drawText("bottom", 6,       -pt.fY - 50, pt.fX + 15,  paint);
}
#Example ##

#Struct FontMetrics

    FontMetrics is filled out by getFontMetrics. FontMetrics contents reflect the values
    computed by Font Manager using Paint Typeface. Values are set to zero if they are
    not availble.

    fUnderlineThickness and fUnderlinePosition have a bit set in fFlags if their values
    are valid, since their value may be zero.
    
    #Enum FontMetricsFlags
        FontMetricsFlags are set in fFlags when underline metrics are valid;
        the underline metric may be valid and zero.
        Fonts with embedded bitmaps may not have valid underline metrics.

        #Code
            enum FontMetricsFlags {
                kUnderlineThinknessIsValid_Flag = 1,
                kUnderlinePositionIsValid_Flag = 2,
            };
        #Code ##

        kUnderlineThinknessIsValid_Flag set in fFlags if fUnderlineThickness is valid.
        kUnderlinePositionIsValid_Flag set in fFlags if fUnderlinePosition is valid.

    #Enum ##

    #Member uint32_t    fFlags
        fFlags is set when underline metrics are valid.
    #Member ##
    
    #Member SkScalar    fTop
        fTop is the largest height for any glyph.
        fTop is a measure from the baseline, and is less than or equal to zero.
    #Member ##
    
    #Member SkScalar    fAscent
        fAscent is the recommended distance above the baseline to reserve for a line of text.
        fAscent is a measure from the baseline, and is less than or equal to zero.
    #Member ##
    
    #Member SkScalar    fDescent
        fDescent is the recommended distance below the baseline to reserve for a line of text.
        fDescent is a measure from the baseline, and is greater than or equal to zero.
    #Member ##
    
    #Member SkScalar    fBottom
        fBottom is the greatest extent below the baseline for any glyph. 
        fBottom is a measure from the baseline, and is greater than or equal to zero.
    #Member ##
    
    #Member SkScalar    fLeading
        fLeading is the recommended distance to add between lines of text.
        fLeading is greater than or equal to zero.
    #Member ##
    
    #Member SkScalar    fAvgCharWidth
        fAvgCharWidth is the average character width, if it is available.
        fAvgCharWidth is zero if no average width is stored in the font.
    #Member ##
    
    #Member SkScalar    fMaxCharWidth
        fMaxCharWidth is the max character width.
    #Member ##
    
    #Member SkScalar    fXMin
        fXMin is the minimum bounding box x value for all glyphs. fXMin
        is typically less than zero.
    #Member ##
    
    #Member SkScalar    fXMax
        fXMax is the maximum bounding box x value for all glyphs. fXMax
        is typically greater than zero.
    #Member ##
    
    #Member SkScalar    fXHeight
        fXHeight is the height of a lower-case 'x'. fXHeight may be zero
        if no lower-case height is stored in the font.
    #Member ##
    
    #Member SkScalar    fCapHeight
        fCapHeight is the height of an upper-case letter. fCapHeight may be zero
        if no upper-case height is stored in the font.
    #Member ##
    
    #Member SkScalar    fUnderlineThickness
        fUnderlineThickness is the underline thickness. If the metric
        is valid, the kUnderlineThinknessIsValid_Flag is set in fFlags.
        If kUnderlineThinknessIsValid_Flag is clear, fUnderlineThickness is zero.
    #Member ##
    
    #Member SkScalar    fUnderlinePosition
       fUnderlinePosition is the underline position relative to the baseline.
       If may be negative, to draw the underline above the baseline, zero
       to draw the underline on the baseline, or positive to draw the underline
       below the baseline. 

       If the metric is valid, the kUnderlinePositionIsValid_Flag is set in fFlags.
       If kUnderlinePositionIsValid_Flag is clear, fUnderlinePosition is zero.
    #Member ##

    #Method bool hasUnderlineThickness(SkScalar* thickness) const
        If Paint Font Metrics has a valid underline thickness, return true, and set 
        thickness to that value. If it doesn't, return false, and ignore
        thickness.
    #Method ##

    #Method bool hasUnderlinePosition(SkScalar* position) const
        If Paint Font Metrics has a valid underline position, return true, and set 
        position to that value. If it doesn't, return false, and ignore
        position.
    #Method ##

#Struct ##

#Method SkScalar getFontMetrics(FontMetrics* metrics, SkScalar scale = 0) const

    getFontMetrics returns Paint Font Metrics associated with Paint Typeface.
    The return value is the recommended spacing between lines: the sum of metrics
    descent, ascent, and leading.
    If metrics is not nullptr, Paint Font Metrics is copied to metrics.
    getFontMetrics scales its results by Paint Text Size and but does not take into account
    dimensions required by stroking and other path effects.
    getFontMetrics results can be additionally scaled by scale.

    #Param metrics  If not null, Paint Font Metrics for Paint Typeface are copied here. ##
    #Param scale    If not 0, an additional multiplier for returned values. ##
    #Return         The recommended spacing between lines. ##

    #Example
        void draw(SkCanvas* canvas) {
            SkPaint paint;
            paint.setTextSize(32);
            SkScalar lineHeight = paint.getFontMetrics(nullptr);
            canvas->drawText("line 1", 6, 10, 40, paint);
            canvas->drawText("line 2", 6, 10, 40 + lineHeight, paint);
            paint.setStyle(SkPaint::kStroke_Style);
            paint.setStrokeWidth(10);
            lineHeight = paint.getFontMetrics(nullptr, 1.10f);  // account for stroke height
            canvas->drawText("line 3", 6, 120, 40, paint);
            canvas->drawText("line 4", 6, 120, 40 + lineHeight, paint);
        }
    #Example ##

    #SeeAlso Paint Text Size, Paint Typeface, Typeface

#Method ##

#Topic ##
--------------------------------------------------------------------------------

#Method SkScalar getFontSpacing() const

    /** Return the recommend line spacing. This will be
        fDescent - fAscent + fLeading
    */

#Example
#Example ##

