##Class #SkPaint

--------------------------------------------------------------------------------

##Method SkPaint::SkPaint() #empty_constructor

#Method constructs an SkPaint with these settings:

##Table
# Anti-alias             # ##A false       kAntiAlias_Flag       ## ##
# Alpha                  # ##A 255         setAlpha              ## ##
# Blend Mode             # ##A srcOver     SkBlendMode::kSrcOver ## ##
# Stroke Cap             # ##A butt        kButt_Cap             ## ##
# Color                  # ##A black       SK_ColorBLACK         ## ##
# Color Filter           # #AA nullptr     setColorFilter        ## ##
# Dither                 # ##A false       kDither_Flag          ## ##
# Draw Looper            # ##A nullptr     setDrawLooper         ## ##
# Embedded Bitmap Fonts  # ##A false       #kEmbeddedBitmapText_Flag ## ##
# Fake Bold              # #AA false       #setFakeBoldText ##          ##
# Filter Quality         # ##A none        #kNone_SkFilterQuality ##    ##
# Forced Autohinting     # ##A false       #kAutoHinting_Flag ##        ##
# Image Filter           # ##A nullptr     #setImageFilter ##           ##
# Join Type              # ##A miter       #kMiter_Join ##              ##
# Linear Text            # ##A false       #kLinearText_Flag ##         ##
# Mask Filter            # ##A nullptr     #setMaskFilter ##            ##
# Miter Limit            # ##A 4           #setMiterLimit ##            ##
# Path Effect            # ##A nullptr     #setPathEffect ##            ##
# Rasterizer             # ##A nullptr     #setRasterizer ##            ##
# Shader                 # ##A nullptr     #setShader ##                ##
# Stroke Width           # ##A 0           #hairline ##                 ##
# Subpixel Glyph         # ##A false       #kLCDRenderText_Flag ##      ##
# Subpixel Position      # ##A false       #kSubpixelText_Flag ##       ##
# Strikethrough          # ##A false       #setStrikeThruText ##        ##
# Style                  # ##A fill        #kFill_Style ##              ##
# Text Alignment         # ##A left        #kLeft_Align ##              ##
# Text Direction         # ##A horizontal  #kVerticalText_Flag ##       ##
# Text Encoding          # ##A UTF-8       #kUTF8_TextEncoding ##       ##
# Text Hinting           # ##A normal      #kNormal_Hinting ##          ##
# Text Kerning           # ##A false       #kDevKernText_Flag ##        ##
# Text Scale X           # ##A 1           #setTextScaleX ##            ##
# Text Size              # ##A 12          #setTextSize ##              ##
# Text Skew X            # ##A 0           #setTextSkewX ##             ##
# Ttypeface              # #AA nullptr     #setTypeface ##              ##
# Underline              # ##A false       #setUnderlineText ##         ##
##Table ##

The flags, text size, hinting, and miter limit may be overridden at compile time by defining
paint default values. The overrides may be included in SkUserConfig.h or predefined by the 
build system.  

##Example #paint_defaults
###$  $ redefine markup character so preprocessor commands appear normally
#ifndef SkUserConfig_DEFINED
#define SkUserConfig_DEFINED

#define SkPaintDefaults_Flags      0x01   // always enable antialiasing
#define SkPaintDefaults_TextSize   24.f   // double default font size
#define SkPaintDefaults_Hinting    3      // use full hinting
#define SkPaintDefaults_MiterLimit 10.f   // use HTML Canvas miter limit setting

#endif
$$$#  # restore original markup character
##Example ##

##Example #measureText
SkPaint paint;
SkDebugf("default width = %g\n", paint.measureText("!", 1));
paint.setTextSize(paint.getTextSize() * 2);
SkDebugf("double width = %g\n", paint.measureText("!", 1));
##Example ##

##StdOut #measureText
default width = 3
double width = 7
##StdOut ##

##Method ##

--------------------------------------------------------------------------------

##Method SkPaint(const SkPaint& paint) #copy_constructor

#Method does a shallow copy of the paint. The paint's typeface, path effect, shader,
mask filter, color filter, rasterizer, draw looper, and image filter are shared
between the original paint and the copy. These objects' reference counts are increased.

By convention, path effects, shaders, and so on have a Make method to instantiate
the object, and only const methods to examine it. This prevents the reference-counted
objects in a paint from being modified on the outside.

##Example #setColor
SkPaint paint1;
paint1.setColor(SK_ColorRED);
SkPaint paint2(paint1);
paint2.setColor(SK_ColorBLUE);
SkASSERT(SK_ColorRED == paint1.getColor());
SkASSERT(SK_ColorBLUE == paint2.getColor());
##Example ##

##Method ##

--------------------------------------------------------------------------------

##Method SkPaint(const SkPaint&& paint) #move_constructor

#Method implements a move constructor to avoid incrementing the reference counts
of objects referenced by the paint.

##Example
SkPaint makeDash(SkPaint paint) {
    float intervals[] = { 5, 5 };
    paint.setPathEffect(SkDashPathEffect::Make(intervals, 2, 2.5f));
    return paint;
}

SkPaint paint = makeDash(SkPaint());
SkDebugf("ref count = %d\n", paint.getPathEffect()->getRefCnt());
##Example ##

##StdOut
ref count = 1
##StdOut ##

##Method ##

--------------------------------------------------------------------------------

##Method ~SkPaint() #destructor

Decrease the reference count of the paint's typeface, path effect, shader,
mask filter, color filter, rasterizer, draw looper, and image filter. If the
objects' reference count goes to zero, delete them.

##Method ##

--------------------------------------------------------------------------------

##Method SkPaint& operator=(const SkPaint&) #copy_assignment_operator

##Example
SkPaint paint1, paint2;
paint1.setColor(SK_ColorRED);
paint2 = paint1;
SkASSERT(SK_ColorRED == paint1.getColor());
SkASSERT(SK_ColorRED == paint2.getColor());
