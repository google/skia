#Topic ##
# ------------------------------------------------------------------------------

#Method bool nothingToDraw() const

    nothingToDraw returns true if Paint prevents all drawing.
    If nothingToDraw returns false, the Paint is not guaranteed to allow drawing.

    nothingToDraw returns true if Blend_Mode and Color_Alpha are enabled,
    and set the computed Color_Alpha to zero.

    #Example
        void draw(SkCanvas* canvas) {
            SkPaint paint;
            SkDebugf("nothing to draw: %s\n", paint.nothingToDraw() ? "true" : "false");
            paint.setBlendMode(SkBlendMode::kDst);
            SkDebugf("nothing to draw: %s\n", paint.nothingToDraw() ? "true" : "false");
            paint.setBlendMode(SkBlendMode::kSrcOver);
            SkDebugf("nothing to draw: %s\n", paint.nothingToDraw() ? "true" : "false");
            paint.setAlpha(0);
            SkDebugf("nothing to draw: %s\n", paint.nothingToDraw() ? "true" : "false");
        }

        #StdOut
            nothing to draw: false
            nothing to draw: true
            nothing to draw: false
            nothing to draw: true
        #StdOut  ##
    ##

##

