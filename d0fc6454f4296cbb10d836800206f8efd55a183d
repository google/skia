      "writtenOn": "2019-08-13T19:20:09Z",
      "side": 1,
      "message": "This simplifies the different filtering signatures, and helps differentiate the \u0027src\u0027 and \u0027input\u0027 images that a filter might access. In most cases, the filter only cares about the \u0027input\u0027 image and the fact that \u0027src\u0027 was assigned as the \u0027input\u0027 is irrelevant to them.",
      "range": {
        "startLine": 85,
        "startChar": 0,
        "endLine": 86,
        "endChar": 65
      },
      "revId": "d0fc6454f4296cbb10d836800206f8efd55a183d",
