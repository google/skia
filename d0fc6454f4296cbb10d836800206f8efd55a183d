    {
      "key": {
        "uuid": "8a90d71b_78ebcbd3",
        "filename": "src/core/SkImageFilterTypes.h",
        "patchSetId": 5
      },
      "lineNbr": 91,
      "author": {
        "id": 8341
      },
      "writtenOn": "2019-08-13T19:20:09Z",
      "side": 1,
      "message": "New helpers that hide the use of the source image. Frequently implementations would pass the source special image and the actual filtered \u0027input\u0027 image into their processing function. The result would be based on the contents of \u0027input\u0027, but \u0027src\u0027 would be used to create scratch surfaces, or to decide on cpu-gpu mode.\n\nWhile the underlying logic is still based on how the source image was created, this helps make it clear that \u0027input\u0027 is the image being processed.",
      "range": {
        "startLine": 88,
        "startChar": 0,
        "endLine": 91,
        "endChar": 78
      },
