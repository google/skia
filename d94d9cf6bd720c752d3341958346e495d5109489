      "writtenOn": "2021-02-03T13:33:10Z",
      "side": 1,
      "message": "I\u0027m curious why the behavior is different when running locally.  Task drivers are designed to be able to run locally without special handling.",
      "range": {
        "startLine": 51,
        "startChar": 0,
        "endLine": 51,
        "endChar": 13
      },
      "revId": "d94d9cf6bd720c752d3341958346e495d5109489",
