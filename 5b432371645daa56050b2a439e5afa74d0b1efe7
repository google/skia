    {
      "key": {
        "uuid": "be663b38_9c80f593",
        "filename": "src/codec/SkWuffsCodec.cpp",
        "patchSetId": 1
      },
      "lineNbr": 507,
      "author": {
        "id": 5255
      },
      "writtenOn": "2018-11-19T19:55:48Z",
      "side": 1,
      "message": "No. Next patch set disables 565. We need 565 for the first frame, for compatibility with Android. For later frames, we (i.e. SkGifCodec/Android) currently don\u0027t allow 565. The current method for blending doesn\u0027t work in 565, because we first use the swizzler, and then we do not know which pixels should be considered transparent. We could make it work, but Skia is generally moving away from 565, so I don\u0027t currently have a plan to do so.\n\nFWIW, this also doesn\u0027t work for F16, which didn\u0027t work prior to this change, either. Next patch set disables F16, too, until a follow-on change uses skcms. (Unless you\u0027d rather pull that in here? I figured this could be landed sooner, so that flutter can go ahead and use wuffs.)",
      "parentUuid": "5ee09487_bd2dd367",
      "revId": "5b432371645daa56050b2a439e5afa74d0b1efe7",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
