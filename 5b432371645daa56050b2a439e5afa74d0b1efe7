        "id": 5255
      },
      "writtenOn": "2018-11-19T19:55:48Z",
      "side": 1,
      "message": "That sounds like a good idea to me.",
      "parentUuid": "0e77b83e_fd149360",
      "revId": "5b432371645daa56050b2a439e5afa74d0b1efe7",
