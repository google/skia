      "writtenOn": "2020-08-10T16:58:53Z",
      "side": 1,
      "message": "This interface is only available with the Windows 10 Creators Update and beyond, which was released in April 2017. Grabbing an alternate interface is basically how Direct3D handles extensions.",
      "parentUuid": "9f341365_8d7932ed",
      "range": {
        "startLine": 285,
        "startChar": 8,
