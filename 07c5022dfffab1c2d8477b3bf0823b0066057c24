      "side": 1,
      "message": "There\u0027s another way to slice this,\n\nmessage Clip {\n   enum Verb {\n       INTERSECT \u003d 0,\n       DIFFERENCE \u003d 1,\n   }\n\n   bool aa   \u003d 1;\n   Verb verb \u003d 2;\n\n   oneof geometry {\n       Rect  rect  \u003d 3;\n       RRect rrect \u003d 4;\n       Path  path  \u003d 5;\n       ...\n   }\n}\n\nThat\u0027d let you scope ClipVerb right tightly in with everything that would reference it.\n\nSimilarly, we could probably use this same sort of arrangement to slice up the paint fields to just the kinds of draws that want them....\n\n\nmessage Geometry {\n   bool aa \u003d 1;\n\n   oneof geometry {\n     Rect  rect  \u003d 2;\n     Rect  oval  \u003d 3;\n     RRect rrect \u003d 4;\n     Path  path  \u003d 5;\n     ...\n   }\n}\n\nmessage Clip {\n  enum Verb {\n     INTERSECT \u003d 0,\n     DIFFERENCE \u003d 1,\n  }\n  \n  Geometry geometry \u003d 1;\n  Verb     verb     \u003d 2;\n}\n\nmessage Shader {\n   oneof shader {\n       Color    color    \u003d 1;\n       Image    image    \u003d 2;\n       Gradient gradient \u003d 3;\n       ...\n   }\n}\n\nmessage Fill {\n   Geometry geometry \u003d 1; \n   Shader   shader   \u003d 2;\n\n   bool dither \u003d 3;\n}\n\nmessage Stroke {\n   Geometry geometry \u003d 1; \n   Shader   shader   \u003d 2;\n\n   float width \u003d 3;\n   float miter \u003d 4;\n   ...\n}\n\nmessage Text {\n   ... some fields that describe the typeface and glyphs ...\n   Shader shader \u003d 2;\n\n   float size   \u003d 3;\n   float scaleX \u003d 4;\n   float skewX  \u003d 5;\n   ...\n}\n\n\nmessage DrawMsg {\n   oneof msg {\n       Save    save    \u003d 1;\n       Restore restore \u003d 2;\n\n       Concat concat \u003d 3;\n       Clip   clip   \u003d 4;\n\n       Fill   fill   \u003d 5;\n       Stroke stroke \u003d 6;\n       Text   text   \u003d 7;\n   }\n}",
