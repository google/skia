    },
    {
      "key": {
        "uuid": "87ea2c7b_1fbea99a",
        "filename": "modules/canvaskit/canvaskit/viewer.html",
        "patchSetId": 2
      },
      "lineNbr": 80,
      "author": {
        "id": 5633
      },
      "writtenOn": "2020-05-27T18:15:15Z",
      "side": 1,
      "message": "Uh oh! My only constraint is that \"BlitOffscreenFramebuffer\" needs to be called after _flush().\n\nThe other constraint I have is that for the sake of benchmarking, I might want to call\n\ndraw()\nflush()\ndraw()\nflush()\n\nIn succession, since JS caps us at 60fps and we want to measure with finer granularity.",
      "parentUuid": "5cf1cc20_c9d5e843",
      "range": {
        "startLine": 80,
        "startChar": 12,
        "endLine": 80,
        "endChar": 33
      },
      "revId": "81b86d32fda1d97549a6b571d4d5f8f9bcbed8da",
