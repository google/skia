void not_foldable() {
    half4 v = half4(half(sqrt(1)));
    half x = v[0];
    half y = v[1];
    half z = v[2];
    half w = v[3];
    sk_FragColor = half4(x, y, z, w);
}

void foldable() {
    half4 v = half4(2);
    half x = v[0];
    half y = v[1];
    half z = v[2];
    half w = v[3];
    sk_FragColor = half4(x, y, z, w);
}

void main() {
    not_foldable();
    foldable();
}
