/*#pragma settings AllowNarrowingConversions*/

float f = 1;

void main() {
    half h = f;     sk_FragColor.x = h;
    int i = h;      sk_FragColor.x = i;
    uint ui = i;    sk_FragColor.x = ui;
    short s = ui;   sk_FragColor.x = s;
    ushort us = s;  sk_FragColor.x = us;
    byte b = us;    sk_FragColor.x = b;
    ubyte ub = b;   sk_FragColor.x = ub;
}
