/*#pragma settings NoInline*/

half glob = 1;


half4 fn(half a, out half2 b, half2 c, inout half3 d) {
    a = sk_FragColor.r + a;
    b = sk_FragColor.gb - glob;
    c = sk_FragColor.bb * c;
    d = sk_FragColor.aaa / d;
    return half4(a, b.x, c.x, d.x);
}

void main() {
    half2   a = half2(1);
    half3   b = half3(2);
    half4x4 c = half4x4(3);
    half3x3 d = half3x3(4);

    sk_FragColor = fn(a.x, b.yz, c[0].zx, d[1].zyx);
}
