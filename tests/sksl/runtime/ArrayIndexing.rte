uniform float u1[4];
float index_by_literal() {
    return u1[0];
}

uniform float u2[4];
float index_by_loop() {
    float sum = 0;
    for (int i = 0; i < 4; ++i) {
        sum += u2[i];
    }
    return sum;
}

uniform float u3[4];
float index_by_complex_loop() {
    float prod = 1;
    for (int i = 0; i < 4; ++i) {
        prod *= u3[i < 2 ? 0 : i];
    }
    return prod;
}

float4 main() {
    return float4(
        index_by_literal(),
        index_by_loop(),
        index_by_complex_loop(),
        1);
}
