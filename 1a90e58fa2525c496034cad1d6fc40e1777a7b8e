    },
    {
      "key": {
        "uuid": "735d509f_d844e066",
        "filename": "include/gpu/GrContext.h",
        "patchSetId": 1
      },
      "lineNbr": 445,
      "author": {
        "id": 5036
      },
      "writtenOn": "2018-02-09T19:17:17Z",
      "side": 1,
      "message": "I thought there was something we were going to do, or maybe that was in FlushState world?",
      "parentUuid": "d7b6ad48_ea22b84a",
      "range": {
        "startLine": 442,
        "startChar": 6,
        "endLine": 445,
        "endChar": 87
      },
      "revId": "1a90e58fa2525c496034cad1d6fc40e1777a7b8e",
