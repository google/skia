      "writtenOn": "2021-02-04T22:46:20Z",
      "side": 1,
      "message": "Can we get away with `using Operators::Precedence`?\n\n(`using namespace` is forbidden in the Google style guide, which I know we don\u0027t rigorously follow but I like to try and stay on the straight and narrow where we can.)",
      "range": {
        "startLine": 27,
        "startChar": 6,
        "endLine": 27,
        "endChar": 25
      },
      "revId": "f4c51025090359731dcc9149f51a40562081b50e",
