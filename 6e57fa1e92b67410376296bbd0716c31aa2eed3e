      "writtenOn": "2019-04-25T19:29:49Z",
      "side": 1,
      "message": "If GrPrepareForExternalIORequests is provided, but semaphores are not. Which value will be returned?",
      "range": {
        "startLine": 277,
        "startChar": 28,
        "endLine": 277,
        "endChar": 54
      },
      "revId": "6e57fa1e92b67410376296bbd0716c31aa2eed3e",
