    {
      "key": {
        "uuid": "f5cdb148_db2d903e",
        "filename": "src/gpu/GrOpFlushState.cpp",
        "patchSetId": 8
      },
      "lineNbr": 121,
      "author": {
        "id": 5085
      },
      "writtenOn": "2018-06-26T13:16:52Z",
      "side": 1,
      "message": "We aren\u0027t doing that for the other two pointer types compared here. This catches cases where a single op makes a pipeline and gp and does several mesh draws. If doing a deep comparison of gp, pipeline, and dynamic state yielded more opportunities here I think we\u0027d be better off catching those upstack in op combining.\n\nOne example of this is AAConvexPathOp. In the lines-only case it makes a gp/pipeline and then draws a mesh for each path in the op.\n\nI\u0027m not sure how important this is to catch but changing that behavior is kind of orthogonal to this change.",
      "parentUuid": "6a36e569_efb46c0a",
      "revId": "ccf89f45387c23e8a4689e961a7f3d7b6f5c3c61",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
    {
