      "unresolved": true
    },
    {
      "key": {
        "uuid": "658b7033_72d59df9",
        "filename": "src/gpu/glsl/GrGLSL.cpp",
        "patchSetId": 11
      },
      "lineNbr": 100,
      "author": {
        "id": 5036
      },
      "writtenOn": "2020-09-14T16:14:20Z",
      "side": 1,
      "message": "So the history here is that in SPIR-V this is a special type of variable, subpassInput, used for getting attachment pixels (different from sampling textures). It also has its own special sample call, subpassLoad which takes integer offsets instead of a normal coordinate. So we added these to SkSL many years ago now when SkSL\u0027s main function was translating into spirv and glsl. Though until now they haven\u0027t ever been used.\n\nSo I\u0027m simply using the things we have now for simplicity. Previously talking to ethan we talked how maybe it makes sense to rename the subpassLoad op to just a sample call that takes a subpassInput. And additionally we can rename subpassInput to whatever name matches more of what the rest of SkSL has evolved to. In the end we just need to be able to distinguish that variable type and the special type of sample.\n\nBut IMO that is all out of the scope of this specific change.",
      "parentUuid": "6d4758fd_972014de",
      "range": {
        "startLine": 100,
        "startChar": 20,
        "endLine": 100,
        "endChar": 32
      },
      "revId": "cb8fe4dd0017d71b970bd34b0ef406877f79b574",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
