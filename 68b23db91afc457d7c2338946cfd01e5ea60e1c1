      "lineNbr": 475,
      "author": {
        "id": 8209
      },
      "writtenOn": "2018-07-02T21:15:40Z",
      "side": 1,
      "message": "If a non volatile mesh batches with another mesh, then the next time the mesh is drawn, it will draw the previous mesh that it batched with, which isn\u0027t necessarily there anymore.",
