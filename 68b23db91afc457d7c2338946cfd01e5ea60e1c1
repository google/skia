      "lineNbr": 471,
      "author": {
        "id": 8209
      },
      "writtenOn": "2018-07-02T21:15:40Z",
      "side": 1,
      "message": "We can\u0027t allow meshes with bones to batch, because different meshes use different bones, and so then we would have to combine the bone matrices as well as alter the vertex attributes, which we would then be unable to cache.",
      "parentUuid": "3cc99d7a_9fba1ecc",
      "revId": "68b23db91afc457d7c2338946cfd01e5ea60e1c1",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
