uniform half4 a, b;
uniform uint2 c, d;
uniform int3 e, f;
void main() {
    bool4 expectTTFF = lessThan(half4(1, 2, 3, 4), half4(3));
    bool4 expectFFTT = lessThan(int4(0), int4(-100, -50, 50, 100));

    sk_FragColor.x = lessThan(a, b).x ? 1 : 0;
    sk_FragColor.y = lessThan(c, d).y ? 1 : 0;
    sk_FragColor.z = lessThan(e, f).z ? 1 : 0;
    sk_FragColor.w = any(expectTTFF) || any(expectFFTT) ? 1 : 0;
}
