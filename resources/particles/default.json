{
   "MaxCount": 4096,
   "Duration": 2,
   "Rate": 1000,
   "Drawable": {
      "Type": "SkCircleDrawable",
      "Radius": 1
   },
   "Code": [
      "// float rand; Every read returns a random float [0 .. 1)",
      "",
      "void effectUpdate(inout float rate) {",
      "  rate = 0;",
      "  burst(0.0, 2000);",
      "  burst(0.5, 2000);",
      "}",
      "",
      "void spawn(inout Particle p) {",
      "  p.lifetime = 1;//mix(1, 3, rand);",
      "  float a = radians(mix(250, 290, rand));",
      "  float s = mix(10, 30, rand);",
      "  p.vel.x = cos(a) * s;",
      "  p.vel.y = sin(a) * s;",
      "  p.pos = text(rand).xy;",
      "  if (effectAge >= 0.5) { p.pos = text2(rand).xy; }",
      "}",
      "",
      "void update(inout Particle p) {",
      "  float4 startColor = float4(1, 0.196, 0.078, 1);",
      "  float4 endColor   = float4(1, 0.784, 0.078, 1);",
      "  p.color = mix(startColor, endColor, p.age);",
      "}",
      ""
   ],
   "Bindings": [
      {
         "Type": "SkTextBinding",
         "Name": "text",
         "Text": "SKIA",
         "FontSize": 96
      },
      {
         "Type": "SkTextBinding",
         "Name": "text2",
         "Text": "ROCKS",
         "FontSize": 96
      }
   ]
}