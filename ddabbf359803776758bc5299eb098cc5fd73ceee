      },
      "lineNbr": 114,
      "author": {
        "id": 5631
      },
      "writtenOn": "2019-02-12T18:29:37Z",
      "side": 1,
      "message": "I think it makes sense, but I realize that many people object to this style. I can rearrange this to use default args on non-virtuals, and dispatch to virtual helpers (Skia\u0027s typical pattern).",
      "parentUuid": "33fd8377_79c7c386",
      "range": {
        "startLine": 114,
        "startChar": 44,
        "endLine": 114,
        "endChar": 51
      },
