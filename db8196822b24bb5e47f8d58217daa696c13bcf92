      "lineNbr": 4,
      "author": {
        "id": 5395
      },
      "writtenOn": "2020-05-01T14:00:45Z",
      "side": 1,
      "message": "Yes, I ran this approach by him already. Here, the noisy frames at the beginning (e.g. the first frame regularly takes a long time) are an intentional thing we are trying to capture.",
      "parentUuid": "0ad12bd9_bbce89d8",
      "range": {
        "startLine": 4,
        "startChar": 34,
        "endLine": 4,
        "endChar": 96
      },
