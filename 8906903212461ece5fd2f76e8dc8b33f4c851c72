    },
    {
      "key": {
        "uuid": "90fae922_902d0dda",
        "filename": "src/gpu/GrFragmentProcessor.h",
        "patchSetId": 7
      },
      "lineNbr": 221,
      "author": {
        "id": 11059
      },
      "writtenOn": "2020-06-16T20:44:10Z",
      "side": 1,
      "message": "If we take the names `Success` and `Failure` then we\u0027ve kind of monopolized their use throughout all of GrFragmentProcessor. If we could tightly scope it so that these Success() and Failure() helpers only applied inside of a Make() function, I\u0027d 100% agree with this suggestion. There might be a trick we can do to get what we want here, but I don\u0027t want to snipe the names \"Success\" and \"Failure\" broadly. That seems like overkill.",
      "parentUuid": "f50bf92c_608a5e64",
      "range": {
        "startLine": 221,
        "startChar": 22,
        "endLine": 221,
        "endChar": 33
      },
