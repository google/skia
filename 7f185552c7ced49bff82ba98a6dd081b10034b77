      },
      "writtenOn": "2017-09-22T21:49:37Z",
      "side": 1,
      "message": "Can we not just call these Sandy Bridge and Ivy Bridge?",
      "range": {
        "startLine": 251,
        "startChar": 5,
        "endLine": 251,
        "endChar": 12
      },
      "revId": "7f185552c7ced49bff82ba98a6dd081b10034b77",
