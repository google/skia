import os
import sys
import urllib2

def gn_path():
  if 'linux' in sys.platform:
    return 'buildtools/linux64/gn'
  if 'darwin' in sys.platform:
    return 'buildtools/mac/gn'
  return 'buildtools/win/gn.exe'

sha1 = open(gn_path() + '.sha1').read()

with open(gn_path(), 'w') as f:
    f.write(urllib2.urlopen('https://chromium-gn.storage.googleapis.com/' + sha1).read())

os.lchmod(gn_path(), 0755)
