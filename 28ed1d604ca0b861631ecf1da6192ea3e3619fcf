        "id": 5255
      },
      "writtenOn": "2017-07-07T15:57:38Z",
      "side": 1,
      "message": "We typically name enum values like this:\n\nkStartDecompress_State\n\n(I don\u0027t think \"JPEG\" adds much value here. \"_State\" matches the name of the enum. But if you make it a class you can drop that bit and it will be referred to as State::kStartDecompress.)",
      "range": {
        "startLine": 64,
        "startChar": 8,
        "endLine": 64,
        "endChar": 29
      },
      "revId": "28ed1d604ca0b861631ecf1da6192ea3e3619fcf",
