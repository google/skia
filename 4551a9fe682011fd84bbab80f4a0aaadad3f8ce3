      "author": {
        "id": 8341
      },
      "writtenOn": "2019-03-05T20:51:09Z",
      "side": 1,
      "message": "Kind of ugly and maybe non-standard formatting, but it was the best way I came up with for formatting this complex if-then-else-ifx2-else series.",
      "range": {
        "startLine": 235,
        "startChar": 8,
        "endLine": 246,
        "endChar": 41
      },
      "revId": "4551a9fe682011fd84bbab80f4a0aaadad3f8ce3",
