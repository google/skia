    {
      "key": {
        "uuid": "81efb0d5_8b843576",
        "filename": "include/core/SkColor.h",
        "patchSetId": 5
      },
      "lineNbr": 45,
      "author": {
        "id": 7769
      },
      "writtenOn": "2017-09-28T08:03:32Z",
      "side": 1,
      "message": "Interestingly (?) Skia builds add -Wno-conversion to its command line which turns off these warnings for regular functions. (Confusingly -Wconversion isn\u0027t on by default, -Wconstant-conversion IS on by default, -Wno-conversion ensures they are both off). This isn\u0027t true when skia is build as part of Chrome.\n\nHowever, the compiler will still warn about truncation that happens in template parameters regardless of -Wno-conversion, so you\u0027re right :). Here we can use uint8_t and make the static_asserts redundant.",
      "parentUuid": "8005fd02_d3c89eda",
      "range": {
        "startLine": 45,
        "startChar": 10,
        "endLine": 45,
        "endChar": 15
      },
