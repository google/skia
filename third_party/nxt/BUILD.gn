  public_configs = [ ":nxt_public_config" ]

  sources = rebase_path([
                          "src/wire/TerribleCommandBuffer.cpp",
                          "src/wire/TerribleCommandBuffer.h",
                          "src/wire/WireCmd.cpp",
                          "src/wire/WireCmd.h",
                          "src/wire/Wire.h",
                        ],
                        ".",
                        "$nxt_root")
}
