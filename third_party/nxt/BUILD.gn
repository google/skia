# Helper template to call the NXT code generator
# This lives in nxt/generator/CMakelists.txt

import("features.gni")

nxt_root = "../externals/nxt"

default_template_dir =
    rebase_path("$nxt_root/generator/templates", root_build_dir)

template("generator") {
  output_dir = ""
  if (defined(invoker.no_root_gen_dir) && invoker.no_root_gen_dir) {
    output_dir = invoker.output_dir
  } else {
    output_dir = root_gen_dir + "/" + invoker.output_dir
  }

  generator = "$nxt_root/generator/main.py"
  json = "$nxt_root/dawn.json"
  target = invoker.target

  template_dir = default_template_dir
  if (defined(invoker.template_dir)) {
    template_dir = invoker.template_dir
  }

  common_args = [
    rebase_path(json, root_build_dir),
    "-t",
    template_dir,
    "-o",
    rebase_path(output_dir, root_build_dir),
    "-T",
    target,
  ]

  script_inputs = exec_script(generator,
                              common_args + [
                                    "--print-dependencies",
                                    "--gn",
                                  ],
                              "list lines",
                              [ json ])
  script_outputs = exec_script(generator,
                               common_args + [
                                     "--print-outputs",
                                     "--gn",
                                   ],
                               "list lines",
                               [ json ])

  rebased_outputs = []
  foreach(path, script_outputs) {
    rebased_outputs +=
        [ root_build_dir + "/" + rebase_path(path, root_build_dir) ]
  }

  action(target_name + "_gen") {
    script = generator
    inputs = script_inputs
    outputs = rebased_outputs
    args = common_args
  }

  if (defined(invoker.target_type)) {
    target(invoker.target_type, target_name) {
      deps = [
        ":" + target_name + "_gen",
      ]
      if (defined(invoker.deps)) {
        deps += invoker.deps
      }
      sources = script_outputs
      if (defined(invoker.sources)) {
        sources += invoker.sources
      }
      forward_variables_from(invoker,
                             "*",
                             [
                               "deps",
                               "target",
                               "output_dir",
                               "configs",
                               "sources",
                             ])
      configs -= [ "//gn:warnings" ]
    }
  }
}

# Configs for external / internal stuff

config("nxt_public_config") {
  include_dirs = [
    root_gen_dir + "/nxt",
    "$nxt_root/src/include",
    "$nxt_root/src",
  ]
  if (is_debug) {
    defines = [ "DAWN_ENABLE_ASSERTS" ]
  }
  if (!is_win) {
    cflags_cc = [ "-std=c++14" ]
  }
}

# Autogenerated targets for the NXT C and C++ header files and implementations
# These targets live in nxt/CMakeLists.txt

generator("nxt") {
  target = "dawn_headers"
  output_dir = "nxt"
  target_type = "source_set"
  public_configs = [ ":nxt_public_config" ]
}

generator("nxtcpp") {
  target = "libdawn"
  output_dir = "nxt"
  target_type = "static_library"
  deps = [
    ":nxt",
  ]
  public_configs = [ ":nxt_public_config" ]
}

generator("backend_utils") {
  target = "dawn_native_utils"
  output_dir = "nxt"
  target_type = "static_library"
  deps = [
    ":nxtcpp",
  ]
  public_configs = [ ":nxt_public_config" ]
}

# Targets for the common code of NXT
# These live in nxt/src/common/CMakelists.txt

static_library("nxt_common") {
  sources = rebase_path([
                          "src/common/Assert.cpp",
                          "src/common/Assert.h",
                          "src/common/BitSetIterator.h",
                          "src/common/Compiler.h",
                          "src/common/Math.cpp",
                          "src/common/Math.h",
                          "src/common/Platform.h",
                          "src/common/Serial.h",
                          "src/common/SerialQueue.h",
                          "src/common/SwapChainUtils.h",
                        ],
                        ".",
                        "$nxt_root")

  public_configs = [ ":nxt_public_config" ]
}

#add_library(nxt_common STATIC ${COMMON_SOURCES})
#target_include_directories(nxt_common PUBLIC ${SRC_DIR})
#NXTInternalTarget("" nxt_common)

