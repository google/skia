config("spirv-headers_config") {
  include_dirs = [ "$nxt_thirdparty_root/spirv-headers/include" ]
}

config("spirv-tools_config") {
  include_dirs = [ "$nxt_thirdparty_root/spirv-tools/include" ]
}

grammar_script =
    "$nxt_thirdparty_root/spirv-tools/utils/generate_grammar_tables.py"

template("spirv_tools_core_tables") {
  version = invoker.version

  action(target_name) {
    script = grammar_script
    grammar = "$nxt_thirdparty_root/spirv-headers/include/spirv/${version}/spirv.core.grammar.json"
    inputs = [
      grammar_script,
      grammar,
    ]
    outputs = [
      "$target_gen_dir/spirv-tools/core.insts-${version}.inc",
      "$target_gen_dir/spirv-tools/operand.kinds-${version}.inc",
    ]
    args = [
      "--spirv-core-grammar=" + rebase_path(grammar, root_build_dir),
      "--core-insts-output=" +
          rebase_path("$target_gen_dir/spirv-tools/core.insts-${version}.inc",
                      root_build_dir),
      "--operand-kinds-output=" + rebase_path(
              "$target_gen_dir/spirv-tools/operand.kinds-${version}.inc",
              root_build_dir),
    ]
  }
}

spirv_tools_core_tables("spirv_tools_core_tables_1_0") {
  version = "1.0"
}

spirv_tools_core_tables("spirv_tools_core_tables_1_1") {
  version = "1.1"
}

action("spirv_tools_glsl_tables_1_0") {
  script = grammar_script
  inputs = [
    grammar_script,
    "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/spirv.core.grammar.json",
    "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/extinst.glsl.std.450.grammar.json",
  ]
  outputs = [
    "$target_gen_dir/spirv-tools/glsl.std.450.insts-1.0.inc",
  ]
  args = [
    "--spirv-core-grammar=" + rebase_path(
            "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/spirv.core.grammar.json",
            root_build_dir),
    "--extinst-glsl-grammar=" + rebase_path(
            "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/extinst.glsl.std.450.grammar.json",
            root_build_dir),
    "--glsl-insts-output=" +
        rebase_path("$target_gen_dir/spirv-tools/glsl.std.450.insts-1.0.inc",
                    root_build_dir),
  ]
}

action("spirv_tools_opencl_tables_1_0") {
  script = grammar_script
  inputs = [
    grammar_script,
    "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/spirv.core.grammar.json",
    "$nxt_thirdparty_root/spirv-tools/source/extinst-1.0.opencl.std.grammar.json",
  ]
  outputs = [
    "$target_gen_dir/spirv-tools/opencl.std.insts-1.0.inc",
  ]
  args = [
    "--spirv-core-grammar=" + rebase_path(
            "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/spirv.core.grammar.json",
            root_build_dir),
    "--extinst-opencl-grammar=" + rebase_path(
            "$nxt_thirdparty_root/spirv-headers/include/spirv/1.0/extinst.glsl.std.450.grammar.json",
            root_build_dir),
    "--opencl-insts-output=" +
        rebase_path("$target_gen_dir/spirv-tools/opencl.std.insts-1.0.inc",
                    root_build_dir),
  ]
}

action("spirv_tools_build_version_inc") {
  script = "$nxt_thirdparty_root/spirv-tools/utils/update_build_version.py"
  inputs = [
    script,
    "$nxt_thirdparty_root/spirv-tools/CHANGES",
  ]
  outputs = [
    "$target_gen_dir/spirv-tools/build-version.inc",
  ]
  args = [
    rebase_path("$nxt_thirdparty_root/spirv-tools/", root_build_dir),
    rebase_path("$target_gen_dir/spirv-tools/build-version.inc",
                root_build_dir),
  ]
}

