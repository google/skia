declare_args() {
  skia_use_system_icu = is_official_build
}

import("../third_party.gni")
import("icu.gni")

if (skia_use_system_icu) {
  system("icu") {
    libs = [ "icuuc" ]
    defines = [ "U_USING_ICU_NAMESPACE=0" ]
  }
} else {
  icu_include_dirs = [
    "../externals/icu/icu4c/source/common",
    "../externals/icu/icu4c/source/i18n",
  ]
  third_party("icu") {
    public_include_dirs = icu_include_dirs + [ "." ]
    public_defines = [ "U_USING_ICU_NAMESPACE=0" ]
    deps = [
      ":icu_data",
      ":icu_common",
      ":icu_i18n",
    ]
  }
  icu_defines = [
    # http://userguide.icu-project.org/howtouseicu
    "U_STATIC_IMPLEMENTATION",
    "U_ENABLE_DYLOAD=0",
    "U_NOEXCEPT=",
  ]
  third_party("icu_common") {
    public_include_dirs = icu_include_dirs
    public_defines = [ "U_USING_ICU_NAMESPACE=0" ]
    configs -= [ "//gn:no_rtti" ]
    defines = icu_defines +  [ "U_COMMON_IMPLEMENTATION" ]
    sources = icu_common_sources
  }
  third_party("icu_i18n") {
    public_include_dirs = icu_include_dirs
    public_defines = [ "U_USING_ICU_NAMESPACE=0" ]
    configs -= [ "//gn:no_rtti" ]
    defines = icu_defines +  [ "U_I18N_IMPLEMENTATION" ]
    sources = icu_i18n_sources
  }
  data_assembly = "$target_gen_dir/icudtl_dat.S"
  action("make_data_assembly") {
    if (is_win) {
      if (target_cpu == "x64" || target_cpu == "arm64") {
        icu_assembly_format = "ms_asm_64"
      } else {
        icu_assembly_format = "ms_asm"
      }
    } else {
      icu_assembly_format = "gcc_asm"
    }
    script = "make_data_assembly.py"
    inputs = [ "icudtl.dat", ]
    outputs = [ "$data_assembly", ]
    if (is_mac || is_ios) {
      _name = "_" + icu_dtname
    } else {
      _name = icu_dtname
    }
    args = [
      _name,
      icu_assembly_format,
      rebase_path(inputs[0], root_build_dir),
      rebase_path(data_assembly, root_build_dir),
    ]
  }
  third_party("icu_data") {
    public_include_dirs = []
    public_defines = []
    deps = [
      ":make_data_assembly",
    ]
    sources = [ "$data_assembly" ]
  }
}
