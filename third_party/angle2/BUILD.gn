declare_args() {
}

config("suppress_deprecated_copy_dtor") {
  if (!is_win || is_clang) {
    cflags = [ "-Wdeprecated-copy-dtor" ]
  }
}

group("angle2") {
  public_configs = [ ":suppress_deprecated_copy_dtor" ]
  public_deps = [
    "//third_party/externals/angle2:libEGL",
    "//third_party/externals/angle2:libGLESv2",
  ]
}
