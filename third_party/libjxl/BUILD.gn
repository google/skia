import("../externals/libjxl/lib/lib.gni")
import("../third_party.gni")

third_party("libjxl") {
  deps = [
    "//modules/skcms",
    "//third_party/brotli",
    "//third_party/highway",
  ]

  public_include_dirs = [
    ".",
    "include",
    "../externals/libjxl/lib/include",
  ]

  include_dirs = [
    "../externals/libjxl",
    "../../modules/skcms",
  ]

  defines = [
    "JPEGXL_ENABLE_SKCMS=1",
    "JPEGXL_ENABLE_TRANSCODE_JPEG=0",
  ]

  if (is_official_build) {
    defines += [ "JXL_DEBUG_ON_ABORT=0" ]
  }

  _lib = "../externals/libjxl/lib"
  sources = []
  foreach(src, libjxl_base_sources) {
    sources += [ "$_lib/$src" ]
  }
  foreach(src, libjxl_cms_sources) {
    sources += [ "$_lib/$src" ]
  }
  foreach(src, libjxl_dec_sources) {
    sources += [ "$_lib/$src" ]
  }
  foreach(src, libjxl_dec_box_sources) {
    sources += [ "$_lib/$src" ]
  }
  foreach(src, libjxl_dec_jpeg_sources) {
    sources += [ "$_lib/$src" ]
  }
  foreach(src, libjxl_enc_sources) {
    sources += [ "$_lib/$src" ]
  }
}
