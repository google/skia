    "../externals/MoltenVK/MoltenVK/MoltenVK/Vulkan/vk_mvk_moltenvk.mm",
  ]
  args = [ rebase_path(target_out_dir, root_build_dir) ]
  if (is_mac) {
    args += [ "macOS" ]
  } else {
    args += [ "iOS" ]
  }
  outputs = [
    "$target_out_dir/MoltenVK.framework",
  ]
}
