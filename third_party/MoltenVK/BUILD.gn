declare_args() {
}

config("MoltenVK_config") {
  framework_path = rebase_path(target_out_dir, root_build_dir)
  cflags = [ "-F$framework_path" ]
  ldflags = [ "-F$framework_path" ]
  libs = [
    "MoltenVK.framework",
    "Metal.framework",
    "IOSurface.framework",
    "QuartzCore.framework",
    "Foundation.framework",
  ]
  if (is_ios) {
    libs += [ "UIKit.framework" ]
  } else {
    libs += [ "IOKit.framework" ]
  }
  defines = [ "SK_MOLTENVK" ]
}

action("MoltenVK") {
  public_configs = [ ":MoltenVK_config" ]
  script = "generate_framework.py"
  inputs = [
    "generate_framework.py",

    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCmdDispatch.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCmdDraw.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCmdPipeline.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCmdQueries.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCmdRenderPass.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCmdTransfer.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCommand.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCommandBuffer.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCommandEncoderState.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCommandEncodingPool.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCommandPool.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKCommandResourceFactory.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/Commands/MVKMTLBufferAllocation.mm",

    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKBuffer.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKDescriptorSet.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKDevice.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKDeviceMemory.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKFramebuffer.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKImage.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKInstance.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKPipeline.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKQueryPool.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKQueue.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKRenderPass.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKResource.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKShaderModule.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKSurface.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKSwapchain.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/GPUObjects/MVKSync.mm",

    "../externals/MoltenVK/MoltenVK/MoltenVK/Layers/MVKLayers.mm",

    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/CAMetalLayer+MoltenVK.m",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/MTLRenderPassDescriptor+MoltenVK.m",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/MTLRenderPipelineDescriptor+MoltenVK.m",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/MTLSamplerDescriptor+MoltenVK.m",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/MTLTextureDescriptor+MoltenVK.m",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/MVKGPUCapture.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/MVKOSExtensions.mm",
    "../externals/MoltenVK/MoltenVK/MoltenVK/OS/NSString+MoltenVK.mm",

    "../externals/MoltenVK/MoltenVK/MoltenVK/Utility/MVKWatermark.mm",

    "../externals/MoltenVK/MoltenVK/MoltenVK/Vulkan/mvk_datatypes.mm",
