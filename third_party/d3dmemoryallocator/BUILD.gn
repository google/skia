config("d3dmemoryallocator_public") {
  include_dirs = [ "." ]
}

source_set("d3dmemoryallocator") {
  public_configs = [ ":d3dmemoryallocator_public" ]

  include_dirs = []

  sources = [
    "src/D3D12MemAlloc.cpp",
    "src/D3D12MemAlloc.h",
  ]

  # Warnings are just noise if we're not maintaining the code.
  if (is_win) {
    cflags = [ "/w" ]
  } else {
    cflags = [ "-w" ]
  }
}
