      "writtenOn": "2020-01-06T17:01:26Z",
      "side": 1,
      "message": "While I agree that it does represent the shape the geometry ends up taking, it\u0027s not a very common geometric description in my experience, nor is it connected to the nomenclature that tessellation shaders use. These are not strong objections, so if no one else is opposed to \"wedge\", I\u0027m fine with keeping it.",
      "parentUuid": "614a09f2_d0880f8e",
      "range": {
        "startLine": 18,
        "startChar": 32,
        "endLine": 18,
        "endChar": 38
      },
      "revId": "c88a515092c6d2efbd3e96bc327425f08e6491c1",
