#Method void translate(int dx, int dy, SkRegion* dst) const
#In incomplete
#Line # incomplete ##

Translate the region by the specified (dx, dy) amount, writing the
resulting region into dst. Note: it is legal to pass this region as the
dst parameter, effectively translating the region in place. If dst is
null, nothing happens.

#Param dx  incomplete ##
#Param dy  incomplete ##
#Param dst  incomplete ##

#Example
// incomplete
##

#SeeAlso incomplete

#Method ##

# ------------------------------------------------------------------------------

#Enum Op

#Code
    enum Op {
        kDifference_Op,
        kIntersect_Op,
        kUnion_Op,
        kXOR_Op,
        kReverseDifference_Op,
        kReplace_Op,
        kLastOp = kReplace_Op,
    };
##

The logical operations that can be performed when combining two regions.

#Const kDifference_Op
subtract the op region from the first region
##
#Const kIntersect_Op
intersect the two regions
##
#Const kUnion_Op
union (inclusive-or) the two regions
##
#Const kXOR_Op
exclusive-or the two regions
##
#Const kReverseDifference_Op
subtract the first region from the op region
##
#Const kReplace_Op
replace the dst region with the op region
##
#Const kLastOp = kReplace_Op
##

#Example
// incomplete
##

#SeeAlso incomplete

#Enum ##

