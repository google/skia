# ------------------------------------------------------------------------------

#Enum Op
#Line # incomplete ##

#Code
    enum Op {
        kDifference_Op,
        kIntersect_Op,
        kUnion_Op,
        kXOR_Op,
        kReverseDifference_Op,
        kReplace_Op,
        kLastOp = kReplace_Op,
    };
##

The logical operations that can be performed when combining two regions.

#Const kDifference_Op 0
#Line # incomplete ##
subtract the op region from the first region
##
#Const kIntersect_Op 1
#Line # incomplete ##
intersect the two regions
##
#Const kUnion_Op 2
#Line # incomplete ##
union (inclusive-or) the two regions
##
#Const kXOR_Op 3
#Line # incomplete ##
exclusive-or the two regions
##
#Const kReverseDifference_Op 4
#Line # incomplete ##
subtract the first region from the op region
##
#Const kReplace_Op 5
#Line # incomplete ##
replace the dst region with the op region
##
#Const kLastOp 5
#Line # incomplete ##
##

#Example
// incomplete
##

#SeeAlso incomplete

#Enum ##

