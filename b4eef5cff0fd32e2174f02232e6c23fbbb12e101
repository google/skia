      "writtenOn": "2021-04-29T13:55:31Z",
      "side": 1,
      "message": "Nit: seems more natural for these to be zero-based",
      "range": {
        "startLine": 29,
        "startChar": 25,
        "endLine": 29,
        "endChar": 27
