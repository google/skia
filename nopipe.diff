+uint32_t GrRenderTargetOpList::addOp(std::unique_ptr<GrOp> op,
+                                     GrRenderTargetContext* renderTargetContext,
+                                     GrAppliedClip* clip, const DstTexture& dstTexture) {
+    const GrOp* opForCombineCheck = op.get();
+    if (clip) {
+        clip = &fAppliedClips.push_back(std::move(*clip));
+    }
+    const GrOp* recordedOp = this->recordOp(std::move(op), renderTargetContext, clip,
+                                            &dstTexture);
+    // Can we not reord it until after?
+    if (clip && recordedOp != opForCombineCheck) {
+        fAppliedClips.pop_back();
+    }
+    return this->uniqueID();
