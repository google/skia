    },
    {
      "unresolved": true,
      "key": {
        "uuid": "5028daa5_220a85f8",
        "filename": "src/sksl/SkSLCFGGenerator.h",
        "patchSetId": 3
      },
      "lineNbr": 63,
      "author": {
        "id": 5640
      },
      "writtenOn": "2021-01-22T15:03:42Z",
      "side": 1,
      "message": "If the new statement is not a Nop, then it will likely incorporate pieces of the previous statement (think replacing an If with just the first branch). This means the previous If is now broken, because its first child has been removed; if I return that broken If statement, almost any interaction with it will result in a segfault. It seemed safest to just avoid that whole minefield.",
      "parentUuid": "f323a9cb_657f4207",
      "range": {
        "startLine": 63,
        "startChar": 8,
        "endLine": 63,
        "endChar": 77
      },
