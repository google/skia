      "writtenOn": "2021-01-22T14:36:28Z",
      "side": 1,
      "message": "Can\u0027t we just *always* return the previous statement?\n\nIf the caller ignores the return value, returning it is the same as freeing it AFAICS. The Nop rule seems unnecessary.",
      "range": {
        "startLine": 63,
        "startChar": 8,
        "endLine": 63,
        "endChar": 77
      },
      "revId": "a93b1f4f7b7f532cf2f8281f82aad6d93dab8253",
