        "id": 5210
      },
      "writtenOn": "2018-04-23T21:26:42Z",
      "side": 1,
      "message": "I think we don\u0027t need a typeface for the GPU. We would have to check all the details, but I don\u0027t think we even need to push it. The typeface was only needed in the pull strategy to deserialize the the text blobs.",
      "range": {
        "startLine": 540,
        "startChar": 10,
        "endLine": 540,
        "endChar": 22
      },
      "revId": "22ce6772d57faa560174ec1eaf08a0ddf8b907a3",
