      "writtenOn": "2020-07-23T22:14:19Z",
      "side": 1,
      "message": "This one being \u003e was intentional, to second guess places where we use the more powerful widen_cast() even when the more constrained bit_cast() would work fine.  Kind of like using static_cast even though reinterpret_cast would always work.  bit_cast is a nice reminder that the signs match exactly, and widen_cast that they definitely don\u0027t.",
      "range": {
        "startLine": 115,
        "startChar": 31,
        "endLine": 115,
        "endChar": 33
      },
      "revId": "528abb882a8226896f15f1d554dfac56d2b5b68d",
