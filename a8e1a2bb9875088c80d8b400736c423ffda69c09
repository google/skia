        "filename": "src/utils/SkShadowUtils.cpp",
        "patchSetId": 3
      },
      "lineNbr": 101,
      "author": {
        "id": 11059
      },
      "writtenOn": "2021-06-15T20:21:24Z",
      "side": 1,
      "message": "For that matter, the vast majority of FP Make() calls take the inputFP as the first argument. Can we just add it to the front of GrSkSLFP::Make()?",
      "parentUuid": "214fa5aa_4ba8b35e",
      "range": {
        "startLine": 99,
        "startChar": 0,
        "endLine": 101,
        "endChar": 5
      },
      "revId": "a8e1a2bb9875088c80d8b400736c423ffda69c09",
