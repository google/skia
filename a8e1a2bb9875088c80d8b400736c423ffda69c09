      "writtenOn": "2021-06-15T20:19:51Z",
      "side": 1,
      "message": "We should allow setting a null input FP. Everywhere else in the code can handle it; it feels weird to need to guard this.",
      "range": {
        "startLine": 99,
        "startChar": 0,
        "endLine": 101,
        "endChar": 5
      },
      "revId": "a8e1a2bb9875088c80d8b400736c423ffda69c09",
