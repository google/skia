      "writtenOn": "2021-06-15T20:34:25Z",
      "side": 1,
      "message": "Can you leave an empty slot at 0 if there\u0027s no input FP?",
      "parentUuid": "67402797_742cdcfa",
      "range": {
        "startLine": 99,
        "startChar": 0,
        "endLine": 101,
        "endChar": 5
      },
      "revId": "a8e1a2bb9875088c80d8b400736c423ffda69c09",
