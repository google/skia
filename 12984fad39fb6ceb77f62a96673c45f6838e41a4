    {
      "key": {
        "uuid": "1252fc19_f0392531",
        "filename": "tests/SkSLGLSLTest.cpp",
        "patchSetId": 16
      },
      "lineNbr": 69,
      "author": {
        "id": 5640
      },
      "writtenOn": "2019-06-05T18:56:26Z",
      "side": 1,
      "message": "Yes; 0.01 was obviously a stupid choice for a constant on my part since it cannot be precisely represented in binary.\n\nI originally used doubles internally since GLSL supported them, and 0.01 made the round trip ok there. In the years since we have never had a need for doubles, so I came to regard my decision to use doubles internally as a mistake. The SKSL_FLOAT macro will at least make it easy to revisit in the future.",
      "parentUuid": "1061b76c_079c20e7",
      "revId": "12984fad39fb6ceb77f62a96673c45f6838e41a4",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
