        "id": 5633
      },
      "writtenOn": "2020-12-16T18:28:46Z",
      "side": 1,
      "message": "Ah ok.\n\nI know we\u0027ve talked about this before, but in GL I would use glBlitFramebuffer to do this. Is there nothing similar in Vulkan?",
      "parentUuid": "95c1e18f_8bb121f0",
      "range": {
        "startLine": 234,
        "startChar": 34,
        "endLine": 234,
        "endChar": 49
      },
      "revId": "e124049e362f7606d34c025137b5ad535c7bc765",
