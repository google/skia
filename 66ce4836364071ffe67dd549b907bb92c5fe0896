        "id": 5140
      },
      "writtenOn": "2020-06-03T21:13:06Z",
      "side": 1,
      "message": "We get these from ICU, but the information isn\u0027t tied to ICU in any way. I suppose these are flags (in that this is set of bit flags). They aren\u0027t types though. These are all properties of  code units in fText, so perhaps this is better named \u0027CodeUnitFlags\u0027.",
      "range": {
        "startLine": 76,
        "startChar": 5,
        "endLine": 76,
        "endChar": 17
      },
      "revId": "66ce4836364071ffe67dd549b907bb92c5fe0896",
