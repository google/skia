      "writtenOn": "2018-11-02T15:45:40Z",
      "side": 1,
      "message": "class PDFDefaultBitmap final : public SkPDFObject {\npublic:\n    void emitObject(SkWStream* stream,\n                    const SkPDFObjNumMap\u0026 objNumMap) const override {\n        SkASSERT(fImage);\n        if (!fSMask) {  // opaque\n            emit_opaque_image_xobject(stream, fImage.get());\n            return\n        }\n        emit_image_xobject(stream, fImage.get(), false, fSMask, objNumMap);\n    }\n    // ....\n};\nstatic void emit_opaque_image_xobject(SkWStream* stream, const SkImage* image) {\n    int w \u003d image-\u003ewidth(); h \u003d image-\u003eheight();\n    SkBitmap bgra;\n    bgra.allocPixels(SkImageInfo::Make(w, 1,\n                                       kBGRA_8888_SkColorType,\n                                       kUnpremul_SkAlphaType));\n    SkASSERT(w \u003d\u003d bgra.computeByteSize());\n    SkAutoTMalloc\u003cuint8_t\u003e scanline(3 * w);\n    for (int y \u003d 0; y \u003c h, ++y) {\n        if (!image-\u003ereadPixels(bgra.pixmap(), 0, y))\n            fill_stream(out, \u0027\\x00\u0027, 3 * w);\n            continue;\n        }\n        const SkColor* src \u003d bgra.getAddr32(0, y);\n        uint8_t* dst \u003d scanline.get();\n        for (int x \u003d 0; x \u003c w; ++x) {\n            SkColor color \u003d *src++;\n            *dst++ \u003d SkColorGetR(color);\n            *dst++ \u003d SkColorGetG(color);\n            *dst++ \u003d SkColorGetB(color);\n        }\n        out-\u003ewrite(scanline.get(), 3 * w);\n    }\n}",
