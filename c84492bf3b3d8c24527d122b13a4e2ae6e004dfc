      "author": {
        "id": 5632
      },
      "writtenOn": "2018-12-07T16:42:14Z",
      "side": 1,
      "message": "If there are paths where all the points are the same, getBounds().isEmpty() would detect the single point better than countPoints() \u003d\u003d 1; plus getBounds() is cached and fairly cheap.",
      "parentUuid": "06f636d7_69e5e5b5",
