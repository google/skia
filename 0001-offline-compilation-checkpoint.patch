+/* SECTION LBRACE <any sequence of tokens with balanced braces> RBRACE */
+std::unique_ptr<ASTDeclaration> Parser::section() {
+    Token start;
+    if (!this->expect(Token::SECTION, "a section token", &start)) {
+        return nullptr;
+    }
+    if (!this->expect(Token::LBRACE, "'{'")) {
+        return nullptr;
+    }
+    SkString text;
+    int level = 1;
+    for (;;) {
+        Token next = this->nextToken();
+        switch (next.fKind) {
+            case Token::LBRACE:
+                ++level;
+                break;
+            case Token::RBRACE:
+                --level;
+                break;
+            case Token::END_OF_FILE:
+                this->error(start.fPosition, "reached end of file while parsing section");
+                break;
+            default:
+                break;
+        } 
+        if (!level) {
+            break;
+        }
+        text += " " + next.fText;
+    }
+    return std::unique_ptr<ASTDeclaration>(new ASTSection(start.fPosition, 
+                                                          SkString(start.fText.c_str() + 1),
+                                                          text));
+}
