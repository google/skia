+static bool ends_with(const char* s, const char* suffix) {
+    int slen = strlen(s);
+    int suffixlen = strlen(suffix);
+    return slen >= suffixlen && !strcmp(s + slen - suffixlen, suffix);
+}
+
+// Given the path to a fragment processor file (e.g. src/gpu/effects/GrFooFragmentProcessor.fp), 
+// returns the "name" of the fragment processor (in this case, 'Foo').
+static SkString base_name(const char* fpPath) {
+    #define PREFIX "Gr"
+    #define SUFFIX "FragmentProcessor"
+    SkString result;
+    const char* fileName = fpPath + strlen(fpPath);
+    while (fileName != fpPath && '/' != *(fileName - 1) && '\\' != *(fileName - 1)) {
+        --fileName;
+    }
+    size_t dot = strlen(fileName);
+    while (dot && '.' != *(fileName + dot)) {
+        --dot;
+    }
+    if (!strncmp(fileName, PREFIX, strlen(PREFIX)) && dot > strlen(SUFFIX) &&
+        !strncmp(fileName + dot - strlen(SUFFIX), SUFFIX, strlen(SUFFIX))) {
+        result.append(fileName + strlen(PREFIX), dot - strlen(PREFIX) - strlen(SUFFIX));
+    } else {
+        result = "Error";
+    }
+    return result;
+}
