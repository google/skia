new file mode 100644
index 0000000000..3031b321fd
--- /dev/null
+++ b/src/sksl/SkSLHCodeGenerator.cpp
@@ -0,0 +1,156 @@
+/*
+ * Copyright 2016 Google Inc.
+ *
+ * Use of this source code is governed by a BSD-style license that can be
+ * found in the LICENSE file.
+ */
+
+#include "SkSLHCodeGenerator.h"
+
+#include "SkSLUtil.h"
+#include "ir/SkSLFunctionDeclaration.h"
+#include "ir/SkSLFunctionDefinition.h"
+#include "ir/SkSLSection.h"
+#include "ir/SkSLVarDeclarations.h"
+
+namespace SkSL {
+
+const char* HCodeGenerator::CType(const Type& type) {
+    if (type.fName == "ivec4") {
+        return "const SkIRect&";
+    } else if (type.fName == "sampler2D") {
+        return "sk_sp<GrTextureProxy>";
+    }
+    return type.name().c_str();
+}
+
+bool HCodeGenerator::IsSupportedSection(const char* name) {
+    return !strcmp(name, HEADER_SECTION) ||
+           !strcmp(name, CONSTRUCTOR_PARAMS_SECTION) ||
+           !strcmp(name, INITIALIZERS_SECTION) ||
+           !strcmp(name, CONSTRUCTOR_SECTION) ||
+           !strcmp(name, BODY_SECTION);
+}
+
+void HCodeGenerator::writef(const char* s, va_list va) {
+    SkString formatted;
+    formatted.appendVAList(s, va);
+    fOut->writeText(formatted.c_str());
+}
+
+void HCodeGenerator::writef(const char* s, ...) {
+    va_list va;
+    va_start(va, s);
+    this->writef(s, va);
+    va_end(va);
+}
+
+void HCodeGenerator::writeSection(const char* name, const char* prefix) {
+    const auto found = fSections.find(SkString(name));
+    if (found != fSections.end()) {
+        this->writef("%s%s", prefix, found->second.c_str());
+    }
+}
+
+bool HCodeGenerator::generateCode() {
+    std::vector<const Variable*> parameters;
+    for (const auto& p : fProgram.fElements) {
+        switch (p->fKind) {
+            case ProgramElement::kVar_Kind: {
+                const VarDeclarations* decls = (const VarDeclarations*) p.get();
+                for (const auto& decl : decls->fVars) {
+                    if ((decl->fVar->fModifiers.fFlags | Modifiers::kIn_Flag) &&
+                        -1 == decl->fVar->fModifiers.fLayout.fBuiltin) {
+                        parameters.push_back(decl->fVar);
+                    }
+                }
+                break;
+            }
+            case ProgramElement::kSection_Kind: {
+                SkDebugf("processing %s\n", p->description().c_str());
+                const Section* s = (const Section*) p.get();
+                if (!IsSupportedSection(s->fName.c_str())) {
+                    fErrors.error(s->fPosition, 
+                                  ("unsupported section '@" + s->fName + "'").c_str());
+                }
+                if (fSections.find(s->fName) != fSections.end()) {
+                    fErrors.error(s->fPosition, 
+                                  ("duplicate section '@" + s->fName + "'").c_str());
+                }
+                fSections[s->fName] = s->fText;
+                break;
+            }
+            default:
+                break;
+        }
+    }
+    const char* baseName = fName.c_str();
+    SkString fullNameString = SkStringPrintf("Gr%sFragmentProcessor", baseName);
+    const char* fullName = fullNameString.c_str();
+    this->writef("/*\n"
+                 " * This file was autogenerated from %s.fp.\n"
+                 " */\n"
+                 "#ifndef %s_DEFINED\n"
+                 "#define %s_DEFINED\n"
+                 "#include \"GrFragmentProcessor.h\"\n"
+                 "class %s : public GrFragmentProcessor {\n"
+                 "public:\n"
+                 "    static sk_sp<GrFragmentProcessor> Make(",
+                 fullName, fullName, fullName, fullName);
+    const char* separator = "";
+    for (const auto& param : parameters) {
+        this->writef("%s%s %s", separator, CType(param->fType), param->fName.c_str());
+        separator = ", ";
+    }
+    this->writef(") {\n"
+                 "        return sk_sp<GrFragmentProcessor>(new %s(",
+                 fullName);
+    separator = "";
+    for (const auto& param : parameters) {
+        this->writef("%s%s", separator, param->fName.c_str());
+        separator = ", ";
+    }
+    this->writef("));\n"
+                 "    }\n"
+                 "    const char* name() const override { return \"%s\"; }\n"
+                 "private:\n"
+                 "    %s(",
+                 baseName, fullName);
+    separator = "";
+    for (const auto& param : parameters) {
+        this->writef("%s%s %s", separator, CType(param->fType), param->fName.c_str());
+        separator = ", ";
+    }
+    this->writeSection(CONSTRUCTOR_PARAMS_SECTION, ", ");
+    this->writef(")\n"
+                 "    : INHERITED(kNone_OptimizationFlags)\n");
+    for (const auto& param : parameters) {
+        const char* name = param->fName.c_str();
+        this->writef("    , f%c%s(%s)", toupper(name[0]), name + 1, name);
+        separator = "    ,";
+    }
+    this->writeSection(INITIALIZERS_SECTION, "    , ");
+    this->writef(" {\n");
+    if (fProgram.fInputs.fDistanceVector) {
+        this->writef("        this->setWillUseDistanceVectorField();\n");
+    }
+    this->writeSection(CONSTRUCTOR_SECTION);
+    this->writef("        this->initClassID<%s>();\n"
+                 "    }\n"
+                 "    GrGLSLFragmentProcessor* onCreateGLSLInstance() const override;\n"
+                 "    void onGetGLSLProcessorKey(const GrShaderCaps&,"
+                                                "GrProcessorKeyBuilder*) const override;\n"
+                 "    bool onIsEqual(const GrFragmentProcessor&) const override;\n"
+                 "    GR_DECLARE_FRAGMENT_PROCESSOR_TEST;\n",
+                 fullName);
+    for (const auto& param : parameters) {
+        const char* name = param->fName.c_str();
+        this->writef("    %s f%c%s;\n", CType(param->fType), toupper(name[0]), name + 1);
+    }
+    this->writef("    typedef GrFragmentProcessor INHERITED;\n"
+                 "};\n"
+                 "#endif\n");
+    return true;
+}
+
+} // namespace
