    {
      "key": {
        "uuid": "95cd22ec_8bde1b4e",
        "filename": "src/codec/SkPngCodec.cpp",
        "patchSetId": 6
      },
      "lineNbr": 628,
      "author": {
        "id": 5255
      },
      "writtenOn": "2017-04-24T18:01:05Z",
      "side": 1,
      "message": "The original motivation for this change was to allow picking up the stream from where we left off after an interlaced PNG, but it also makes it work for subset/sampled decoding, which was broken in N with https://bugs.chromium.org/p/skia/issues/detail?id\u003d4041. I think it would be messy to deliberately break those while still supporting interlaced.",
      "range": {
        "startLine": 628,
        "startChar": 55,
