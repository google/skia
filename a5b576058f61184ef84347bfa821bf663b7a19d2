    {
      "key": {
        "uuid": "27a4f40b_2ed5a96b",
        "filename": "src/core/SkRecord.h",
        "patchSetId": 4
      },
      "lineNbr": 61,
      "author": {
        "id": 5210
      },
      "writtenOn": "2017-04-18T15:40:44Z",
      "side": 1,
      "message": "SkVarAlloc returns the number of bytes of all the large blocks, so bytes used + overhead + waste. I don\u0027t track any of that because it seems like a waste of time. Are you saying that I can approximate this by using count * alignof(T)? I could see something like count * sizeof(T) + alignof(T).",
      "parentUuid": "c98d7b4d_8a54b8a2",
      "range": {
        "startLine": 61,
        "startChar": 41,
        "endLine": 61,
        "endChar": 49
      },
      "revId": "a5b576058f61184ef84347bfa821bf663b7a19d2",
