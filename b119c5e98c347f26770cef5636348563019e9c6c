      "message": "Ooops, that was the C++17 version.  Here\u0027s the C++11..\n\n#define NAMED_BOOL(name)                                                           \\\n    class name {                                                                   \\\n    public:                                                                        \\\n        name() \u003d default;  /* Uninitialized. */                                    \\\n                                                                                   \\\n        struct Yes {                                                               \\\n            template \u003ctypename T\u003e                                                  \\\n            constexpr bool operator\u003d\u003d(T other) const { return (bool)other; };      \\\n        };                                                                         \\\n        struct No {                                                                \\\n            template \u003ctypename T\u003e                                                  \\\n            constexpr bool operator\u003d\u003d(T other) const { return !(bool)other; };     \\\n        };                                                                         \\\n                                                                                   \\\n        static constexpr Yes kYes{};                                               \\\n        static constexpr No  kNo{};                                                \\\n                                                                                   \\\n        constexpr name(Yes) : fVal(true ) {}                                       \\\n        constexpr name(No)  : fVal(false) {}                                       \\\n                                                                                   \\\n        template \u003ctypename T\u003e                                                      \\\n        constexpr explicit name(T val) : fVal((bool)val) {}                        \\\n                                                                                   \\\n        constexpr explicit operator bool() const { return fVal; }                  \\\n                                                                                   \\\n        constexpr bool operator\u003d\u003d(name other) const { return fVal \u003d\u003d other.fVal; } \\\n                                                                                   \\\n                                                                                   \\\n    private:                                                                       \\\n        bool fVal;                                                                 \\\n    }",
