import os, subprocess, fnmatch, threading, sys

os.chdir(os.path.join(os.path.dirname(__file__), os.pardir))

bad = False

# test header for self-sufficiency and idempotency.
def compile_header(header, args):
    # sys.stdout.write(header + '\n')
    cmd = ['c++', '--std=c++11'] + args + [ '-o', '/dev/null', '-c', '-x', 'c++', '-']
    proc = subprocess.Popen(cmd, stdin=subprocess.PIPE)
    proc.stdin.write('#include "%s"\n#include "%s"\n' % (header, header))
    proc.stdin.close()
    if proc.wait() != 0:
        global bad
        bad = True
        sys.stdout.write('FAIL: %s\n' % header)


