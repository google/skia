import os
import sys

fmt = '''
target_cpu                       = "{arch}"
is_debug                         = false
ndk                              = "{ndk}"
ndk_api                   = {api_version}
skia_enable_fontmgr_empty        = true
skia_enable_pdf                  = false
skia_skqp_global_error_tolerance = 4
skia_use_dng_sdk                 = false
skia_use_expat                   = false
skia_use_icu                     = false
skia_use_libheif                 = false
skia_use_lua                     = false
skia_use_piex                    = false
skia_use_skcms                   = false
skia_skqp_enable_driver_correctness_workarounds = {use_workarounds}
'''

def make_args_gn(out_dir, ndk, arch, api_version, use_workarounds):
    if not os.path.exists(out_dir):
        os.makedirs(out_dir)
    with open(os.path.join(out_dir, 'args.gn'), 'w') as o:
        o.write(fmt.format(ndk=os.path.abspath(ndk),
                           arch=arch,
                           api_version=api_version,
                           use_workarounds=use_workarounds))

def usage():
    sys.stderr.write(
            'Usage:\n' +
            '  {} TARGET_BUILD_DIR ANDROID_NDK_DIR ARCHITECTURE API_VERSION WORK_AROUNDS\n\n'.format(sys.argv[0]) +
            'ARCHITECTURE should be "arm" "arm64" "x86" or "x64"\n\n')
    exit(1)

if __name__ == '__main__':
    if len(sys.argv) != 6:
        usage()
    build, android_ndk, arch, api_version, use_workarounds = sys.argv[1:6]
    if len(build) == 0 or len(arch) == 0 or not os.path.isdir(android_ndk):
        usage()
    make_args_gn(build, android_ndk, arch, api_version, use_workarounds)


