    {
      "key": {
        "uuid": "3aa7ce12_08d59f80",
        "filename": "tests/CodecTest.cpp",
        "patchSetId": 3
      },
      "lineNbr": 99,
      "author": {
        "id": 5255
      },
      "writtenOn": "2018-07-31T20:23:30Z",
      "side": 1,
      "message": "There\u0027s only one test where we set expectedResult to kErrorInInput. That test was added as a part of skbug.com/5887. I don\u0027t remember the details off hand, but I introduced kErrorInInput to handle incremental decoding. If the image is truncated, SkGifCodec returns kIncompleteInput. The caller knows that they need to provide more data in order to continue decoding. But if there is a fatal error in the stream (i.e. providing more data will not make it possible to keep decoding), kErrorInInput tells you that. But it\u0027s different from kInvalidInput in that there was potentially a partial image to draw.",
      "range": {
        "startLine": 98,
        "startChar": 0,
        "endLine": 99,
        "endChar": 79
      },
      "revId": "36facc38703bfce7dcf6e54ba081722571ffb5ec",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
