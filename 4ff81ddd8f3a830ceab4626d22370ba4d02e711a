    {
      "key": {
        "uuid": "c4eb3dec_cbfbcc15",
        "filename": "src/gpu/geometry/GrStyledShape.cpp",
        "patchSetId": 15
      },
      "lineNbr": 482,
      "author": {
        "id": 8341
      },
      "writtenOn": "2020-04-27T23:11:47Z",
      "side": 1,
      "message": "This is the dynamic mapping from rect indices to rrect indices that used to be performed at construction time with DefaultRectDirAndStart. It felt better to me for GrShape to store start relative to the shape type. Since GrStyledShape is still set up to normalize to round rects, it can handle the mapping at query time. This also makes it a bit more robust to changes to the shape type during simplification.",
      "range": {
        "startLine": 456,
        "startChar": 12,
        "endLine": 482,
        "endChar": 13
      },
