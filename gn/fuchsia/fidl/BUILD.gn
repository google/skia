assert(is_fuchsia)
import("//gn/fuchsia/fuchsia.gni")
import("//gn/fuchsia/sdk.gni")

#
# Generate gn targets for fidl libraries in the Fuchsia SDK.
#
fuchsia_sdk("fidl") {
  meta = "$fuchsia_sdk_path/meta/manifest.json"
  enabled_parts = [ "fidl_library" ]
}
