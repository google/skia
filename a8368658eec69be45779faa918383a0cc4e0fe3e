      "message": "I\u0027d expect low single digit number of matrix ids since the ids are added by vertex attributes.",
      "parentUuid": "482f40fc_9f07d635",
      "range": {
        "startLine": 67,
        "startChar": 16,
        "endLine": 69,
        "endChar": 42
      },
      "revId": "a8368658eec69be45779faa918383a0cc4e0fe3e",
