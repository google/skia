      "writtenOn": "2021-03-10T19:54:53Z",
      "side": 1,
      "message": "Got it. I assumed the Raster implementation would use SIMD across pixels instead of on SkSL vectors. Is that correct?",
      "parentUuid": "7fb06116_e4ac88bd",
      "range": {
        "startLine": 353,
        "startChar": 26,
