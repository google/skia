    {
      "key": {
        "uuid": "b363185e_90e9ae30",
        "filename": "include/private/GrRecordingContext.h",
        "patchSetId": 7
      },
      "lineNbr": 53,
      "author": {
        "id": 5230
      },
      "writtenOn": "2019-10-21T20:48:36Z",
      "side": 1,
      "message": "It is true that we could store non-GrOpsTask data in here but, for that matter, we could also store non-POD data (since it is a full blown SkArenaAlloc). I was just trying to limit the expected use case as we build this out.\n\nThe real current definition is something like - memoryWithTheSameLifetimeAsASetOfRenderTasks.\n\nRight now it is actually very limited - although it will grow into something we can use for other data I don\u0027t think it would even work for adding data that isn\u0027t ripped off to be stored in a DDL. For the more generic case we would need a missing step in flush that resets the arena at the end of flush (and that will get very complicated when we add partial flushing).",
      "parentUuid": "aa5bee7a_52d3d291",
      "range": {
        "startLine": 53,
        "startChar": 18,
        "endLine": 53,
        "endChar": 32
      },
      "revId": "012f36e7aa0237ea380e080a1dc161016e478042",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
