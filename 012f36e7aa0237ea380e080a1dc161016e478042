      "writtenOn": "2019-10-21T19:38:38Z",
      "side": 1,
      "message": "What do you think of \u0027podAllocator\u0027? This allocator doesn\u0027t necessarily have to be specific to ops, and \u0027opPOD\u0027 is a little hard to read to me :P",
      "range": {
        "startLine": 53,
        "startChar": 18,
        "endLine": 53,
        "endChar": 32
      },
      "revId": "012f36e7aa0237ea380e080a1dc161016e478042",
