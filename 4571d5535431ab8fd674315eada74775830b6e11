    {
      "key": {
        "uuid": "70495e5a_edce7e71",
        "filename": "src/gpu/d3d/GrD3DResourceProvider.cpp",
        "patchSetId": 5
      },
      "lineNbr": 33,
      "author": {
        "id": 5036
