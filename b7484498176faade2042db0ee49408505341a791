    {
      "key": {
        "uuid": "5d55d0c1_25af3b9a",
        "filename": "src/codec/SkJpegCodec.cpp",
        "patchSetId": 20
      },
      "lineNbr": 802,
      "author": {
        "id": 5255
      },
      "writtenOn": "2017-07-19T14:41:50Z",
      "side": 1,
      "message": "Though you\u0027re adjusting the number of lines to decode, there\u0027s a couple of problems here:\n- you don\u0027t skip lines at the beginning (i.e. from line 0 to options().fSubset-\u003etop())\n- you don\u0027t skip lines within the subset (e.g. if sampleY is 2, we need to skip every other line)",
      "range": {
        "startLine": 802,
        "startChar": 8,
        "endLine": 802,
        "endChar": 13
      },
      "revId": "b7484498176faade2042db0ee49408505341a791",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
