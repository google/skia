    {
      "key": {
        "uuid": "f04cb88e_966cd68e",
        "filename": "experimental/multi-skp/SkMultiSkp.cpp",
        "patchSetId": 4
      },
      "lineNbr": 103,
      "author": {
        "id": 9065
      },
      "writtenOn": "2019-05-06T21:35:40Z",
      "side": 1,
      "message": "I thought it was less clear. Te wait has to happen inside the mutex scope. I would need to open one mutex scope and close it outside the while loop, and another inside the while loop. I\u0027d basically have to unroll  tryPop completely, not just move the wait.",
      "parentUuid": "bce5e9d7_71b7f9dc",
      "range": {
        "startLine": 102,
        "startChar": 8,
        "endLine": 103,
        "endChar": 21
      },
      "revId": "04db2a13652652d3ef888e6d6007b134b2071fef",
