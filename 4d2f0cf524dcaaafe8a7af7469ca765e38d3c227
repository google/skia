    {
      "unresolved": true,
      "key": {
        "uuid": "b0ce51bf_303a3ca3",
        "filename": "src/gpu/vk/GrVkPipelineStateBuilder.cpp",
        "patchSetId": 32
      },
      "lineNbr": 218,
      "author": {
        "id": 5065
      },
      "writtenOn": "2021-02-05T20:20:24Z",
      "side": 1,
      "message": "The decision is made in SkSL. The problem is that we have a chicken and egg situation. As we\u0027re finalizing the raw shader code that\u0027s sent to the SkSL compiler, we need to know which layout to specify and whether we\u0027re using push constants. But we don\u0027t know the final size of the uniforms until the compiler is run because it might add kRTHeight. So if flipY is set we decide whether to use push constants or not based on the max possible size, i.e, including RTHeight. Once the code is created and compiled, we get the final size for the uniforms, and that\u0027s what gets set in the layoutCreateInfo.",
      "parentUuid": "3e6532d8_4ab9d372",
      "range": {
        "startLine": 218,
        "startChar": 22,
        "endLine": 218,
        "endChar": 48
      },
      "revId": "4d2f0cf524dcaaafe8a7af7469ca765e38d3c227",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02"
    },
