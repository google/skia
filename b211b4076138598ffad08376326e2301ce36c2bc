    {
      "key": {
        "uuid": "9c6eaae8_9df347f9",
        "filename": "src/gpu/GrTracing.h",
        "patchSetId": 3
      },
      "lineNbr": 38,
      "author": {
        "id": 5010
      },
      "writtenOn": "2016-10-12T16:50:48Z",
      "side": 1,
      "message": "We don\u0027t really type NULL anymore.  if (lib) or if (lib !\u003d nullptr) or if (nullptr !\u003d lib)?\n\nOr even tidier:\n\nif (void* lib \u003d dlopen(...)) {\n  ... code using lib ...\n}",
      "revId": "b211b4076138598ffad08376326e2301ce36c2bc",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": false
