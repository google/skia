      "lineNbr": 13,
      "author": {
        "id": 9065
      },
      "writtenOn": "2019-05-03T16:48:25Z",
      "side": 1,
      "message": "What makes it different?",
      "parentUuid": "7f8c112d_e6fbe4d0",
      "range": {
        "startLine": 13,
        "startChar": 0,
        "endLine": 13,
        "endChar": 16
      },
      "revId": "ad461f1b2ebc939b6afef7b31408b007cae78ffb",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
