      },
      "writtenOn": "2017-12-01T20:16:28Z",
      "side": 1,
      "message": "This is an error that was detected by clang extended warnings on Windows. See:\n\nhttps://skia-review.googlesource.com/c/skia/+/67720\n\nAt least on Windows, jmp_buf requires 16 bytes of alignment, whereas the default allocator only guarantees 8.",
      "parentUuid": "bc827851_7377fa71",
      "range": {
        "startLine": 9,
        "startChar": 0,
        "endLine": 9,
        "endChar": 38
      },
