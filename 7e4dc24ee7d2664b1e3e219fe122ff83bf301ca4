      "writtenOn": "2021-04-14T21:41:08Z",
      "side": 1,
      "message": "The DSLWriter instance\u0027s fConfig is now null. Is there any way for the user to reasonably continue using the DSLWriter past the call to ReleaseProgram, and somehow trip on that null fConfig?",
      "parentUuid": "72684bb5_f4d79349",
      "range": {
        "startLine": 244,
        "startChar": 50,
        "endLine": 244,
        "endChar": 83
