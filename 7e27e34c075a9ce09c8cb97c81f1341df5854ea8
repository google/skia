    {
      "key": {
        "uuid": "83759ba7_7ffb5fc2",
        "filename": "src/codec/SkDumbCodec.cpp",
        "patchSetId": 2
      },
      "lineNbr": 224,
      "author": {
        "id": 5255
      },
      "writtenOn": "2017-11-30T14:30:56Z",
      "side": 1,
      "message": "Even though we check for overflow, size could be a very large number. Android gets cranky when a malicious file can make us likely to run out of memory, so what we do in other places is call a version of malloc that won\u0027t throw and return null if malloc did. Since this is exposed publicly through SkCodec, should we follow the same pattern here?\n\nIf we just want to make Android happy, we can make BitmapFactory check for an SkDumbCodec and discard it, so users of the public API won\u0027t try to decode these, but we can still decode it internally.",
      "range": {
        "startLine": 224,
        "startChar": 25,
        "endLine": 224,
        "endChar": 50
      },
      "revId": "7e27e34c075a9ce09c8cb97c81f1341df5854ea8",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
