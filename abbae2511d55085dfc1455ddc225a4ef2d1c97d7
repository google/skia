      },
      "writtenOn": "2020-08-27T16:01:53Z",
      "side": 1,
      "message": "How common would we have zero-length non-null fontFamilies array? Would the null check alone be sufficient?",
      "revId": "abbae2511d55085dfc1455ddc225a4ef2d1c97d7",
