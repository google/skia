      "author": {
        "id": 12084
      },
      "writtenOn": "2020-08-27T16:01:53Z",
      "side": 1,
      "message": "same for these fields (they may always need values to prevent garbage)",
      "revId": "abbae2511d55085dfc1455ddc225a4ef2d1c97d7",
