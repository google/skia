      },
      "lineNbr": 114,
      "author": {
        "id": 12084
      },
      "writtenOn": "2020-08-27T16:01:53Z",
      "side": 1,
      "message": "Do we know if this field will have a reasonable default (as opposed to picking up garbage from the allocator)? We might have to always populate this field (might even be faster since there won\u0027t be a branch).",
      "revId": "abbae2511d55085dfc1455ddc225a4ef2d1c97d7",
