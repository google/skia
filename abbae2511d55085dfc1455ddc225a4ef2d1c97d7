    {
      "key": {
        "uuid": "a2d82096_27a8a6f9",
        "filename": "modules/canvaskit/paragraph_bindings.cpp",
        "patchSetId": 2
      },
      "lineNbr": 207,
      "author": {
        "id": 5395
      },
      "writtenOn": "2020-08-31T14:57:05Z",
      "side": 1,
      "message": "It is a best practice to always supply a len with arbitrary strings coming over the wire, unless we know the strings won\u0027t be arbitrary (i.e. won\u0027t have null bytes). If we can get away w/o specifying the length, please document why we can do that.",
      "range": {
