defines = -D_GLIBCXX_DEBUG
include_dirs = -I../../../../../../../third_party/externals/googletest/googletest
cflags = -w -fstrict-aliasing -fPIC -g -Wno-unused-parameter -O3 -fdata-sections -ffunction-sections -isystem /usr/local/google/home/ethannicholas/Source/git/skia-clean/third_party/externals/googletest/googletest/include
cflags_cc = -std=c++14 -fno-exceptions -fno-rtti
