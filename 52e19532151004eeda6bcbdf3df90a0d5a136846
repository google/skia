    {
      "key": {
        "uuid": "79200832_e4ce8b84",
        "filename": "src/gpu/gl/GrGLOpsRenderPass.cpp",
        "patchSetId": 3
      },
      "lineNbr": 87,
      "author": {
        "id": 5633
      },
      "writtenOn": "2020-03-31T17:09:03Z",
      "side": 1,
      "message": "There actually is no such thing as baseVertex support without baseInstance. glDrawElementsInstanced has neither baseVertex nor baseInstance, and ARB_base_instance/EXT_base_instance introduce both. So, since we don\u0027t know which draw call the client intends to make, we need to just defer everything.\n\n(The baseVertex in glDrawArrays actually isn\u0027t even an extension. This has been core functionality all along, so it\u0027s not even an extension that\u0027s broken there.)",
      "parentUuid": "8bf92e2b_3517434e",
      "range": {
        "startLine": 85,
        "startChar": 8,
        "endLine": 87,
        "endChar": 5
      },
