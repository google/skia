+void CoverageCountingPathRenderer::preFlush(GrOnFlushResourceProvider* onFlushRP,
+                                            const uint32_t* opListIDs, int numOpListIDs,
+                                            SkTArray<sk_sp<GrRenderTargetContext>>* results) {
+    using CoverInstance = PathCoverProcessor::Instance;
+
+    SkASSERT(!fPathTexelBuffer);
+    SkASSERT(!fCoversInstanceBuffer);
+
+    int numPaths = 0;
+    for (int i = 0; i < numOpListIDs; ++i) {
+        numPaths += fCoverOpLists[opListIDs[i]].fNumPaths;
+    }
+
+    GrResourceProvider* rp = fContext->resourceProvider();
+
+    fPathTexelBuffer.reset(rp->createBuffer(numPaths * 2 * 4 * sizeof(float),
+                                            kTexel_GrBufferType, kDynamic_GrAccessPattern,
+                                            GrResourceProvider::kNoPendingIO_Flag |
+                                            GrResourceProvider::kRequireGpuMemory_Flag));
+    if (!fPathTexelBuffer) {
+        return; // TODO: REMOVE from stupid list
+    }
+
+    fCoversInstanceBuffer.reset(rp->createBuffer(numPaths * sizeof(CoverInstance),
+                                                 kVertex_GrBufferType, kDynamic_GrAccessPattern,
+                                                 GrResourceProvider::kNoPendingIO_Flag |
+                                                 GrResourceProvider::kRequireGpuMemory_Flag));
+    if (!fCoversInstanceBuffer) {
+        return; // TODO: REMOVE from stupid list
+    }
+
+    std::array<float, 4>* texelData =
+        static_cast<std::array<float, 4>*>(fPathTexelBuffer->map());
+    SkASSERT(texelData);
+    int pathTexelsIdx = 0;
+
+    CoverInstance* instanceData = static_cast<CoverInstance*>(fCoversInstanceBuffer->map());
+    SkASSERT(instanceData);
+    int instanceIdx = 0;
+
+    std::unique_ptr<AtlasOp> atlasOp = skstd::make_unique<AtlasOp>();
+
+    for (int i = 0; i < numOpListIDs; ++i) {
+        auto it = fCoverOpLists.find(opListIDs[i]);
+        SkASSERT(fCoverOpLists.end() != it);
+        const CoverOpList& coverOps = it->second;
+
+        CoverOpList::Iter iter;
+        iter.init(coverOps, CoverOpList::Iter::kHead_IterStart);
+        while (CoverOp* op = iter.get()) {
+            for (const CoverOp::Draw& draw : op->fDraws) {
+                const SkMatrix& m = draw.fMatrix;
+
+                SkRect devBounds, devBounds45;
+                get_tight_dev_bounds(m, draw.fPath, &devBounds, &devBounds45);
+                if (devBounds.isEmpty()) {
+                    SkASSERT(!"sadness");
+                    // return true;
+                }
+
+                SkRect clippedDevBounds;
+                bool needsAtlasScissor = !GrClip::IsInsideClip(draw.fClipBounds, devBounds);
+                if (needsAtlasScissor) {
+                    if (!clippedDevBounds.intersect(devBounds, SkRect::Make(draw.fClipBounds))) {
+                        // SkASSERT(!"sadness");
+                        // return true;
+                        clippedDevBounds = devBounds;
+                    }
+                } else {
+                    clippedDevBounds = devBounds;
+                }
+
+                const SkIRect& clippedDevIBounds = GrClip::GetPixelIBounds(clippedDevBounds);
+
+                SkIPoint16 atlasLocation;
+                if (!fCurrentAtlas->addPath(draw.fPath, pathTexelsIdx, clippedDevIBounds.width(),
+                                            clippedDevIBounds.height(), needsAtlasScissor,
+                                            0/* approximationTolerance */, &atlasLocation)) {
+                    SkASSERT(!"sadness");
+                    return;
+                }
+                if (!needsAtlasScissor) {
+                    atlasOp->addPath(draw.fPath, pathTexelsIdx);
+                } else {
+                    SkIRect scissor = SkIRect::MakeXYWH(atlasLocation.x(), atlasLocation.y(),
+                                                        clippedDevIBounds.width(),
+                                                        clippedDevIBounds.height());
+                    atlasOp->addPath(draw.fPath, pathTexelsIdx, &scissor);
+                }
+                texelData[pathTexelsIdx] = {{m.getScaleX(), m.getSkewY(), m.getSkewX(), m.getScaleY()}};
+                texelData[pathTexelsIdx + 1] = {{m.getTranslateX(), m.getTranslateY(),
+                                                 float(atlasLocation.x() - clippedDevIBounds.left()),
+                                                 float(atlasLocation.y() - clippedDevIBounds.top())}};
+                instanceData[instanceIdx + i] = {
+                    pathTexelsIdx,
+                    op->fDraws[i].fColor,
+                    {{devBounds.left(), devBounds.top(), devBounds.right(), devBounds.bottom()}},
+                    {{devBounds45.left(), devBounds45.top(), devBounds45.right(), devBounds45.bottom()}}
+                };
+                pathTexelsIdx += 2;
+            }
+
+            SkASSERT(-1 == op->fInstancesIdxInGpuBuffer);
+            op->fInstancesIdxInGpuBuffer = instanceIdx;
+            instanceIdx += op->fDraws.count();
+
+            iter.next();
+        }
+
+        SkASSERT(pathTexelsIdx == 2 * numPaths);
+        SkASSERT(instanceIdx == numPaths);
+    }
+
+    fCoversInstanceBuffer->unmap();
+    fPathTexelBuffer->unmap();
+
+    SkISize atlasSize = SkISize::Make(fCurrentAtlas->width(), fCurrentAtlas->height());
+    if (!atlasOp->myPrepare(rp, this, atlasSize)) {
+        SkASSERT(!"sadness");
+        return;
+    }
+
+    GrSurfaceDesc desc;
+    desc.fFlags = kRenderTarget_GrSurfaceFlag;
+    desc.fOrigin = PathMaskProcessor::kAtlasOrigin;
+    desc.fWidth = atlasSize.width();
+    desc.fHeight = atlasSize.height();
+    desc.fConfig = kAlpha_half_GrPixelConfig;
+    sk_sp<GrRenderTargetContext> rtc = onFlushRP->makeRenderTargetContext(desc, nullptr, nullptr);
+
+    GrFixedClip scissor;
+    scissor.setScissor(SkIRect::MakeWH(atlasSize.width(), atlasSize.height()));
+    rtc->addDrawOp(scissor, std::move(atlasOp));
+
+    for (int i = 0; i < numOpListIDs; ++i) {
+        auto it = fCoverOpLists.find(opListIDs[i]);
+        SkASSERT(fCoverOpLists.end() != it);
+        const CoverOpList& coverOps = it->second;
+
+        CoverOpList::Iter iter;
+        iter.init(coverOps, CoverOpList::Iter::kHead_IterStart);
+        while (CoverOp* op = iter.get()) {
+            op->setAtlas(sk_ref_sp(rtc->asTextureProxy()));
+            iter.next();
+        }
+
+        fCoverOpLists.erase(it);
+    }
+
+
+    results->push_back(std::move(rtc));
+
+    fCurrentAtlas.reset();
+}
+
+bool CoverageCountingPathRenderer::renderPathMasks(GrRenderTarget* atlasTexture,
+                                                   const SkISize& drawBounds,
+                                                   GrBuffer* pointsBuffer,
+                                                   GrBuffer* trianglesBuffer,
+                                                   const TriangleCounts& unclippedCounts,
+                                                   const ScissoredTriangleCounts scissoredCounts[],
+                                                   int numScissoredDraws,
+                                                   const TriangleCounts& totalCounts) {
+    // SkASSERT(this->isFlushing());
+    SkASSERT(fPathTexelBuffer);
+    SkDEBUGCODE(PathMaskProcessor::Verify(atlasTexture));
+
+    GrScissorState scissor(SkIRect::MakeSize(drawBounds));
+    GrPipeline pipeline(atlasTexture, SkBlendMode::kPlus, &scissor);
+    this->gpu()->handleDirtyContext();
+// #ifndef SK_DEBUG
+//     for (int i = 0; i < 10; ++i)
+// #endif
+    if (!this->onRenderPathMasks(pipeline, drawBounds, fPathTexelBuffer.get(), pointsBuffer,
+                                 trianglesBuffer, unclippedCounts, scissoredCounts,
+                                 numScissoredDraws, totalCounts)) {
+        return false;
+    }
+
+    return true;
+}
+
+void CoverOp::onExecute(GrOpFlushState* state) {
+    SkASSERT(fCCPR->gpu() == state->gpu());
+
+    GrPipeline pipeline;
+    GrPipeline::InitArgs args;
+    args.fAppliedClip = state->drawOpArgs().fAppliedClip;
+    args.fCaps = &state->caps();
+    args.fProcessors = &fProcessors;
+    args.fFlags = 0;
+    args.fRenderTarget = state->drawOpArgs().fRenderTarget;
+    args.fDstProxy = state->drawOpArgs().fDstProxy;
+    pipeline.init(args);
+
+    SkASSERT(fAtlas);
+    fCCPR->drawPathCovers(std::move(fAtlas), pipeline, *this);
+}
+
+void CoverageCountingPathRenderer::drawPathCovers(sk_sp<GrTextureProxy> atlasTexture,
+                                                  const GrPipeline& pipeline, const CoverOp& op) {
+    // SkASSERT(this->isFlushing());
+    if (!fCoversInstanceBuffer) {
+        return; // Either setup failed or resetGpuResources was called.
+    }
+
+    SkASSERT(fPathTexelBuffer);
+
+    this->gpu()->handleDirtyContext();
+    if (GrXferBarrierType barrierType = pipeline.xferBarrierType(*this->gpu()->caps())) {
+        this->gpu()->xferBarrier(pipeline.getRenderTarget(), barrierType);
+    }
+
+    PathCoverProcessor coverProc(fContext->resourceProvider(), atlasTexture, fPathTexelBuffer.get(),
+                                 op.fillType(), *this->gpu()->caps()->shaderCaps());
+// #ifndef SK_DEBUG
+//     for (int i = 0; i < 10; ++i)
+// #endif
+    this->onDrawPathCovers(pipeline, coverProc, fCoversInstanceBuffer.get(), op);
+}
+
+void CoverageCountingPathRenderer::postFlush() {
+    fCurrentAtlas = sk_make_sp<PathMaskAtlas>(*fContext->caps());
+
+    fCoversInstanceBuffer.reset();
+    fPathTexelBuffer.reset();
+
+    // The caller is expected to delete all tracked ops (i.e. ops whose applyPipelineOptimizations
+    // method has been called) before ending the flush.
+    // SkASSERT(fCoverOpList.isEmpty());
+}
+
