+
+#include "GrGeometryProcessor.h"
+#include <array>
+
+class GrShaderCaps;
+
+namespace ccpr {
+
+class PathCoverProcessor : public GrGeometryProcessor {
+
+public:
+    PathCoverProcessor(GrResourceProvider*, sk_sp<GrTextureProxy> atlas, GrBuffer* pathRecBuffer,
+                       SkPath::FillType, const GrShaderCaps&);
+
+    enum class Attrib {
+        kPathTexelsIdx,
+        kColor,
+        kDevBounds,
+        kDevBounds45
+    };
+    static constexpr int kNumAttribs = 1 + (int)Attrib::kDevBounds45;
+
+    struct Instance {
+        int32_t                fPathTexelsIdx;
+        uint32_t               fColor;
+        std::array<float, 4>   fDevBounds;
+        std::array<float, 4>   fDevBounds45;
+    };
+
+    GR_STATIC_ASSERT(sizeof(Instance) == 4 * 10);
+
+    const char* name() const override { return "Cover Processor"; }
+
+    const Attribute& getAttrib(Attrib attrib) const {
+        return this->INHERITED::getAttrib(int(attrib));
+    }
+
+    const GrTexture* atlas() const { return fAtlasAccess.peekTexture(); }
+
+    SkPath::FillType fillType() const { return fFillType; }
+
+    void getGLSLProcessorKey(const GrShaderCaps&, GrProcessorKeyBuilder*) const override;
+    GrGLSLPrimitiveProcessor* createGLSLInstance(const GrShaderCaps&) const override;
+
+private:
+    BufferAccess       fPathBufferAccess;
+    TextureSampler     fAtlasAccess;
+    SkPath::FillType   fFillType;
+
+    typedef GrGeometryProcessor INHERITED;
+};
