+            // stroke.setAntiAlias(true);
+            canvas->drawPath(path, stroke);
+
+            rtc->addDrawOp(GrNoClip(), skstd::make_unique<PerfectTriangleBatch>(fMode));
+        } else {
+            canvas->drawPath(path, paint);
+        }
+    }
+
+    SkView::Click* onFindClickHandler(SkScalar x, SkScalar y, unsigned modi) override {
+        for (int i = 0; i < 8; i += 2) {
+            if (fabs(x / 8.0f - kTri[i]) < 0.5 && fabsf(y / 8.0f - kTri[i + 1]) < 0.5) {
+                return new MyClick(this, &kTri[i]);
+            }
+        }
+        return new MyClick(this, nullptr);
+    }
+
+    bool onClick(Click* click) override {
+        MyClick* myClick = (MyClick*) click;
+        myClick->doClick();
+        this->inval(NULL);
+        return true;
+    }
+
+private:
+    Mode fMode;
+
+    typedef SampleView INHERITED;
+};
+
+void PerfectTriangleBatch::onExecute(GrOpFlushState* state) {
+    using Triangle = ccpr::PathMaskProcessor::Triangle;
+    using Curve = ccpr::PathMaskProcessor::Curve;
+    GrGLGpu* gpu = static_cast<GrGLGpu*>(state->gpu());
+
+    GrResourceProvider* rp = state->gpu()->getContext()->resourceProvider();
+    sk_sp<GrBuffer> trans(rp->createBuffer(3*4*sizeof(float), kTexel_GrBufferType,
+                                           kDynamic_GrAccessPattern,
+                                           GrResourceProvider::kNoPendingIO_Flag |
+                                           GrResourceProvider::kRequireGpuMemory_Flag));
+    if (!trans) {
+        return;
+    }
+    float* transdata = (float*)trans->map();
+    if (!transdata) {
+        return;
+    }
+    transdata[0] = 8;  transdata[2] =  0;  transdata[4] = 0;
+    transdata[1] =  0;  transdata[3] = 8;  transdata[5] = 0;
+    memcpy(&transdata[8], kClip, sizeof(kClip));
+    // transdata[8] =  0;  transdata[9] =  0;  transdata[10] = 10000;   transdata[11] = 10000;
+    trans->unmap();
+
+    sk_sp<GrBuffer> tex(rp->createBuffer(sizeof(kTri), kTexel_GrBufferType,
+                                         kDynamic_GrAccessPattern,
+                                         GrResourceProvider::kNoPendingIO_Flag |
+                                         GrResourceProvider::kRequireGpuMemory_Flag, kTri));
+
+    sk_sp<GrBuffer> klm(rp->createBuffer(4*sizeof(float), kTexel_GrBufferType,
+                                         kDynamic_GrAccessPattern,
+                                         GrResourceProvider::kNoPendingIO_Flag |
+                                         GrResourceProvider::kRequireGpuMemory_Flag));
+
+    ccpr::PathMaskProcessor proc(fMode, trans.get(), tex.get());
+    SkDEBUGCODE(proc.enableDebugVisualizations();)
+
+    GrProcessorSet procs((GrPaint()));
+    procs.finalize(GrColor(), GrProcessorAnalysisCoverage::kSingleChannel,
+                   state->drawOpArgs().fAppliedClip, false, *state->gpu()->caps(), 0);
+
+    GrPipeline pipeline;
+    GrPipeline::InitArgs args;
+    args.fAppliedClip = state->drawOpArgs().fAppliedClip;
+    args.fCaps = &state->caps();
+    args.fProcessors = &procs;
+    args.fFlags = 0;
+    args.fRenderTarget = state->drawOpArgs().fRenderTarget;
+    args.fDstProxy = state->drawOpArgs().fDstProxy;
+    pipeline.init(args);
+
+    if (!gpu->flushGLState(pipeline, proc, false)) {
+        return;
+    }
+
+    sk_sp<GrBuffer> buff(rp->createBuffer(16, kVertex_GrBufferType,
+                                          kDynamic_GrAccessPattern,
+                                          GrResourceProvider::kNoPendingIO_Flag |
+                                          GrResourceProvider::kRequireGpuMemory_Flag));
+    if (!buff) {
+        return;
+    }
+    if (fMode < Mode::kQuadraticHulls) {
+        Triangle* data = (Triangle*)buff->map();
+        data->fPathTexelsIdx = 0;
+        data->fControlPtIdx = 2;
+        data->fStartPtIdx = 0;
+        data->fEndPtIdx = 1;
+    } else {
+        Curve* data = (Curve*)buff->map();
+        data->fPathTexelsIdx = 0;
+        data->fKLMTexelsIdx = 0;
+        data->fControlPtsIdx = 0;
+        data->fEndPtsIdx = 2;
+    }
+
+    buff->unmap();
+    gpu->bindBuffer(kVertex_GrBufferType, buff.get());
+
+    GrGLuint vao;
+    GL_CALL(GenVertexArrays(1, &vao));
+    if (!vao) {
+        return;
+    }
+    gpu->bindVertexArray(vao);
+
+    GL_CALL(EnableVertexAttribArray(0));
+    GL_CALL(VertexAttribDivisor(0, 1));
+
+    GL_CALL(PolygonMode(GR_GL_FRONT_AND_BACK, GR_GL_LINE));
+    GL_CALL(Enable(GR_GL_LINE_SMOOTH));
+    if (fMode < Mode::kSerpInset) {
+        GL_CALL(VertexAttribIPointer(0, 3, GR_GL_INT, 0, nullptr));
+        GL_CALL(DrawArraysInstanced(GR_GL_TRIANGLES, 0, 3, 1));
+    } else {
+        GL_CALL(VertexAttribIPointer(0, 4, GR_GL_INT, 0, nullptr));
+        GL_CALL(DrawArraysInstanced(GR_GL_LINES_ADJACENCY, 0, 4, 1));
+    }
+    GL_CALL(Disable(GR_GL_LINE_SMOOTH));
+    GL_CALL(PolygonMode(GR_GL_FRONT_AND_BACK, GR_GL_FILL));
+
+    GL_CALL(DeleteVertexArrays(1, &vao));
+    gpu->notifyVertexArrayDelete(vao);
+}
+
