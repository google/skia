+#include "glsl/GrGLSLVarying.h"
+
+// We achieve conservative raster by defining pixel-size boxes around vertices, and then drawing
+// convex hulls around those boxes. We slightly undershoot a radius of 0.5 so vertices that fall on
+// integer boundaries (common) don't accidentally bleed into neighbor pixels.
+constexpr float kBloatBoxRadius = 0.491111f;
+
+// We achieve conservative under-raster by insetting the polygon edges.
+//constexpr float kInsetRadius = 1 - kBloatBoxRadius;
+
+
+namespace ccpr {
+
+PathMaskProcessor::PathMaskProcessor(Mode mode, GrBuffer* pathRecBuffer, GrBuffer* pointsBuffer)
+    : fMode(mode) {
+    this->initClassID<PathMaskProcessor>();
+
+    fPathBufferAccess.reset(kRGBA_float_GrPixelConfig, pathRecBuffer, kVertex_GrShaderFlag);
+    this->addBufferAccess(&fPathBufferAccess);
+
+    fPointsBufferAccess.reset(kRG_float_GrPixelConfig, pointsBuffer, kVertex_GrShaderFlag);
+    this->addBufferAccess(&fPointsBufferAccess);
+
+    fInstanceAttrib = &this->addInstanceAttrib("instance", kVec4i_GrVertexAttribType,
+                                               kHigh_GrSLPrecision);
+    this->setWillUseGeoShader();
+
+    SkDEBUGCODE(fDebugVisualizations = false;)
+}
+
+void PathMaskProcessor::getGLSLProcessorKey(const GrShaderCaps&, GrProcessorKeyBuilder* b) const {
+    b->add32(int(fMode));
+}
+
+#ifdef SK_DEBUG
+void PathMaskProcessor::Verify(GrRenderTarget* atlasTexture) {
+    SkASSERT(kAtlasOrigin == atlasTexture->origin());
+}
+#endif
+
+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+class GLSLGeometryGenerator : public GrGLSLGeometryProcessor {
+public:
+    enum class CoverageType {
+        kOne,
+        kInterpolated,
+        kShader
+    };
+
+protected:
+    GLSLGeometryGenerator(CoverageType coverageType)
+        : fCoverageType(coverageType)
+        , fGeoWind("wind", kFloat_GrSLType, GrShaderVar::kNonArray, kLow_GrSLPrecision)
+        , fWind(kFloat_GrSLType)
+        , fCoverageTimesWind(kFloat_GrSLType) {}
+
+    virtual void resetVaryings(GrGLSLVaryingHandler*) {}
+    virtual void fetchVertex(const PathMaskProcessor&, GrGLSLVertexBuilder*, const char*
+                             rtAdjustName, const TexelBufferHandle& pointsBuffer,
+                             const char* ptName) const = 0;
+    virtual void emitWind(GrGLSLGeometryBuilder*, const char* windName) const;
+    int emitHullGeometry(GrGLSLGeometryBuilder*, int numPts, const char* emitVertexFn,
+                         const char* hullPts, const char* insetPts = nullptr) const;
+    int emitEdgeGeometry(GrGLSLGeometryBuilder*, const char* emitVertexFn) const;
+    virtual void emitGeometrySetupCode(GrGLSLGeometryBuilder*, const char* wind,
+                                       const char* rtAdjustName) const {}
+    virtual void onEmitGeometryShader(GrGLSLGeometryBuilder*, const char* emitVertexFn,
+                                      const char* wind, const char* rtAdjustName) const = 0;
+    virtual void emitPerVertexGeometryCode(SkString* fnBody, const char* position,
+                                           const char* coverage, const char* wind) const {}
+    virtual void onEmitCoverage(GrGLSLFragmentBuilder*, const char* outputCoverage) const {
+        SkFAIL("Shader coverage not implemented.");
+    }
+
+protected:
+    void onEmitCode(EmitArgs& args, GrGPArgs* gpArgs) final;
+
+    void emitVertexShader(const PathMaskProcessor&, GrGLSLVertexBuilder*, const char* rtAdjustName,
+                          const TexelBufferHandle& pathTexelSampler,
+                          const TexelBufferHandle& pointsBuffer, GrGPArgs* gpArgs) const;
+    void emitGeometryShader(const PathMaskProcessor&, GrGLSLGeometryBuilder*,
+                            const char* rtAdjustName) const;
+    void emitCoverage(const PathMaskProcessor&, GrGLSLFragmentBuilder*,
+                      const char* outputColor, const char* outputCoverage) const;
+
+    void setData(const GrGLSLProgramDataManager& pdman, const GrPrimitiveProcessor&,
+                 FPCoordTransformIter&& transformIter) override {
+        this->setTransformDataHelper(SkMatrix::I(), pdman, &transformIter);
+    }
+
+    const CoverageType   fCoverageType;
+    GrShaderVar          fGeoWind;
+    GrGLSLGeoToFrag      fWind;
+    GrGLSLGeoToFrag      fCoverageTimesWind;
+};
+
+void GLSLGeometryGenerator::onEmitCode(EmitArgs& args, GrGPArgs* gpArgs) {
+    const PathMaskProcessor& mp = args.fGP.cast<PathMaskProcessor>();
+
+    GrGLSLVaryingHandler* varyingHandler = args.fVaryingHandler;
+    switch (fCoverageType) {
+        case CoverageType::kOne:
+        case CoverageType::kShader:
+            varyingHandler->addFlatVarying("wind", &fWind, kLow_GrSLPrecision);
+            break;
+        case CoverageType::kInterpolated:
+            varyingHandler->addVarying("coverage_times_wind", &fCoverageTimesWind,
+                                       kMedium_GrSLPrecision);
+            break;
+    }
+    this->resetVaryings(varyingHandler);
+
+    varyingHandler->emitAttributes(mp);
+
+    this->emitVertexShader(mp, args.fVertBuilder, args.fRTAdjustName, args.fTexelBuffers[0],
+                           args.fTexelBuffers[1], gpArgs);
+    this->emitGeometryShader(mp, args.fGeomBuilder, args.fRTAdjustName);
+    this->emitCoverage(mp, args.fFragBuilder, args.fOutputColor, args.fOutputCoverage);
+
+    SkASSERT(!args.fFPCoordTransformHandler->nextCoordTransform());
+}
+
+void GLSLGeometryGenerator::emitVertexShader(const PathMaskProcessor& mp,
+                                             GrGLSLVertexBuilder* v,
+                                             const char* rtAdjustName,
+                                             const TexelBufferHandle& pathTexelSampler,
+                                             const TexelBufferHandle& pointsBuffer,
+                                             GrGPArgs* gpArgs) const {
+    v->codeAppendf("int texels_idx = %s[0];", mp.instanceAttrib());
+
+    // Fetch the view matrix.
+    v->codeAppend ("highp mat2 M = mat2(");
+    v->appendTexelFetch(pathTexelSampler, "texels_idx");
+    v->codeAppend (");");
+    v->codeAppend ("highp vec4 packeddata = ");
+    v->appendTexelFetch(pathTexelSampler, "(texels_idx + 1)");
+    v->codeAppend (";");
+    v->codeAppend ("highp vec2 T = packeddata.xy + packeddata.zw;");
+
+    // Fetch the vertex.
+    this->fetchVertex(mp, v, rtAdjustName, pointsBuffer, "self");
+
+    gpArgs->fPositionVar.set(kVec2f_GrSLType, "self");
+}
+
+void GLSLGeometryGenerator::emitGeometryShader(const PathMaskProcessor& mp,
+                                               GrGLSLGeometryBuilder* g,
+                                               const char* rtAdjustName) const {
+    g->declareGlobal(fGeoWind);
+    this->emitWind(g, fGeoWind.c_str());
+
+    SkString emitVertexFn;
+    SkSTArray<2, GrShaderVar> emitArgs;
+    const char* position = emitArgs.emplace_back("position", kVec2f_GrSLType,
+                                                 GrShaderVar::kNonArray,
+                                                 kHigh_GrSLPrecision).c_str();
+    const char* coverage = emitArgs.emplace_back("coverage", kFloat_GrSLType,
+                                                 GrShaderVar::kNonArray,
+                                                 kHigh_GrSLPrecision).c_str();
+    g->emitFunction(kVoid_GrSLType, "emitVertex", emitArgs.count(), emitArgs.begin(), [&]() {
+        SkString fnBody;
+        this->emitPerVertexGeometryCode(&fnBody, position, coverage, fGeoWind.c_str());
+        if (fWind.gsOut()) {
+            fnBody.appendf("%s = %s;", fWind.gsOut(), fGeoWind.c_str());
+        }
+        if (fCoverageTimesWind.gsOut()) {
+            fnBody.appendf("%s = %s * %s;", fCoverageTimesWind.gsOut(), coverage, fGeoWind.c_str());
+        }
+        fnBody.append ("gl_Position = vec4(position, 0, 1);");
+        fnBody.append ("EmitVertex();");
+        return fnBody;
+    }().c_str(), &emitVertexFn);
+
+    g->codeAppendf("highp vec2 bloat = %f * abs(%s.xz);", kBloatBoxRadius, rtAdjustName);
+
+    // Otherwise we would need abs(rtAdjustName.xz).
+    GR_STATIC_ASSERT(kTopLeft_GrSurfaceOrigin == PathMaskProcessor::kAtlasOrigin);
+
+#ifdef SK_DEBUG
+    if (mp.debugVisualizations()) {
+        g->codeAppend ("bloat *= 50;");
+    }
+#endif
+
+    this->emitGeometrySetupCode(g, fGeoWind.c_str(), rtAdjustName);
+    return this->onEmitGeometryShader(g, emitVertexFn.c_str(), fGeoWind.c_str(), rtAdjustName);
+}
+
+void GLSLGeometryGenerator::emitWind(GrGLSLGeometryBuilder* g, const char* windName) const {
+    g->codeAppend("highp mat3x2 P = mat3x2(sk_in[0].gl_Position.xy, "
+                                          "sk_in[1].gl_Position.xy, "
+                                          "sk_in[2].gl_Position.xy);");
+    g->codeAppendf("%s = sign(determinant(mat2(P[1] - P[0], P[2] - P[0])));", windName);
+}
+
+int GLSLGeometryGenerator::emitHullGeometry(GrGLSLGeometryBuilder* g, int numPts,
+                                            const char* emitVertexFn, const char* hullPts,
+                                            const char* insetPts) const {
+    SkASSERT(numPts >= 3);
+
+    if (!insetPts) {
+        g->codeAppendf("highp vec2 centroidpt = %s * vec%i(1.0 / %i.0);", hullPts, numPts, numPts);
+    }
+
+    g->codeAppendf("int previdx = (sk_InvocationID + %i) %% %i;"
+                   "int nextidx = (sk_InvocationID + 1) %% %i;", numPts - 1, numPts, numPts);
+
+    g->codeAppendf("highp vec2 self = %s[sk_InvocationID];"
+                   "highp int leftidx = %s > 0.0 ? previdx : nextidx;"
+                   "highp int rightidx = %s > 0.0 ? nextidx : previdx;",
+                   hullPts, fGeoWind.c_str(), fGeoWind.c_str());
+
+    // Which quadrant does the vector from self -> right fall into?
+    g->codeAppendf("highp vec2 right = %s[rightidx];", hullPts);
+    if (3 == numPts) {
+        // TODO: evaluate perf gains.
+        g->codeAppend ("highp vec2 qsr = sign(right - self);");
+    } else {
+        SkASSERT(4 == numPts);
+        g->codeAppendf("highp vec2 diag = %s[(sk_InvocationID + 2) %% 4];", hullPts);
+        g->codeAppend ("highp vec2 qsr = sign((right != self ? right : diag) - self);");
+    }
+
+    // Which quadrant does the vector from left -> self fall into?
+    g->codeAppendf("highp vec2 qls = sign(self - %s[leftidx]);", hullPts);
+
+    // d2 just helps us reduce triangle counts with orthogonal, axis-aligned lines.
+    // TODO: evaluate perf gains.
+    const char* dr2 = "dr";
+    if (3 == numPts) {
+        // TODO: evaluate perf gains.
+        g->codeAppend ("highp vec2 dr = vec2(qsr.y != 0.0 ? +qsr.y : +qsr.x, "
+                                            "qsr.x != 0.0 ? -qsr.x : +qsr.y);");
+        g->codeAppend ("highp vec2 dr2 = vec2(qsr.y != 0.0 ? +qsr.y : -qsr.x, "
+                                             "qsr.x != 0.0 ? -qsr.x : -qsr.y);");
+        g->codeAppend ("highp vec2 dl = vec2(qls.y != 0.0 ? +qls.y : +qls.x, "
+                                            "qls.x != 0.0 ? -qls.x : +qls.y);");
+        dr2 = "dr2";
+    } else {
+        g->codeAppend ("highp vec2 dr = vec2(qsr.y != 0 ? +qsr.y : 1, "
+                                            "qsr.x != 0 ? -qsr.x : 1);");
+        g->codeAppend ("highp vec2 dl = (qls == vec2(0)) ? dr : vec2(qls.y != 0.0 ? +qls.y : 1, "
+                                                                    "qls.x != 0.0 ? -qls.x : 1);");
+    }
+    g->codeAppendf("bvec2 dnotequal = notEqual(%s, dl);", dr2);
+
+    // Emit one third of what is the convex hull of pixel-size boxes centered on the vertices.
+    // Each invocation emits a different third.
+    if (insetPts) {
+        g->codeAppendf("%s(%s[rightidx], 1.0);", emitVertexFn, insetPts);
+    }
+    g->codeAppendf("%s(right + bloat * dr, 1.0);", emitVertexFn);
+    if (insetPts) {
+        g->codeAppendf("%s(%s[sk_InvocationID], 1.0);", emitVertexFn, insetPts);
+    } else {
+        g->codeAppendf("%s(centroidpt, 1.0);", emitVertexFn);
+    }
+    g->codeAppendf("%s(self + bloat * %s, 1.0);", emitVertexFn, dr2);
+    g->codeAppend ("if (any(dnotequal)) {");
+    g->codeAppendf(    "%s(self + bloat * dl, 1.0);", emitVertexFn);
+    g->codeAppend ("}");
+    g->codeAppend ("if (all(dnotequal)) {");
+    g->codeAppendf(    "%s(self + bloat * vec2(-dl.y, dl.x), 1.0);", emitVertexFn);
+    g->codeAppend ("}");
+    g->codeAppend ("EndPrimitive();");
+
+    return insetPts ? 6 : 5;
+}
+
+int GLSLGeometryGenerator::emitEdgeGeometry(GrGLSLGeometryBuilder* g,
+                                            const char* emitVertexFn) const {
+    // Which quadrant does the vector from left -> right fall into?
+    g->codeAppend ("highp vec2 qlr = sign(right - left);");
+
+    g->codeAppend ("highp vec2 d1 = vec2(qlr.y, -qlr.x);");
+    g->codeAppend ("highp vec2 d2 = d1;");
+
+    g->codeAppend ("highp mat2 endpts = mat2(left - bloat * qlr, right + bloat * qlr);");
+    g->codeAppendf("highp vec2 n = vec2(right.y - left.y, left.x - right.x);");
+    g->codeAppend ("highp vec2 d = n * mat2(left + bloat * d1, left - bloat * d1);");
+    // Clamp for when n=0. wind=0 when n=0 so as long as we don't get Inf or NaN we are fine.
+    g->codeAppendf("mediump vec2 endpts_cvg = (d[1] - n * endpts) / max(d[0] - d[1], 1e-30);");
+
+    g->codeAppend ("bool aligned = qlr.x == 0.0 || qlr.y == 0.0;");
+    g->codeAppend ("if (aligned) {");
+    g->codeAppend (    "d1 -= qlr;");
+    g->codeAppend (    "d2 += qlr;");
+    g->codeAppend ("}");
+
+    // Emit the convex hull of 2 pixel-size boxes centered on the endpoints of the edge. Each
+    // invocation emits a different edge. Emit negative coverage that subtracts the appropiate
+    // amount back out from the hull we drew above.
+    g->codeAppend ("if (!aligned) {");
+    g->codeAppendf(    "%s(endpts[0], endpts_cvg[0]);", emitVertexFn);
+    g->codeAppend ("}");
+    g->codeAppendf("%s(left + bloat * d1, -1.0);", emitVertexFn);
+    g->codeAppendf("%s(left - bloat * d2, 0.0);", emitVertexFn);
+    g->codeAppendf("%s(right + bloat * d2, -1.0);", emitVertexFn);
+    g->codeAppendf("%s(right - bloat * d1, 0.0);", emitVertexFn);
+    g->codeAppend ("if (!aligned) {");
+    g->codeAppendf(    "%s(endpts[1], endpts_cvg[1]);", emitVertexFn);
+    g->codeAppend ("}");
+    g->codeAppend ("EndPrimitive();");
+
+    return 6;
+}
+
+void GLSLGeometryGenerator::emitCoverage(const PathMaskProcessor& mp,
+                                         GrGLSLFragmentBuilder* f,
+                                         const char* outputColor,
+                                         const char* outputCoverage) const {
+    switch (fCoverageType) {
+        case CoverageType::kOne:
+            f->codeAppendf("%s.a = %s;", outputColor, fWind.fsIn());
+            break;
+        case CoverageType::kInterpolated:
+            f->codeAppendf("%s.a = %s;", outputColor, fCoverageTimesWind.fsIn());
+            break;
+        case CoverageType::kShader:
+            f->codeAppendf("mediump float coverage = 0.0;");
+            this->onEmitCoverage(f, "coverage");
+            f->codeAppendf("%s.a = coverage * %s;", outputColor, fWind.fsIn());
+            break;
+    }
+
+    f->codeAppendf("%s = vec4(1);", outputCoverage);
+
+#ifdef SK_DEBUG
+    if (mp.debugVisualizations()) {
+        f->codeAppendf("%s = vec4(-%s.a, %s.a, 0, 1);", outputColor, outputColor, outputColor);
+    }
+#endif
+}
+
+////////////////////////////////////////////////////////////////////////////////////////////////////
+
+class TriangleGenerator : public GLSLGeometryGenerator {
+public:
+    enum class GeometryType {
+        kHulls,
+        kEdges,
+        kHullsAndEdges
+    };
+
+    TriangleGenerator(CoverageType initialCoverage, GeometryType geometryType)
+        : INHERITED(initialCoverage)
+        , fGeometryType(geometryType) {}
+
+protected:
+    void fetchVertex(const PathMaskProcessor& mp, GrGLSLVertexBuilder* v, const char* rtAdjustName,
+                     const TexelBufferHandle& pointsBuffer, const char* ptName) const override {
+        v->codeAppendf("ivec3 vertex_indices = %s.wyz;", mp.instanceAttrib());
+        v->codeAppend ("highp vec2 self = T + M * ");
+        v->appendTexelFetch(pointsBuffer, "vertex_indices[sk_VertexID]");
+        v->codeAppend (".xy;");
+    }
+
+    void onEmitGeometryShader(GrGLSLGeometryBuilder* g, const char* emitVertexFn, const char* wind,
+                              const char* rtAdjustName) const override {
+        int maxVertices = 0;
+
+        if (GeometryType::kEdges != fGeometryType) {
+            if (GeometryType::kHullsAndEdges == fGeometryType) {
+                g->codeAppend ("{");
+            }
+
+            maxVertices += this->emitHullGeometry(g, 3, emitVertexFn, "P");
+
+            if (fGeometryType != GeometryType::kHulls) {
+                g->codeAppend ("}");
+            }
+        }
+
+        if (GeometryType::kHulls != fGeometryType) {
+            if (GeometryType::kHullsAndEdges == fGeometryType) {
+                g->codeAppend ("{");
+            }
+
+            g->codeAppend ("int selfidx = sk_InvocationID, "
+                               "nextidx = (selfidx + 1) % 3;");
+            g->codeAppendf("highp vec2 left = sk_in[%s > 0.0 ? selfidx : nextidx].gl_Position.xy;",
+                           wind);
+            g->codeAppendf("highp vec2 right = sk_in[%s > 0.0 ? nextidx : selfidx].gl_Position.xy;",
+                           wind);
+            maxVertices += this->emitEdgeGeometry(g, emitVertexFn);
+
+            if (fGeometryType != GeometryType::kEdges) {
+                g->codeAppend ("}");
+            }
+        }
+
+        g->configure(GrGLSLGeometryBuilder::InputType::kTriangles,
+                     GrGLSLGeometryBuilder::OutputType::kTriangleStrip,
+                     maxVertices, 3);
+    }
+
+    const GeometryType fGeometryType;
+
+    typedef GLSLGeometryGenerator INHERITED;
+};
+
+/**
+ * This class fixes the corner pixels of a triangle. It erases the coverage that was written
+ * previously for its hull and edges, and then approximates the true coverage by sampling the
+ * triangle.
+ */
+class TriangleCornerGenerator : public TriangleGenerator {
+public:
+    TriangleCornerGenerator()
+        : INHERITED(CoverageType::kShader, GeometryType::kHulls) // TODO: abolish!
+        , fEdgeDistance(kVec3f_GrSLType)
+        , fDevCoord(kVec2f_GrSLType)
+        , fNeighbors(kVec4f_GrSLType)
+        , fEdgeDistances(kMat33f_GrSLType)
+        , fCornerIdx(kInt_GrSLType) {}
+
+    void resetVaryings(GrGLSLVaryingHandler* varyingHandler) override {
+        this->INHERITED::resetVaryings(varyingHandler);
+        varyingHandler->addFlatVarying("edge_distance", &fEdgeDistance, kHigh_GrSLPrecision);
+        varyingHandler->addFlatVarying("devcoord", &fDevCoord, kHigh_GrSLPrecision);
+        varyingHandler->addFlatVarying("neighbors", &fNeighbors, kHigh_GrSLPrecision);
+        varyingHandler->addFlatVarying("edge_distances", &fEdgeDistances, kHigh_GrSLPrecision);
+        varyingHandler->addFlatVarying("corner_idx", &fCornerIdx, kLow_GrSLPrecision);
+    }
+
+    void fetchVertex(const PathMaskProcessor& mp, GrGLSLVertexBuilder* v, const char* rtAdjustName,
+                     const TexelBufferHandle& pointsBuffer, const char* ptName) const override {
+        this->INHERITED::fetchVertex(mp, v, rtAdjustName, pointsBuffer, ptName);
+
+        // Fetch and transform the next point in the triangle.
+        v->codeAppend ("highp vec2 next = T + M * ");
+        v->appendTexelFetch(pointsBuffer, "vertex_indices[(sk_VertexID + 1) % 3]");
+        v->codeAppend (".xy;");
+
+        // Find the plane that gives distance from the [self -> next] edge, normalized to its AA
+        // bloat width.
+        v->codeAppend ("highp vec2 n = vec2(next.y - self.y, self.x - next.x);");
+        v->codeAppendf("highp vec2 d = n * mat2(self + %f * sign(n), "
+                                               "self - %f * sign(n));",
+                                               kBloatBoxRadius, kBloatBoxRadius);
+
+        // Clamp for when n=0. wind=0 when n=0 so as long as we don't get Inf or NaN we are fine.
+        v->codeAppendf("%s.xy = n / max(d[0] - d[1], 1e-30);", fEdgeDistance.vsOut());
+        v->codeAppendf("%s.z = -dot(%s.xy, self);", fEdgeDistance.vsOut(), fEdgeDistance.vsOut());
+
+        // Emit device coords to geo shader.
+        v->codeAppendf("%s = self;", fDevCoord.vsOut());
+    }
+
+    void onEmitGeometryShader(GrGLSLGeometryBuilder* g, const char* emitVertexFn, const char* wind,
+                              const char* rtAdjustName) const override {
+        g->codeAppend ("highp vec2 self = sk_in[sk_InvocationID].gl_Position.xy;");
+        g->codeAppendf("%s(self + vec2(-bloat.x, -bloat.y), 1.0);", emitVertexFn);
+        g->codeAppendf("%s(self + vec2(-bloat.x, +bloat.y), 1.0);", emitVertexFn);
+        g->codeAppendf("%s(self + vec2(+bloat.x, -bloat.y), 1.0);", emitVertexFn);
+        g->codeAppendf("%s(self + vec2(+bloat.x, +bloat.y), 1.0);", emitVertexFn);
+        g->codeAppend ("EndPrimitive();");
+
+        g->configure(GrGLSLGeometryBuilder::InputType::kTriangles,
+                     GrGLSLGeometryBuilder::OutputType::kTriangleStrip,
+                     4, 4);
+    }
+
+    void emitPerVertexGeometryCode(SkString* fnBody, const char* position, const char* coverage,
+                                   const char* wind) const override {
+        fnBody->appendf("%s.xy = %s[(sk_InvocationID + 1) %% 3];",
+                        fNeighbors.gsOut(), fDevCoord.gsIn());
+        fnBody->appendf("%s.zw = %s[(sk_InvocationID + 2) %% 3];",
+                        fNeighbors.gsOut(), fDevCoord.gsIn());
+        fnBody->appendf("%s = mat3(%s[(sk_InvocationID + 2) %% 3], "
+                                  "%s[sk_InvocationID], "
+                                  "%s[(sk_InvocationID + 1) %% 3]) * %s;",
+                        fEdgeDistances.gsOut(), fEdgeDistance.gsIn(), fEdgeDistance.gsIn(),
+                        fEdgeDistance.gsIn(), wind);
+
+        // Otherwise, fEdgeDistances = mat3(...) * sign(wind * rtAdjust.x * rdAdjust.z).
+        GR_STATIC_ASSERT(kTopLeft_GrSurfaceOrigin == PathMaskProcessor::kAtlasOrigin);
+
+        fnBody->appendf("%s = sk_InvocationID;", fCornerIdx.gsOut());
+    }
+
+    void onEmitCoverage(GrGLSLFragmentBuilder* f, const char* outputCoverage) const override {
+        // FIXME: Adreno breaks if we don't put the frag coord in an intermediate highp variable.
+        f->codeAppendf("highp vec2 fragcoord = sk_FragCoord.xy;");
+
+#if 0
+        f->codeAppendf("%s = 0;", coverage);
+
+        constexpr int kNumSamples = 16;
+        f->defineConstant("highp vec2[16]", "mysamples", "vec2[16]("
+            "vec2(+1, +1)/16., vec2(-1, -3)/16., vec2(-3, +2)/16., vec2(+4, -1)/16., "
+            "vec2(-5, -2)/16., vec2(+2, +5)/16., vec2(+5, +3)/16., vec2(+3, -5)/16., "
+            "vec2(-2, +6)/16., vec2( 0, -7)/16., vec2(-4, -6)/16., vec2(-6, +4)/16., "
+            "vec2(-8,  0)/16., vec2(+7, -4)/16., vec2(+6, +7)/16., vec2(-7, -8)/16."
+        ")");
+
+        f->codeAppendf("for (int i = 0; i < %i; ++i) {", kNumSamples);
+        f->codeAppendf(    "highp vec3 d = vec3(fragcoord + mysamples[i], 1) * %s;",
+                           fEdgeDistances.fsIn());
+        f->codeAppendf(    "if (all(greaterThan(vec3(0), d))) {");
+        f->codeAppendf(        "%s += (1.0 / %i.0);",
+                               coverage, kNumSamples);
+        f->codeAppendf(    "}");
+        f->codeAppendf("}");
+
+        return;
+#endif
+
+        // Approximate coverage by tracking where 4 horizontal lines enter and leave the triangle.
+        GrShaderVar samples("samples", kVec4f_GrSLType, GrShaderVar::kNonArray,
+                            kHigh_GrSLPrecision);
+        f->declareGlobal(samples);
+        f->codeAppendf("%s = fragcoord.y + vec4(-0.375, -0.125, 0.125, 0.375);", samples.c_str());
+
+        GrShaderVar leftedge("leftedge", kVec4f_GrSLType, GrShaderVar::kNonArray,
+                             kHigh_GrSLPrecision);
+        f->declareGlobal(leftedge);
+        f->codeAppendf("%s = vec4(fragcoord.x - 0.5);", leftedge.c_str());
+
+        GrShaderVar rightedge("rightedge", kVec4f_GrSLType, GrShaderVar::kNonArray,
+                              kHigh_GrSLPrecision);
+        f->declareGlobal(rightedge);
+        f->codeAppendf("%s = vec4(fragcoord.x + 0.5);", rightedge.c_str());
+
+        SkString sampleEdgeFn;
+        GrShaderVar edgeArg("edge_distance", kVec3f_GrSLType, GrShaderVar::kNonArray,
+                            kHigh_GrSLPrecision);
+        f->emitFunction(kVoid_GrSLType, "sampleEdge", 1, &edgeArg, [&]() {
+            SkString b;
+            b.appendf("highp float m = abs(%s.x) < 1e-3 ? 1e18 : -1.0 / %s.x;",
+                      edgeArg.c_str(), edgeArg.c_str());
+            b.appendf("highp vec4 edge = m * (%s.y * samples + %s.z);",
+                      edgeArg.c_str(), edgeArg.c_str());
+            b.appendf("if (%s.x <= 1e-3 || (abs(%s.x) < 1e-3 && %s.y > 0.0)) {",
+                      edgeArg.c_str(), edgeArg.c_str(), edgeArg.c_str());
+            b.appendf(    "%s = max(%s, edge);", leftedge.c_str(), leftedge.c_str());
+            b.append ("} else {");
+            b.appendf(    "%s = min(%s, edge);", rightedge.c_str(), rightedge.c_str());
+            b.append ("}");
+            return b;
+        }().c_str(), &sampleEdgeFn);
+
+
+#if 0
+        f->codeAppendf("%s = 0;", coverage);
+        f->codeAppendf("%s(%s[0]);", sampleEdgeFn.c_str(), fEdgeDistances.fsIn());
+        f->codeAppendf("%s(%s[1]);", sampleEdgeFn.c_str(), fEdgeDistances.fsIn());
+        f->codeAppendf("%s(%s[2]);", sampleEdgeFn.c_str(), fEdgeDistances.fsIn());
+        f->codeAppendf("highp vec4 widths = max(%s - %s, 0.0);",
+                       rightedge.c_str(), leftedge.c_str());
+        f->codeAppendf("%s += dot(widths, vec4(0.25));", coverage);
+
+        return;
+#endif
+
+
+        // See if the previous neighbor already handled this pixel.
+        f->codeAppendf("if (all(lessThan(abs(fragcoord - %s.zw), vec2(%f)))) {",
+                       fNeighbors.fsIn(), kBloatBoxRadius);
+        // Handle the case where all 3 corners defer to the previous neighbor.
+        f->codeAppendf(    "if (%s != 0 || !all(lessThan(abs(fragcoord - %s.xy), vec2(%f)))) {",
+                           fCornerIdx.fsIn(), fNeighbors.fsIn(), kBloatBoxRadius);
+        f->codeAppend (        "discard;");
+        f->codeAppend (    "}");
+        f->codeAppend ("}");
+
+        // Erase what the hull and two egdes wrote at this corner in previous shaders (the two .5's
+        // for the edges and the -1.0 for the hull cancel each other out).
+        f->codeAppendf("%s = dot(vec3(fragcoord, 1) * mat2x3(%s), vec2(1));",
+                       outputCoverage, fEdgeDistances.fsIn());
+
+        // Sample the two egdes at this corner.
+        f->codeAppendf("%s(%s[0]);", sampleEdgeFn.c_str(), fEdgeDistances.fsIn());
+        f->codeAppendf("%s(%s[1]);", sampleEdgeFn.c_str(), fEdgeDistances.fsIn());
+
+        // Handle the opposite edge if the next neighbor will defer to us.
+        f->codeAppendf("if (all(lessThan(abs(fragcoord - %s.xy), vec2(%f)))) {",
+                       fNeighbors.fsIn(), kBloatBoxRadius);
+        // Erase the coverage the opposite edge wrote to this corner.
+        f->codeAppendf(    "%s += dot(%s[2], vec3(fragcoord, 1)) + 0.5;",
+                           outputCoverage, fEdgeDistances.fsIn());
+        // Sample the opposite edge.
+        f->codeAppendf(    "%s(%s[2]);", sampleEdgeFn.c_str(), fEdgeDistances.fsIn());
+        f->codeAppend ("}");
+
+        f->codeAppendf("highp vec4 widths = max(%s - %s, 0.0);",
+                       rightedge.c_str(), leftedge.c_str());
+        f->codeAppendf("%s += dot(widths, vec4(0.25));", outputCoverage);
+    }
+
+private:
+    GrGLSLVertToGeo fEdgeDistance;
+    GrGLSLVertToGeo fDevCoord;
+    GrGLSLGeoToFrag fNeighbors;
+    GrGLSLGeoToFrag fEdgeDistances;
+    GrGLSLGeoToFrag fCornerIdx;
+
+    typedef TriangleGenerator INHERITED;
+};
