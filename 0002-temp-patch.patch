new file mode 100644
index 0000000000..11affc6920
--- /dev/null
+++ b/src/gpu/ccpr/AtlasOp.cpp
@@ -0,0 +1,402 @@
+/*
+ * Copyright 2017 Google Inc.
+ *
+ * Use of this source code is governed by a BSD-style license that can be
+ * found in the LICENSE file.
+ */
+
+#include "AtlasOp.h"
+
+#include "GrBuffer.h"
+#include "GrOpFlushState.h"
+#include "GrPathUtils.h"
+#include "GrResourceProvider.h"
+#include "GrRectanizer_skyline.h"
+#include "PathMaskProcessor.h"
+#include "SkGeometry.h"
+#include "SkMakeUnique.h"
+#include "SkMathPriv.h"
+#include "SkPath.h"
+#include "SkPathOpsCubic.h"
+#include "SkPathPriv.h"
+#include "SkPoint.h"
+#include <cmath>
+#include <numeric>
+
+using TriangleCounts = ccpr::CoverageCountingPathRenderer::TriangleCounts;
+
+static TriangleCounts operator-(const TriangleCounts& a, const TriangleCounts& b) {
+    return {a.fNumAnchors - b.fNumAnchors, a.fNumQuadratics - b.fNumQuadratics,
+            a.fNumSerps - b.fNumSerps, a.fNumLoops - b.fNumLoops};
+}
+
+static int sum(const TriangleCounts& counts) {
+    return counts.fNumAnchors + counts.fNumQuadratics + counts.fNumSerps + counts.fNumLoops;
+}
+
+static int num_pts(uint8_t verb) {
+    switch (verb) {
+        case SkPath::kClose_Verb:
+        case SkPath::kDone_Verb:
+        default:
+            SkFAIL("Path verb does not have an endpoint.");
+            return 0;
+        case SkPath::kMove_Verb:
+        case SkPath::kLine_Verb:
+            return 1;
+        case SkPath::kQuad_Verb:
+            return 2;
+        case SkPath::kConic_Verb:
+            return 2;
+        case SkPath::kCubic_Verb:
+            return 3;
+    }
+}
+
+static SkPoint to_skpoint(double x, double y) {
+    return {static_cast<SkScalar>(x), static_cast<SkScalar>(y)};
+}
+
+static SkPoint to_skpoint(const SkDPoint& dpoint) {
+    return to_skpoint(dpoint.fX, dpoint.fY);
+}
+
+
+namespace ccpr {
+
+class PathGpuBuffersBuilder {
+public:
+    using Triangle = PathMaskProcessor::Triangle;
+    using Curve = PathMaskProcessor::Curve;
+
+#ifdef SK_SCALAR_IS_FLOAT
+    using Point = SkPoint;
+#else
+    struct Point {
+        void operator=(const SkPoint& pt) {
+            fX = SkScalarToFloat(pt.x());
+            fY = SkScalarToFloat(pt.y());
+        }
+        float fX, fY;
+    };
+#endif
+
+    GR_STATIC_ASSERT(8 == sizeof(Point));
+
+    TriangleCounts triangleCounts() const {
+        return {fFanTriangles.count(), fQuadratics.count(), fSerps.count(), fLoops.count()};
+    }
+
+    const Triangle* fanTriangles() const { return fFanTriangles.begin(); }
+    const Curve& quadraticAt(int i) const { return fQuadratics[i]; }
+    const Curve& serpAt(int i) const { return fSerps[i]; }
+    const Curve& loopAt(int i) const { return fLoops[i]; }
+
+    int numTotalPoints() const {
+        return fFanPoints.count() + fControlPoints.count();
+    }
+
+    int numFanPoints() const { return fFanPoints.count(); }
+    const Point* fanPointsData() const { return fFanPoints.begin(); }
+
+    int numControlPoints() const { return fControlPoints.count(); }
+    const Point* controlPointsData() const { return fControlPoints.begin(); }
+
+    void consume(const SkPathRef* pathRef, int pathTexelsIdx, SkScalar approximationTolerance) {
+        SkDEBUGCODE(pathRef->validate();)
+        const int lastVerbIdx = -pathRef->countVerbs();
+        const uint8_t* const verbs = pathRef->verbs();
+        const SkPoint* pts = pathRef->points();
+        SkSTArray<64, std::array<SkPoint, 4>, true> cubicContours;
+
+        fPathTexelsIdx = pathTexelsIdx;
+        fApproximationTolerance = approximationTolerance;
+        fContourStartIdx = fFanPoints.count();
+
+        for (int i = -1; i >= lastVerbIdx; --i) {
+            const int verb = verbs[i];
+            switch (verb) {
+                case SkPath::kMove_Verb:
+                    this->startContour(*pts++);
+                    continue;
+                case SkPath::kClose_Verb:
+                    this->closeContour();
+                    continue;
+                case SkPath::kLine_Verb:
+                    this->fanTo(pts[0]);
+                    break;
+                case SkPath::kQuad_Verb:
+                    this->quadraticTo(pts[0], pts[1]);
+                    break;
+                case SkPath::kCubic_Verb:
+                    this->cubicTo(pts[0], pts[1], pts[2]);
+                    break;
+                case SkPath::kConic_Verb:
+                    SkFAIL("Conics are not supported.");
+                default:
+                    SkFAIL("Unexpected path verb.");
+            }
+
+            pts += num_pts(verb);
+        }
+        this->closeContour();
+    }
+
+private:
+    void startContour(const SkPoint& anchorPoint) {
+        this->closeContour();
+        fFanPoints.push_back(anchorPoint);
+        SkASSERT(fContourStartIdx == fFanPoints.count() - 1);
+    }
+
+    void fanTo(const SkPoint& pt) {
+        SkASSERT(fContourStartIdx < fFanPoints.count());
+        if (pt == fFanPoints[fContourStartIdx]) {
+            this->startContour(pt);
+            return;
+        }
+        fFanPoints.push_back(pt);
+    }
+
+    void quadraticTo(const SkPoint& c, const SkPoint& endpt) {
+        this->fanTo(endpt);
+        fControlPoints.push_back(c);
+        fQuadratics.push_back() = {fPathTexelsIdx, 0, fControlPoints.count() - 1,
+                                   fFanPoints.count() - 2};
+    }
+
+    void cubicTo(const SkPoint& c1, const SkPoint& c2, const SkPoint& endpt) {
+        SkPoint P[4] = {fFanPoints.back(), c1, c2, endpt};
+
+        double t[2], s[2];
+        SkCubicType type = SkClassifyCubic(P, t, s);
+        if (SkCubicType::kLineOrPoint == type) {
+            this->fanTo(endpt);
+            return;
+        } else if (SkCubicType::kQuadratic == type) {
+            SkScalar x1 = P[1].y() - P[0].y(),  y1 = P[0].x() - P[1].x(),
+                     k1 = x1 * P[0].x() + y1 * P[0].y();
+            SkScalar x2 = P[2].y() - P[3].y(),  y2 = P[3].x() - P[2].x(),
+                     k2 = x2 * P[3].x() + y2 * P[3].y();
+            SkScalar rdet = 1 / (x1*y2 - y1*x2);
+            SkPoint isect = {(y2*k1 - y1*k2) * rdet, (x1*k2 - x2*k1) * rdet};
+            this->quadraticTo(isect, endpt);
+            return;
+        }
+
+        auto& cubics = SkCubicType::kLoop != type ? fSerps : fLoops;
+        SkDCubic C;
+        C.set(P);
+
+        for (int x = 0; x < 2; ++x) {
+            if (t[x] * s[x] <= 0) { // This is equivalent to tx/sx <= 0.
+                // This technically also gets taken if tx/sx = infinity, but the code still does
+                // the right thing in that edge case.
+                continue; // Don't increment x0.
+            }
+            if (std::abs(t[x]) >= std::abs(s[x])) { // tx/sx >= 1.
+                break;
+            }
+
+            const double chopT = t[x] / s[x];
+            SkASSERT(chopT >= 0 && chopT <= 1);
+            if (chopT <= 0 || chopT >= 1) { // floating-point error.
+                continue;
+            }
+
+            const SkDCubicPair& chopped = C.chopAt(chopT);
+            const SkDCubic& C0 = chopped.first();
+            C = chopped.second();
+
+            fControlPoints.push_back(to_skpoint(C0[1]));
+            fControlPoints.push_back(to_skpoint(C0[2]));
+            this->fanTo(to_skpoint(C0[3]));
+
+            fControlPoints.push_back(to_skpoint(t[1 - x], s[1 - x] * chopT));
+            fControlPoints.push_back(to_skpoint(1, 1));
+
+            cubics.push_back() = {
+                fPathTexelsIdx,
+                0,
+                fControlPoints.count() - 4,
+                fFanPoints.count() - 2
+            };
+
+            t[x] = 0;
+            s[x] = 1;
+
+            const double r = s[1 - x] * chopT;
+            t[1 - x] -= r;
+            s[1 - x] -= r;
+        }
+
+        fControlPoints.push_back(to_skpoint(C[1]));
+        fControlPoints.push_back(to_skpoint(C[2]));
+        this->fanTo(to_skpoint(C[3]));
+
+        fControlPoints.push_back(to_skpoint(t[0], s[0]));
+        fControlPoints.push_back(to_skpoint(t[1], s[1]));
+
+        cubics.push_back() = {
+            fPathTexelsIdx,
+            0,
+            fControlPoints.count() - 4,
+            fFanPoints.count() - 2
+        };
+    }
+
+    void closeContour() {
+        int fanSize = fFanPoints.count() - fContourStartIdx;
+        if (fanSize >= 3) {
+             // Technically this can grow to fanSize + log3(fanSize), but we approximate with log2.
+            SkAutoSTMalloc<300, int> indices(fanSize + SkNextLog2(fanSize)); 
+            std::iota(indices.get(), indices.get() + fanSize, fContourStartIdx);
+            this->emitHierarchicalFan(indices, fanSize);
+        }
+
+        // Reset the current contour.
+        fContourStartIdx = fFanPoints.count();
+    }
+
+    void emitHierarchicalFan(int indices[], int count) {
+        if (count < 3) {
+            return;
+        }
+
+        const int oneThirdPt = count / 3;
+        const int twoThirdsPt = (2 * count) / 3;
+        fFanTriangles.push_back() = {fPathTexelsIdx, indices[0], indices[oneThirdPt],
+                                     indices[twoThirdsPt]};
+
+        this->emitHierarchicalFan(indices, oneThirdPt + 1);
+        this->emitHierarchicalFan(&indices[oneThirdPt], twoThirdsPt - oneThirdPt + 1);
+
+        int oldIndex = indices[count];
+        indices[count] = indices[0];
+        this->emitHierarchicalFan(&indices[twoThirdsPt], count - twoThirdsPt + 1);
+        indices[count] = oldIndex;
+    }
+
+private:
+    int                                  fPathTexelsIdx;
+    SkScalar                             fApproximationTolerance;
+    int                                  fContourStartIdx;
+
+    SkSTArray<1024, Point, true>         fFanPoints;
+    SkSTArray<512, Point, true>          fControlPoints;
+
+    SkSTArray<1024, Triangle, true>      fFanTriangles;
+    SkSTArray<512, Curve, true>          fQuadratics;
+    SkSTArray<512, Curve, true>          fSerps;
+    SkSTArray<512, Curve, true>          fLoops;
+};
+
+void AtlasOp::addPath(const SkPath& path, int texelsIdx, const SkIRect* scissor) {
+    sk_sp<const SkPathRef> pathRef = sk_ref_sp(SkPathPriv::PathRef(path));
+
+    if (!scissor) {
+        fUnclippedMasks.push_back() = {std::move(pathRef), texelsIdx, 0/* approximationTolerance */};
+    } else {
+        fScissoredMasks.push_back() = {{std::move(pathRef), texelsIdx, 0/* approximationTolerance */},
+                                       *scissor};
+    }
+}
+
+bool AtlasOp::myPrepare(GrResourceProvider* rp, CoverageCountingPathRenderer* ccpr, SkISize bounds) {
+//    using ScissoredTriangleCounts = CoverageCountingPathRenderer::ScissoredTriangleCounts;
+    using Point = PathGpuBuffersBuilder::Point;
+    using Triangle = PathMaskProcessor::Triangle;
+    using Curve = PathMaskProcessor::Curve;
+
+    // Build GPU buffers.
+    PathGpuBuffersBuilder builder;
+    for (GrTAllocator<MaskDraw>::Iter iter(&fUnclippedMasks); iter.next();) {
+        builder.consume(iter->fPathRef.get(), iter->fPathTexelsIdx, iter->fApproximationTolerance);
+    }
+
+    fTotalTriangleCounts = builder.triangleCounts();
+    fUnclippedCounts = fTotalTriangleCounts;
+
+    // Now build the buffers for draws that need a scissor.
+    fScissoredCounts.reserve(fScissoredMasks.count());
+    for (GrTAllocator<ScissoredMaskDraw>::Iter iter(&fScissoredMasks); iter.next();) {
+        const MaskDraw& draw = iter->fDraw;
+        builder.consume(draw.fPathRef.get(), draw.fPathTexelsIdx, draw.fApproximationTolerance);
+        TriangleCounts newCounts = builder.triangleCounts();
+        fScissoredCounts.push_back() = {newCounts - fTotalTriangleCounts, iter->fScissor};
+        fTotalTriangleCounts = newCounts;
+    }
+
+    fPointsBuffer.reset(rp->createBuffer(builder.numTotalPoints() * sizeof(Point),
+                                         kTexel_GrBufferType, kDynamic_GrAccessPattern,
+                                         GrResourceProvider::kNoPendingIO_Flag |
+                                         GrResourceProvider::kRequireGpuMemory_Flag));
+    if (!fPointsBuffer) {
+        return false;
+    }
+    Point* pointsData = static_cast<Point*>(fPointsBuffer->map());
+    SkASSERT(pointsData);
+    memcpy(pointsData, builder.fanPointsData(), builder.numFanPoints() * sizeof(Point));
+    memcpy(pointsData + builder.numFanPoints(), builder.controlPointsData(),
+           builder.numControlPoints() * sizeof(Point));
+    fPointsBuffer->unmap();
+
+    fTrianglesBuffer.reset(rp->createBuffer(sum(fTotalTriangleCounts) * sizeof(Triangle),
+                                            kVertex_GrBufferType, kDynamic_GrAccessPattern,
+                                            GrResourceProvider::kNoPendingIO_Flag |
+                                            GrResourceProvider::kRequireGpuMemory_Flag));
+    if (!fTrianglesBuffer) {
+        return false;
+    }
+    Triangle* trianglesData = static_cast<Triangle*>(fTrianglesBuffer->map());
+    SkASSERT(trianglesData);
+    memcpy(trianglesData, builder.fanTriangles(),
+           fTotalTriangleCounts.fNumAnchors * sizeof(Triangle));
+    trianglesData += fTotalTriangleCounts.fNumAnchors;
+    for (int i = 0; i < fTotalTriangleCounts.fNumQuadratics; ++i) {
+        const Curve& quadratic = builder.quadraticAt(i);
+        trianglesData[i] = {
+            quadratic.fPathTexelsIdx,
+            quadratic.fKLMTexelsIdx,
+            quadratic.fControlPtsIdx + builder.numFanPoints(),
+            quadratic.fEndPtsIdx
+        };
+    }
+    trianglesData += fTotalTriangleCounts.fNumQuadratics;
+    for (int i = 0; i < fTotalTriangleCounts.fNumSerps; ++i) {
+        const Curve& cubic = builder.serpAt(i);
+        trianglesData[i] = {
+            cubic.fPathTexelsIdx,
+            cubic.fKLMTexelsIdx,
+            cubic.fControlPtsIdx + builder.numFanPoints(),
+            cubic.fEndPtsIdx
+        };
+    }
+    trianglesData += fTotalTriangleCounts.fNumSerps;
+    for (int i = 0; i < fTotalTriangleCounts.fNumLoops; ++i) {
+        const Curve& cubic = builder.loopAt(i);
+        trianglesData[i] = {
+            cubic.fPathTexelsIdx,
+            cubic.fKLMTexelsIdx,
+            cubic.fControlPtsIdx + builder.numFanPoints(),
+            cubic.fEndPtsIdx
+        };
+    }
+    fTrianglesBuffer->unmap();
+
+
+    fCCPR = ccpr;
+    fBounds = bounds;
+    this->setBounds(SkRect::MakeIWH(bounds.width(), bounds.height()),
+                    GrOp::HasAABloat::kNo, GrOp::IsZeroArea::kNo);
+    return true;
+}
+
+void AtlasOp::onExecute(GrOpFlushState* flushState) {
+    // Render the atlas.
+    fCCPR->renderPathMasks(flushState->drawOpArgs().fRenderTarget, fBounds, fPointsBuffer.get(),
+                           fTrianglesBuffer.get(), fUnclippedCounts, fScissoredCounts.begin(),
+                           fScissoredCounts.count(), fTotalTriangleCounts);
+}
+
+}
