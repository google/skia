+
+namespace ccpr {
+
+class CoverageCountingPathRenderer;
+
+class AtlasOp : public GrDrawOp {
+public:
+    DEFINE_OP_CLASS_ID
+
+    AtlasOp() : INHERITED(ClassID()) {}
+
+    const char* name() const override { return "Coverage Counting Atlas Op"; }
+
+    void addPath(const SkPath&, int texelsIdx, const SkIRect* scissor = nullptr);
+    bool myPrepare(GrResourceProvider* rp, CoverageCountingPathRenderer*, SkISize bounds);
+
+private:
+    FixedFunctionFlags fixedFunctionFlags() const override { return FixedFunctionFlags::kNone; }
+    bool xpRequiresDstTexture(const GrCaps&, const GrAppliedClip*) override { return false; }
+    bool onCombineIfPossible(GrOp* other, const GrCaps& caps) override { return false; }
+    void onPrepare(GrOpFlushState*) override {}
+    void onExecute(GrOpFlushState*) override;
+
+    struct MaskDraw {
+        sk_sp<const SkPathRef>   fPathRef;
+        int                      fPathTexelsIdx;
+        SkScalar                 fApproximationTolerance;
+    };
+
+    struct ScissoredMaskDraw {
+        MaskDraw   fDraw;
+        SkIRect    fScissor;
+    };
+
+    GrSTAllocator<1024, MaskDraw>            fUnclippedMasks;
+    GrSTAllocator<1024, ScissoredMaskDraw>   fScissoredMasks;
+
+    sk_sp<GrBuffer> fPointsBuffer;
+    sk_sp<GrBuffer> fTrianglesBuffer;
+    CoverageCountingPathRenderer::TriangleCounts fTotalTriangleCounts;
+    CoverageCountingPathRenderer::TriangleCounts fUnclippedCounts;
+    SkSTArray<512, CoverageCountingPathRenderer::ScissoredTriangleCounts, true> fScissoredCounts;
+    CoverageCountingPathRenderer* fCCPR;
+    SkISize fBounds;
+
+    typedef GrDrawOp INHERITED;
+};
+
+}
+
+#endif
