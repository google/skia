+ *
+ * Use of this source code is governed by a BSD-style license that can be
+ * found in the LICENSE file.
+ */
+
+#include "GLCoverageCountingPathRenderer.h"
+
+#include "GrFixedClip.h"
+#include "GrMesh.h"
+#include "gl/GrGLGpu.h"
+
+#define GL_CALL(X) GR_GL_CALL(this->glGpu()->glInterface(), X)
+
+
+namespace ccpr {
+
+inline GrGLGpu* GLCoverageCountingPathRenderer::glGpu() const {
+    return static_cast<GrGLGpu*>(this->gpu());
+}
+
+GLCoverageCountingPathRenderer::GLCoverageCountingPathRenderer(GrContext* context)
+    : INHERITED(context) {
+    const GrGLContextInfo& ctxInfo = this->glGpu()->ctxInfo();
+    const GrGLCaps& caps = this->glGpu()->glCaps();
+    fUseScissorForAtlasClear = !caps.fullClearIsFree() && kNVIDIA_GrGLVendor == ctxInfo.vendor();
+    fCombineEdgeAndHullDraws = kQualcomm_GrGLVendor != ctxInfo.vendor();
+}
+
+bool GLCoverageCountingPathRenderer::onRenderPathMasks(const GrPipeline& pipeline,
+                                                    const SkISize& drawBounds,
+                                                    GrBuffer* pathTexelBuffer,
+                                                    GrBuffer* pointsBuffer,
+                                                    GrBuffer* trianglesBuffer,
+                                                    const TriangleCounts& unclippedCounts,
+                                                    const ScissoredTriangleCounts scissoredCounts[],
+                                                    int numScissoredDraws,
+                                                    const TriangleCounts& totalCounts) {
+
+//    using Triangle = PathMaskProcessor::Triangle;
+    using Mode = PathMaskProcessor::Mode;
+
+    SkASSERT(pipeline.getScissorState().enabled());
+
+    GrFixedClip clearClip(pipeline.getScissorState().rect());
+    this->glGpu()->clear(clearClip, 0, pipeline.getRenderTarget());
+
+    int baseInstance = 0;
+
+    if (totalCounts.fNumAnchors) {
+        if (fCombineEdgeAndHullDraws) {
+            if (!this->drawMaskPrimitives(pipeline, Mode::kCombinedFanHullsAndEdges,
+                                          pathTexelBuffer, pointsBuffer, unclippedCounts,
+                                          scissoredCounts, numScissoredDraws, baseInstance,
+                                          kTriangles_GrPrimitiveType, trianglesBuffer,
+                                          &TriangleCounts::fNumAnchors)) {
+                return false;
+            }
+        } else {
+            if (!this->drawMaskPrimitives(pipeline, Mode::kAnchorHulls, pathTexelBuffer,
+                                          pointsBuffer, unclippedCounts, scissoredCounts,
+                                          numScissoredDraws, baseInstance,
+                                          kTriangles_GrPrimitiveType, trianglesBuffer,
+                                          &TriangleCounts::fNumAnchors) ||
+                !this->drawMaskPrimitives(pipeline, Mode::kAnchorEdges, pathTexelBuffer,
+                                          pointsBuffer, unclippedCounts, scissoredCounts,
+                                          numScissoredDraws, baseInstance,
+                                          kTriangles_GrPrimitiveType, trianglesBuffer,
+                                          &TriangleCounts::fNumAnchors)) {
+                return false;
+            }
+        }
+        if (!this->drawMaskPrimitives(pipeline, Mode::kAnchorCorners, pathTexelBuffer, pointsBuffer,
+                                      unclippedCounts, scissoredCounts, numScissoredDraws,
+                                      baseInstance, kTriangles_GrPrimitiveType, trianglesBuffer,
+                                      &TriangleCounts::fNumAnchors)) {
+            return false;
+        }
+        baseInstance += totalCounts.fNumAnchors;
+    }
+
+    if (totalCounts.fNumQuadratics) {
+        if (!this->drawMaskPrimitives(pipeline, Mode::kQuadraticHulls, pathTexelBuffer,
+                                      pointsBuffer, unclippedCounts, scissoredCounts,
+                                      numScissoredDraws, baseInstance, kTriangles_GrPrimitiveType,
+                                      trianglesBuffer, &TriangleCounts::fNumQuadratics) ||
+            !this->drawMaskPrimitives(pipeline, Mode::kQuadraticInnerEdges, pathTexelBuffer,
+                                      pointsBuffer, unclippedCounts, scissoredCounts,
+                                      numScissoredDraws, baseInstance, kTriangles_GrPrimitiveType,
+                                      trianglesBuffer, &TriangleCounts::fNumQuadratics)) {
+            return false;
+        }
+        baseInstance += totalCounts.fNumQuadratics;
+    }
+
+    if (totalCounts.fNumSerps) {
+        if (/*!this->drawMaskPrimitives(pipeline, Mode::kSerpInset, pathTexelBuffer, pointsBuffer,
+                                      klmBuffer, unclippedCounts, scissoredCounts,
+                                      numScissoredDraws, baseInstance, kLinesAdjacency_GrPrimitiveType, trianglesBuffer,
+                                      &TriangleCounts::fNumSerps) ||*/
+            !this->drawMaskPrimitives(pipeline, Mode::kSerpBorder, pathTexelBuffer, pointsBuffer,
+                                      unclippedCounts, scissoredCounts, numScissoredDraws,
+                                      baseInstance, kLinesAdjacency_GrPrimitiveType, trianglesBuffer,
+                                      &TriangleCounts::fNumSerps)) {
+            return false;
+        }
+        baseInstance += totalCounts.fNumSerps;
+    }
+
+    if (totalCounts.fNumLoops) {
+        if (/*!this->drawMaskPrimitives(pipeline, Mode::kLoopInset, pathTexelBuffer, pointsBuffer,
+                                      klmBuffer, unclippedCounts, scissoredCounts,
+                                      numScissoredDraws, baseInstance, kLinesAdjacency_GrPrimitiveType, trianglesBuffer,
+                                      &TriangleCounts::fNumLoops) ||*/
+            !this->drawMaskPrimitives(pipeline, Mode::kLoopBorder, pathTexelBuffer, pointsBuffer,
+                                      unclippedCounts, scissoredCounts, numScissoredDraws,
+                                      baseInstance, kLinesAdjacency_GrPrimitiveType, trianglesBuffer,
+                                      &TriangleCounts::fNumLoops)) {
+            return false;
+        }
+        baseInstance += totalCounts.fNumLoops;
+    }
+
+    return true;
+}
+
+bool GLCoverageCountingPathRenderer::drawMaskPrimitives(const GrPipeline& pipeline,
+                                                    PathMaskProcessor::Mode mode,
+                                                    GrBuffer* pathTexelBuffer,
+                                                    GrBuffer* pointsBuffer,
+                                                    const TriangleCounts& unclippedCounts,
+                                                    const ScissoredTriangleCounts scissoredCounts[],
+                                                    int numScissoredDraws,
+                                                    int baseInstance,
+                                                    GrPrimitiveType primitiveType,
+                                                    GrBuffer* instanceBuffer,
+                                                    int TriangleCounts::* field) const {
+    const int vertexCount = kLinesAdjacency_GrPrimitiveType == primitiveType ? 4 : 3;
+    GrMesh mesh(primitiveType);
+
+    PathMaskProcessor proc(mode, pathTexelBuffer, pointsBuffer);
+    if (!this->glGpu()->flushGLState(pipeline, proc, false)) {
+        return false;
+    }
+
+    int instanceCount = unclippedCounts.*field;
+    if (instanceCount) {
+        mesh.setInstanced(instanceBuffer, instanceCount, baseInstance, vertexCount);
+        this->glGpu()->draw(pipeline, proc, &mesh, 1, nullptr);
+        baseInstance += instanceCount;
+    }
+
+    for (int i = 0; i < numScissoredDraws; ++i) {
+        instanceCount = scissoredCounts[i].fCounts.*field;
+        if (!instanceCount) {
+            continue;
+        }
+        mesh.setInstanced(instanceBuffer, instanceCount, baseInstance, vertexCount);
+        GrPipeline::DynamicState dynamicState = {scissoredCounts[i].fScissor};
+        this->glGpu()->draw(pipeline, proc, &mesh, 1, &dynamicState);
+        baseInstance += instanceCount;
+    }
+
+    return true;
+}
+
+void GLCoverageCountingPathRenderer::onDrawPathCovers(const GrPipeline& pipeline,
+                                                      const PathCoverProcessor& coverProc,
+                                                      GrBuffer* coversInstanceBuffer,
+                                                      const CoverOp& op) {
+#ifdef SK_DEBUG
+    using Attrib = PathCoverProcessor::Attrib;
+    using Instance = PathCoverProcessor::Instance;
+
+    SkASSERT(sizeof(Instance) == coverProc.getInstanceStride());
+    SkASSERT(offsetof(Instance, fPathTexelsIdx) ==
+             coverProc.getAttrib(Attrib::kPathTexelsIdx).fOffsetInRecord);
+    SkASSERT(offsetof(Instance, fColor) ==
+             coverProc.getAttrib(Attrib::kColor).fOffsetInRecord);
+    SkASSERT(offsetof(Instance, fDevBounds) ==
+             coverProc.getAttrib(Attrib::kDevBounds).fOffsetInRecord);
+    SkASSERT(offsetof(Instance, fDevBounds45) ==
+             coverProc.getAttrib(Attrib::kDevBounds45).fOffsetInRecord);
+#endif
+
+    GrMesh mesh(kTriangleStrip_GrPrimitiveType);
+    mesh.setInstanced(coversInstanceBuffer, op.instanceCount(), op.instancesIdxInGpuBuffer(), 8);
+
+    this->glGpu()->draw(pipeline, coverProc, &mesh, 1, nullptr);
+}
+
+}
