+template<typename T>
+static T calc_dot_cross_cubic(const SkPoint& p0, const SkPoint& p1, const SkPoint& p2) {
+    const T xComp = (T)p0.fX * ((T)p1.fY - (T)p2.fY);
+    const T yComp = (T)p0.fY * ((T)p2.fX - (T)p1.fX);
+    const T wComp = (T)p1.fX * (T)p2.fY - (T)p1.fY * (T)p2.fX;
+    return (xComp + yComp + wComp);
