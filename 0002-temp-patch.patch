+
+    // Optimizations.
+    bool drawFanHullsAndEdgesTogether() { return fDrawFanHullsAndEdgesTogether; }
+    bool useScissorForAtlasClear() { return fUseScissorForAtlasClear; }
+
+private:
+    StencilSupport onGetStencilSupport(const GrShape&) const final {
+        return GrPathRenderer::kNoSupport_StencilSupport;
+    }
+
+    bool onCanDrawPath(const CanDrawPathArgs& args) const final;
+    bool onDrawPath(const DrawPathArgs&) final;
+
+    void preFlush(GrOnFlushResourceProvider*, const uint32_t* opListIDs, int numOpListIDs,
+                  SkTArray<sk_sp<GrRenderTargetContext>>* results) override;
+    void postFlush() override;
+
+    struct CoverOpList : public SkTInternalLList<CoverOp> {
+        int fNumPaths = 0;
+    };
+
+    GrContext* const                              fContext;
+
+    std::map<uint32_t, CoverOpList>               fCoverOpLists;
+
+    sk_sp<GrBuffer>                               fPathTexelBuffer;
+    sk_sp<GrBuffer>                               fCoversInstanceBuffer;
+
+    sk_sp<PathMaskAtlas>                          fCurrentAtlas;
+
+    // Optimizations.
+    bool                                          fDrawFanHullsAndEdgesTogether;
+    bool                                          fUseScissorForAtlasClear;
+
+    typedef GrPathRenderer INHERITED;
+};
