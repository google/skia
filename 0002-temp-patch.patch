+// I(s,t) = t*(3*d0*s^2 - 3*d1*s*t + d2*t^2)
+// d0 = a1 - 2*a2+3*a3
+// d1 = -a2 + 3*a3
+// d2 = 3*a3
+// a1 = p0 . (p3 x p2)
+// a2 = p1 . (p0 x p3)
+// a3 = p2 . (p1 x p0)
+// Places the values of d1, d2, d3 in array d passed in
+template<typename T> static void calc_cubic_inflection_func(const SkPoint p[4], T d[4]) {
+    T a1 = calc_dot_cross_cubic<T>(p[0], p[3], p[2]);
+    T a2 = calc_dot_cross_cubic<T>(p[1], p[0], p[3]);
+    T a3 = calc_dot_cross_cubic<T>(p[2], p[1], p[0]);
+
+    d[3] = 3.f * a3;
+    d[2] = d[3] - a2;
+    d[1] = d[2] - a2 + a1;
+    d[0] = 0;
