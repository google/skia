diff --git a/src/gpu/ccpr/PathCoverProcessor.cpp b/src/gpu/ccpr/PathCoverProcessor.cpp
new file mode 100644
index 0000000000..cb39b8d366
--- /dev/null
+++ b/src/gpu/ccpr/PathCoverProcessor.cpp
@@ -0,0 +1,178 @@
+/*
+ * Copyright 2017 Google Inc.
+ *
+ * Use of this source code is governed by a BSD-style license that can be
+ * found in the LICENSE file.
+ */
+
+#include "PathCoverProcessor.h"
+
+#include "GrCaps.h"
+#include "GrContext.h"
+#include "GrRenderTargetPriv.h"
+#include "GrResourceCache.h"
+#include "GrResourceProvider.h"
+#include "glsl/GrGLSLGeometryProcessor.h"
+#include "glsl/GrGLSLFragmentShaderBuilder.h"
+#include "glsl/GrGLSLProgramBuilder.h"
+#include "glsl/GrGLSLVarying.h"
+
+constexpr float kAABloatRadius = 0.49f;
+
+
+namespace ccpr {
+
+PathCoverProcessor::PathCoverProcessor(GrResourceProvider* rp, sk_sp<GrTextureProxy> atlas,
+                                       GrBuffer* pathRecBuffer, SkPath::FillType fillType,
+                                       const GrShaderCaps& shaderCaps)
+    : fFillType(fillType) {
+    this->initClassID<PathCoverProcessor>();
+
+    this->addInstanceAttrib("texels_idx", kInt_GrVertexAttribType, kHigh_GrSLPrecision);
+    this->addInstanceAttrib("color", kVec4ub_GrVertexAttribType, kLow_GrSLPrecision);
+    this->addInstanceAttrib("dev_bounds", kVec4f_GrVertexAttribType, kHigh_GrSLPrecision);
+    this->addInstanceAttrib("dev_bounds45", kVec4f_GrVertexAttribType, kHigh_GrSLPrecision);
+
+    GR_STATIC_ASSERT(0 == int(Attrib::kPathTexelsIdx));
+    GR_STATIC_ASSERT(1 == int(Attrib::kColor));
+    GR_STATIC_ASSERT(2 == int(Attrib::kDevBounds));
+    GR_STATIC_ASSERT(3 == int(Attrib::kDevBounds45));
+    GR_STATIC_ASSERT(4 == kNumAttribs);
+
+    fPathBufferAccess.reset(kRGBA_float_GrPixelConfig, pathRecBuffer, kVertex_GrShaderFlag);
+    this->addBufferAccess(&fPathBufferAccess);
+
+    fAtlasAccess.reset(rp, std::move(atlas), GrSamplerParams::FilterMode::kNone_FilterMode,
+                       SkShader::TileMode::kClamp_TileMode, kFragment_GrShaderFlag);
+    this->addTextureSampler(&fAtlasAccess);
+    fAtlasAccess.instantiate(rp);
+}
+
+void PathCoverProcessor::getGLSLProcessorKey(const GrShaderCaps&, GrProcessorKeyBuilder* b) const {
+    b->add32((fFillType << 16) | this->atlas()->origin());
+}
+
+class GLSLPathCoverProcessor : public GrGLSLGeometryProcessor {
+public:
+    void onEmitCode(EmitArgs& args, GrGPArgs* gpArgs) override;
+
+private:
+    void setData(const GrGLSLProgramDataManager& pdman, const GrPrimitiveProcessor& pp,
+                 FPCoordTransformIter&& transformIter) override {
+        const PathCoverProcessor& pcp = pp.cast<PathCoverProcessor>();
+        pdman.set2f(fAtlasAdjustUniform, 1.0f / pcp.atlas()->width(), 1.0f / pcp.atlas()->height());
+        this->setTransformDataHelper(SkMatrix::I(), pdman, &transformIter);
+    }
+
+    GrGLSLUniformHandler::UniformHandle fAtlasAdjustUniform;
+
+    typedef GrGLSLGeometryProcessor INHERITED;
+};
+
+GrGLSLPrimitiveProcessor* PathCoverProcessor::createGLSLInstance(const GrShaderCaps&) const {
+    return new GLSLPathCoverProcessor();
+}
+
+void GLSLPathCoverProcessor::onEmitCode(EmitArgs& args, GrGPArgs* gpArgs) {
+    using Attrib = PathCoverProcessor::Attrib;
+    const PathCoverProcessor& pcp = args.fGP.cast<PathCoverProcessor>();
+    GrGLSLUniformHandler* uniHandler = args.fUniformHandler;
+    GrGLSLVaryingHandler* varyingHandler = args.fVaryingHandler;
+
+    const char* atlasAdjust;
+    fAtlasAdjustUniform = uniHandler->addUniform(
+            kVertex_GrShaderFlag,
+            kVec2f_GrSLType, kHigh_GrSLPrecision, "atlas_adjust", &atlasAdjust);
+
+    varyingHandler->emitAttributes(pcp);
+
+    GrGLSLVertToFrag texcoord(kVec2f_GrSLType);
+    GrGLSLVertToFrag color(kVec4f_GrSLType);
+    varyingHandler->addVarying("texcoord", &texcoord, kHigh_GrSLPrecision);
+    varyingHandler->addFlatPassThroughAttribute(&pcp.getAttrib(Attrib::kColor), args.fOutputColor,
+                                                kLow_GrSLPrecision);
+
+    // ---- Vertex shader --------------------------------------------------------------------------
+    GrGLSLVertexBuilder* v = args.fVertBuilder;
+
+    // Fetch the path info.
+    v->codeAppend ("highp mat2 M = mat2(");
+    v->appendTexelFetch(args.fTexelBuffers[0], pcp.getAttrib(Attrib::kPathTexelsIdx).fName);
+    v->codeAppend (");");
+    v->codeAppend ("highp vec4 packeddata = ");
+    v->appendTexelFetch(args.fTexelBuffers[0],
+                   SkStringPrintf("(%s + 1)", pcp.getAttrib(Attrib::kPathTexelsIdx).fName).c_str());
+    v->codeAppend (";");
+    v->codeAppend ("highp vec2 T = packeddata.xy;");
+    v->codeAppend ("highp vec2 atlas_offset = packeddata.zw;");
+
+    // Figure out where we are in device space.
+#if 0
+    v->codeAppendf("highp vec2 devcoord = vec2(%s[sk_VertexID & 2], "
+                                              "%s[2 * (sk_VertexID & 1) + 1]);",
+                   pcp.getAttrib(Attrib::kDevBounds).fName,
+                   pcp.getAttrib(Attrib::kDevBounds).fName);
+#elif 0
+    v->codeAppendf("highp vec2 devcoord = vec2(%s[sk_VertexID & 2], "
+                                                "%s[2 * (sk_VertexID & 1) + 1]);",
+                   pcp.getAttrib(Attrib::kDevBounds45).fName,
+                   pcp.getAttrib(Attrib::kDevBounds45).fName);
+    v->codeAppendf("devcoord *= (mat2(1, 1, -1, 1) * %f);",
+                   SK_ScalarRoot2Over2);
+#else
+    v->codeAppend ("int fanidx = int[8](0,1,7,2,6,3,5,4)[sk_VertexID];");
+    v->codeAppend ("int edgeidx = fanidx / 2;");
+    v->codeAppend ("lowp float dir = 1.0 - float(edgeidx & 2);"); // 0-1 -> +1; 2,3 -> -1
+    v->codeAppend ("highp vec2 n = vec2(1 - (edgeidx & 1), edgeidx & 1) * dir;");
+    v->codeAppendf("highp float k = %s[edgeidx] * dir;", pcp.getAttrib(Attrib::kDevBounds).fName);
+    v->codeAppendf("k -= %f;", kAABloatRadius); // bloat one half pixel.
+
+    v->codeAppend ("int edgeidx45 = ((fanidx + 1) / 2) % 4;");
+    v->codeAppend ("lowp float dir45 = (edgeidx45 < 2 ? 1.0 : -1.0);");
+    v->codeAppendf("highp vec2 v45 = vec2(2 * (edgeidx45 & 1) - 1, -1) * dir45;");
+    v->codeAppendf("highp vec2 o45 = edgeidx45 < 2 ? %s.xy : %s.zw;",
+                   pcp.getAttrib(Attrib::kDevBounds45).fName,
+                   pcp.getAttrib(Attrib::kDevBounds45).fName);
+    v->codeAppendf("o45 *= (mat2(1, 1, -1, 1) * %f);", SK_ScalarRoot2Over2); // xform to dev space.
+    v->codeAppendf("o45 -= vec2(-v45.y, +v45.x) * %f;", kAABloatRadius); // bloat one half pixel.
+
+    v->codeAppendf("highp float t = (k - dot(o45, n)) / dot(v45, n);");
+    v->codeAppendf("highp vec2 devcoord = o45 + t * v45;");
+#endif
+    gpArgs->fPositionVar.set(kVec2f_GrSLType, "devcoord");
+
+    // Convert to atlas coordinates.
+    v->codeAppend ("highp vec2 atlascoord = devcoord + atlas_offset;");
+    if (kTopLeft_GrSurfaceOrigin == pcp.atlas()->origin()) {
+        v->codeAppendf("%s = atlascoord * %s;", texcoord.vsOut(), atlasAdjust);
+    } else {
+        SkASSERT(kBottomLeft_GrSurfaceOrigin == pcp.atlas()->origin());
+        v->codeAppendf("%s = vec2(atlascoord.x * %s.x, 1.0 - atlascoord.y * %s.y);",
+                       texcoord.vsOut(), atlasAdjust, atlasAdjust);
+    }
+
+    // Convert to path cordinates.
+    v->codeAppend ("highp vec2 pathcoord = inverse(M) * (devcoord - T);");
+
+    this->emitTransforms(v, varyingHandler, uniHandler, gpArgs->fPositionVar, "pathcoord",
+                         args.fFPCoordTransformHandler);
+
+
+    // ---- Fragment shader ------------------------------------------------------------------------
+    GrGLSLPPFragmentBuilder* f = args.fFragBuilder;
+
+    f->codeAppend ("mediump float coverage_count = ");
+    f->appendTextureLookup(args.fTexSamplers[0], texcoord.fsIn(), kVec2f_GrSLType);
+    f->codeAppend (".a;");
+    if (1||SkPath::kWinding_FillType == pcp.fillType()) {
+        f->codeAppendf("%s = vec4(min(abs(coverage_count), 1.0));", args.fOutputCoverage);
+    } else {
+        f->codeAppend ("mediump float t = mod(abs(coverage_count), 2.0);");
+        f->codeAppendf("%s = vec4(1.0 - abs(t - 1.0));", args.fOutputCoverage);
+    }
+    // f->codeAppendf("%s = vec4(1);", args.fOutputCoverage);
+    // f->codeAppendf("%s = vec4(-(coverage_count), +(coverage_count), 0, abs(coverage_count));",
+    //                args.fOutputColor);
+}
+
+}
