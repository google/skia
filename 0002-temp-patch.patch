+bool CoverageCountingPathRenderer::onCanDrawPath(const CanDrawPathArgs& args) const {
+    SkPath path;
+    args.fShape->asPath(&path);
+
+    return args.fShape->style().isSimpleFill() &&
+           !path.isInverseFillType() &&
+           !SkPathPriv::ConicWeightCnt(path) &&
+           !args.fViewMatrix->hasPerspective() &&
+           GrAAType::kCoverage == args.fAAType;
+}
+
+static void get_tight_dev_bounds(const SkMatrix& m, const SkPath& path,
+                                 SkRect* devBounds, SkRect* devBounds45) {
+    SkASSERT(!m.hasPerspective());
+
+    SkMatrix m45;
+    m45.setSinCos(SK_ScalarRoot2Over2, SK_ScalarRoot2Over2);
+    m45.preConcat(m);
+
+    const SkPoint* const pts = SkPathPriv::PathRef(path)->points();
+    const int numPts = path.countPoints();
+    SkASSERT(numPts >= 2);
+
+#if !SK_SCALAR_IS_FLOAT
+    SkDebugf("warning: computing path tight bounds without Sk4f");
+    SkPoint pt, pt45;
+    m.mapPoints(&pt, pts, 1);
+    m45.mapPoints(&pt45, pts, 1);
+    devBounds->setLTRB(pt.x(), pt.y(), pt.x(), pt.y());
+    devBounds45->setLTRB(pt45.x(), pt45.y(), pt45.x(), pt45.y());
+    for (int i = 1; i < numPts; ++i) {
+        m.mapPoints(&pt, pts + i, 1);
+        m45.mapPoints(&pt45, pts + i, 1);
+        devBounds->setLTRB(SkTMin(devBounds->left(), pt.x()), SkTMin(devBounds->top(), pt.y()),
+                           SkTMax(devBounds->right(), pt.x()), SkTMax(devBounds->bottom(), pt.y()));
+        devBounds45->setLTRB(SkTMin(devBounds45->left(), pt45.x()),
+                             SkTMin(devBounds45->top(), pt45.y()),
+                             SkTMax(devBounds45->right(), pt45.x()),
+                             SkTMax(devBounds45->bottom(), pt45.y()));
+    }
+#else
+    const Sk4f scale(m.getScaleX(), m.getScaleY(), m45.getScaleX(), m45.getScaleY());
+    const Sk4f skew(m.getSkewX(), m.getSkewY(), m45.getSkewX(), m45.getSkewY());
+    const Sk4f translate(m.getTranslateX(), m.getTranslateY(),
+                         m45.getTranslateX(), m45.getTranslateY());
+
+    Sk4f twoPts = Sk4f::Load(pts);
+    Sk4f twoPtsT1 = scale * twoPts + skew * SkNx_shuffle<1,0,3,2>(twoPts);
+    Sk4f twoPtsT2 = scale * SkNx_shuffle<2,3,0,1>(twoPts) + skew * SkNx_shuffle<3,2,1,0>(twoPts);
+    Sk4f topLeft = Sk4f::Min(twoPtsT1, twoPtsT2);
+    Sk4f bottomRight = Sk4f::Max(twoPtsT1, twoPtsT2);
+    for (int i = 2; i < numPts; i += 2) {
+        twoPts = i + 1 < numPts ? Sk4f::Load(&pts[i])
+                                : Sk4f(pts[i].x(), pts[i].y(), pts[i].x(), pts[i].y());
+        twoPtsT1 = scale * twoPts + skew * SkNx_shuffle<1,0,3,2>(twoPts);
+        twoPtsT2 = scale * SkNx_shuffle<2,3,0,1>(twoPts) + skew * SkNx_shuffle<3,2,1,0>(twoPts);
+        topLeft = Sk4f::Min(topLeft, twoPtsT1);
+        bottomRight = Sk4f::Max(bottomRight, twoPtsT1);
+        topLeft = Sk4f::Min(topLeft, twoPtsT2);
+        bottomRight = Sk4f::Max(bottomRight, twoPtsT2);
+    }
+
+    topLeft += translate;
+    bottomRight += translate;
+
+    float topLeftStore[4], bottomRightStore[4];
+    topLeft.store(topLeftStore);
+    bottomRight.store(bottomRightStore);
+    devBounds->setLTRB(topLeftStore[0], topLeftStore[1], bottomRightStore[0], bottomRightStore[1]);
+    devBounds45->setLTRB(topLeftStore[2], topLeftStore[3],
+                         bottomRightStore[2], bottomRightStore[3]);
+
+    GR_STATIC_ASSERT(8 == sizeof(SkPoint));
+    GR_STATIC_ASSERT(0 == offsetof(SkPoint, fX));
+    GR_STATIC_ASSERT(4 == offsetof(SkPoint, fY));
+#endif
+}
