+namespace ccpr {
+
+PathMaskAtlas::PathMaskAtlas(const GrCaps& caps, int initialSize)
+    : fMaxTextureSize(caps.maxTextureSize())
+    , fBounds{0, 0} {
+    SkASSERT(fMaxTextureSize <= caps.maxRenderTargetSize());
+    int size = SkTMax(uint32_t(kMinSize), GrNextPow2(initialSize));
+    size = SkTMin(size, fMaxTextureSize);
+    fHeight = fWidth = size;
+    fTopNode = skstd::make_unique<Node>(nullptr, 0, 0, size, size);
+}
+
+PathMaskAtlas::~PathMaskAtlas() {
+}
+
+////////////////////////////////////////////////////////////////////////////////////////////////////
+// Allocating space
+
+class PathMaskAtlas::Node {
+public:
+    Node(std::unique_ptr<Node> previous, int l, int t, int r, int b)
+        : fPrevious(std::move(previous))
+        , fX(l), fY(t)
+        , fRectanizer(r - l, b - t) {}
+
+    Node* previous() const { return fPrevious.get(); }
+
+    bool addRect(int w, int h, SkIPoint16* loc) {
+        if (!fRectanizer.addRect(w, h, loc)) {
+            return false;
+        }
+        loc->fX += fX;
+        loc->fY += fY;
+        return true;
+    }
+
+private:
+    const std::unique_ptr<Node>   fPrevious;
+    const int                     fX, fY;
+    GrRectanizerSkyline           fRectanizer;
+};
+
+bool PathMaskAtlas::addRect(int w, int h, SkIPoint16* loc) {
+    SkASSERT(SkTMax(w, h) < fMaxTextureSize);
+
+    for (Node* node = fTopNode.get(); node; node = node->previous()) {
+        if (node->addRect(w, h, loc)) {
+            return true;
+        }
+    }
+
+    do {
+        SkASSERT(SkTMax(fWidth, fHeight) <= fMaxTextureSize);
+        if (fWidth == fMaxTextureSize && fHeight == fMaxTextureSize) {
+            return false;
+        }
+        if (fHeight <= fWidth) {
+            int top = fHeight;
+            fHeight = SkTMin(fHeight * 2, fMaxTextureSize);
+            fTopNode = skstd::make_unique<Node>(std::move(fTopNode), 0, top, fWidth, fHeight);
+        } else {
+            int left = fWidth;
+            fWidth = SkTMin(fWidth * 2, fMaxTextureSize);
+            fTopNode = skstd::make_unique<Node>(std::move(fTopNode), left, 0, fWidth, fHeight);
+        }
+    } while (!fTopNode->addRect(w, h, loc));
+
+    return true;
+}
+
+bool PathMaskAtlas::addPath(const SkPath& path, int texelsIdx, int devWidth, int devHeight,
+                            bool needsScissor, SkScalar approximationTolerance, SkIPoint16* loc) {
+    // This can't be called anymore once lazyTexture() has been called.
+    SkASSERT(!fTexture);
+
+    if (!this->addRect(devWidth, devHeight, loc)) {
+        return false;
+    }
+    fBounds = {SkTMax(fBounds.width(), loc->x() + devWidth),
+               SkTMax(fBounds.height(), loc->y() + devHeight)};
+
+    return true;
+}
+
+}
