      "writtenOn": "2021-07-03T01:48:00Z",
      "side": 1,
      "message": "Is there a reason to implement all the polymorphic behaviors in Type via switch or if statements? This code seems like a textbook example where virtual functions would typically be used. Base class returns -1, Literal and Scalar classes override it.",
      "range": {
        "startLine": 85,
        "startChar": 0,
        "endLine": 94,
        "endChar": 1
      },
      "revId": "2329efae28ea0a3dc58002c9bc5458285c92cc43",
