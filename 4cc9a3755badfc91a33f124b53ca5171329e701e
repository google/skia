    {
      "key": {
        "uuid": "d02bfb06_83e39be1",
        "filename": "modules/skottie/src/Animator.cpp",
        "patchSetId": 3
      },
      "lineNbr": 242,
      "author": {
        "id": 5641
      },
      "writtenOn": "2020-02-14T20:33:48Z",
      "side": 1,
      "message": "It\u0027s related in a roundabout way: with external storage, a clever way to detect constant values is to look at the size of the storage array - thanks to tail-deduping, if all values are equal we end up storing exactly one value (see previous KeyframeAnimator::isConstant).\n\nFor inline storage we no longer get this for free, and have to check each \"value\".  But we kinda need to do it in the type-independent base class, and if we do it for inline values we get it for external values too - so we might as well drop the old method.\n\n(note that in the end this \"isConstant\" bit of information is used to discard the animator altogether, so it doesn\u0027t matter much how it\u0027s determined/encoded as long as it\u0027s cheap - see line 477)\n\nAll that said, it\u0027s certainly a change we can spin off if you think it\u0027s clearer - it just won\u0027t have any interesting effects on its own.",
      "parentUuid": "338f7dc0_238ff71e",
      "range": {
        "startLine": 237,
        "startChar": 8,
        "endLine": 242,
        "endChar": 0
      },
      "revId": "4cc9a3755badfc91a33f124b53ca5171329e701e",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
