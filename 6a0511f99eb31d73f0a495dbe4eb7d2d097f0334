      "writtenOn": "2016-12-02T16:21:35Z",
      "side": 1,
      "message": "Not sure we shouldn\u0027t just copy the rect, but if you want to just point at canvas\u0027 copy, then the API should take a pointer to make that clear.",
      "range": {
        "startLine": 97,
        "startChar": 9,
