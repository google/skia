        "id": 5641
      },
      "writtenOn": "2018-12-06T14:53:39Z",
      "side": 1,
      "message": "Does _currentTransform ever diverge from _canvas.getTotalMatrix()?  Can we just use the _canvas transform instead?",
      "range": {
        "startLine": 1188,
        "startChar": 11,
        "endLine": 1188,
        "endChar": 28
      },
      "revId": "61eaf5604d817ae30ff63f69015ce95c605e8542",
