      },
      "lineNbr": 210,
      "author": {
        "id": 5140
      },
      "writtenOn": "2017-03-10T16:48:47Z",
      "side": 1,
      "message": "Because the actual size may have changed.",
      "parentUuid": "359282eb_6bb354e4",
      "range": {
        "startLine": 210,
        "startChar": 22,
        "endLine": 210,
        "endChar": 33
      },
      "revId": "e61ca4daeac8d8461846051bd854e31b754bb9bb",
