      "~^desk_skbug6850overlay2.skp_1_mpd$",
      "~^fontscaler_lcd$",
      "~^rotated_rects_aa_changing_transparent_src$",
      "~^rotated_rects_aa_same_transparent_src$",
      "~^srcmode_rects_1_aa$",
