      "writtenOn": "2020-07-22T18:28:14Z",
      "side": 1,
      "message": "Since we\u0027re renaming this, can we call it hasCoverageFragmentProcessor()? The clip is redundant with it being on GrAppliedClip, and then it matches the name on GrPaint.",
      "range": {
        "startLine": 108,
        "startChar": 8,
        "endLine": 108,
        "endChar": 40
      },
      "revId": "41c6efd550eb494803a75fd466a9f87c904978b1",
