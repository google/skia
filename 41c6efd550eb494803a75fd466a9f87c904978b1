    {
      "key": {
        "uuid": "f057e835_d0679bf2",
        "filename": "src/gpu/GrAppliedClip.h",
        "patchSetId": 4
      },
      "lineNbr": 130,
      "author": {
        "id": 11059
      },
      "writtenOn": "2020-07-22T20:54:39Z",
      "side": 1,
      "message": "Based on the discussion in chat this morning I don\u0027t think we want an Xfermode, because we don\u0027t want to enforce how clip processors choose to mix their inputs. They should be responsible for taking the input and modifying it as they see fit; forcing a particular blend mode on them prevents that.",
      "parentUuid": "4341ffbc_e2a24849",
      "range": {
        "startLine": 126,
        "startChar": 11,
        "endLine": 130,
        "endChar": 95
      },
