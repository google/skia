    {
      "key": {
        "uuid": "5e844f98_46a2494f",
        "filename": "infra/bots/recipe_modules/build/docker.py",
        "patchSetId": 18
      },
      "lineNbr": 30,
      "author": {
        "id": 5120
      },
      "writtenOn": "2019-11-15T15:51:39Z",
      "side": 1,
      "message": "My hope is that we would periodically recreate this image with latest Debian and latest of the other packages installed. These would presumably have the same version of GCC.\n\nOne option for that would be to use the date-tagged Debian images, e.g. buster-20191014-slim, in which case we could remove the \u0027apt-get upgrade\u0027 and use that date as the version.\n\nBut TBH, it doesn\u0027t seem to have a favorable cost-benefit to specify a version everywhere, e.g. the Dockerfile and the Makefile can get out of sync, and three places to update a version instead of one.",
      "parentUuid": "f04190d1_55a41bcf",
      "revId": "d561b4563be4936f56d4526fb6b5f22fa75ae3ea",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": false
    },
