    {
      "key": {
        "uuid": "05abf1f2_addc28a2",
        "filename": "src/codec/SkGifCodec.cpp",
        "patchSetId": 15
      },
      "lineNbr": 151,
      "author": {
        "id": 5631
      },
      "writtenOn": "2018-08-14T16:41:29Z",
      "side": 1,
      "message": "skcms doesn\u0027t really have a preference. It does always assume RGB order when loading and storing, but if you use the BGR PixelFormats, it just adds a channel swap step (after load/before store) in the pipeline it builds. So yeah, things are a tiny bit faster with RGB.",
      "revId": "25b9b40cd26481b9197ef396c7d4ed0e05c182a9",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
