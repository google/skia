    {
      "key": {
        "uuid": "b0d240e7_db24667c",
        "filename": "include/gpu/GrContext.h",
        "patchSetId": 3
      },
      "lineNbr": 433,
      "author": {
        "id": 5036
      },
      "writtenOn": "2020-05-19T15:52:05Z",
      "side": 1,
      "message": "I am going to implement the submitted callback in the next follow on CL. I\u0027d rather land this as is for now to make sure we don\u0027t see any major regressions from using the submit API. The callbacks are also just a helper so the client doesn\u0027t need to keep track of which flushes have been submitted by which submit calls. But technically everything could be done with this CL only if the client does more manual tracking.",
      "parentUuid": "ec90548d_0fbbe24b",
      "range": {
        "startLine": 433,
        "startChar": 4,
        "endLine": 433,
        "endChar": 9
      },
