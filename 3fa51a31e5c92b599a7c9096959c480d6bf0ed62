    {
      "key": {
        "uuid": "1c89518a_7bf3b567",
        "filename": "tests/GrSurfaceTest.cpp",
        "patchSetId": 3
      },
      "lineNbr": 686,
      "author": {
        "id": 5036
      },
      "writtenOn": "2019-05-29T13:38:10Z",
      "side": 1,
      "message": "In general I don\u0027t think so. Clients may have their own way on knowing when it is safe to delete a backend texture object (like using the finish procs on flush). So it is better to not force this sync on everyone. Plus, we are moving towards a world where we want clients to explicitly be calling flush and not have flushing being a side effect of a bunch of different calls like it is today.",
      "parentUuid": "c14bef4d_37098089",
