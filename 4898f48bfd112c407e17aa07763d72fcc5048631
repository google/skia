        "id": 5045
      },
      "writtenOn": "2020-08-06T14:35:56Z",
      "side": 1,
      "message": "I think this really is allow... there are features of SkRuntimeEffect that we don\u0027t want to let SkColorFilters have access to.",
      "parentUuid": "35da9c8b_7420cd0d",
      "range": {
        "startLine": 185,
        "startChar": 11,
        "endLine": 185,
        "endChar": 28
      },
      "revId": "4898f48bfd112c407e17aa07763d72fcc5048631",
