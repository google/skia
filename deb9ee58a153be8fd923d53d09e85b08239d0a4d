        "id": 5065
      },
      "writtenOn": "2018-05-24T18:52:48Z",
      "side": 1,
      "message": "It looks like fSize is only set at creation. Subruns are allocated on the heap, but not tracked.",
      "parentUuid": "d51c1dab_870548e3",
      "range": {
        "startLine": 168,
        "startChar": 23,
        "endLine": 168,
        "endChar": 35
