    {
      "key": {
        "uuid": "9abf3284_af749ead",
        "filename": "tests/SkRuntimeEffectTest.cpp",
        "patchSetId": 1
      },
      "lineNbr": 87,
      "author": {
        "id": 5631
      },
      "writtenOn": "2020-07-22T17:46:56Z",
      "side": 1,
      "message": "Not a great one, no. I could use GrColor, which is spec\u0027d to always be RGBA. SkColor is defined to be unpremul (and BGRA). SkPMColor is premul, but the byte order depends on compile flags. I switched them to GrColor (we can safely use that in unit tests, because we always have the GPU backend present).",
      "parentUuid": "ca0a0644_be02835f",
      "range": {
        "startLine": 87,
        "startChar": 14,
        "endLine": 87,
        "endChar": 22
      },
      "revId": "6c46dea40ce6df4140063290cce437e812a63f68",
