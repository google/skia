      "writtenOn": "2020-07-22T15:46:15Z",
      "side": 1,
      "message": "Do we have a more descriptive type we could use for these color inputs? (e.g. something like GrColor but not Ganesh-specific) From their names alone they seem more like point coordinates.",
      "range": {
        "startLine": 87,
        "startChar": 14,
        "endLine": 87,
        "endChar": 22
      },
      "revId": "6c46dea40ce6df4140063290cce437e812a63f68",
