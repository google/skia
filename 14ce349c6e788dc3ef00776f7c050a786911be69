    },
    {
      "unresolved": true,
      "key": {
        "uuid": "60e24d2a_dc7e91c5",
        "filename": "src/sksl/dsl/DSLVar.cpp",
        "patchSetId": 2
      },
      "lineNbr": 43,
      "author": {
        "id": 11059
      },
      "writtenOn": "2021-01-08T17:57:05Z",
      "side": 1,
      "message": "This lookup (for the non-owned variable-by-name case) would happen every time var() is called.\n\nThis means that DSLVar(\"foo\") could actually refer to totally distinct `foo` variables, if more than one `foo` exists in the code, depending on what scope we\u0027re in when var() is called. It \nalso has a sneaky performance cost; this feels like a freebie accessor, not a recursive hash table lookup.",
      "range": {
        "startLine": 40,
        "startChar": 0,
        "endLine": 43,
        "endChar": 41
      },
      "revId": "14ce349c6e788dc3ef00776f7c050a786911be69",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02"
    },
