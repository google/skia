      },
      "lineNbr": 35,
      "author": {
        "id": 5640
      },
      "writtenOn": "2021-01-08T19:50:56Z",
      "side": 1,
      "message": "\"Lookup mode\", so to speak, should have been private. The only public function of this class is creating new variables. I\u0027ve made the other constructor private.",
      "parentUuid": "5363ea89_d791b30b",
      "range": {
        "startLine": 21,
        "startChar": 0,
        "endLine": 35,
        "endChar": 0
      },
      "revId": "14ce349c6e788dc3ef00776f7c050a786911be69",
