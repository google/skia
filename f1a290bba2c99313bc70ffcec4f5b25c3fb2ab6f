        "id": 5255
      },
      "writtenOn": "2018-07-31T20:23:30Z",
      "side": 1,
      "message": "Yes. SkCodec\u0027s API is intended to hide any knowledge frame-rects being subset from the image-rect. So the SkCodec implementation has to fill all of those pixels with something (unless they were filled by a prior frame).",
      "parentUuid": "e1e2a948_24c59353",
      "range": {
        "startLine": 313,
        "startChar": 0,
        "endLine": 318,
        "endChar": 30
      },
      "revId": "f1a290bba2c99313bc70ffcec4f5b25c3fb2ab6f",
      "serverId": "5086850b-e599-37d2-8ec8-ff16aeccbf02",
      "unresolved": true
    },
