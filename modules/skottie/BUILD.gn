config("public_config") {
  defines = [ "SK_ENABLE_SKOTTIE" ]
  include_dirs = [ "include" ]
}

source_set("skottie") {
  import("skottie.gni")
  public_configs = [ ":public_config" ]
  public = skia_skottie_public
  sources = skia_skottie_sources
  configs += [ "../../:skia_private" ]
  deps = [
    "../..:skia",
    "../sksg",
  ]
}
